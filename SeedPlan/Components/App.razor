<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="components.css" /> @* Din nya fil för gemensamma element *@
    <link rel="stylesheet" href="SeedPlan.styles.css" /> @* Denna behövs för isolerad CSS (t.ex. .razor.css) *@
    <link rel="manifest" href="manifest.webmanifest">
    
    @* Laddar Lucide-ikonerna *@
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <HeadOutlet @rendermode="new InteractiveWebAssemblyRenderMode(prerender: false)" />
</head>
<body>
    <div id="app">
    <Routes @rendermode="new InteractiveWebAssemblyRenderMode(prerender: false)" />
    </div>
    <script src="_framework/blazor.web.js"></script>

    @* BARA en säker funktion som vi kallar på manuellt, INGEN Observer som kraschar appen *@
    <script>
        let lucideTimer;
    
        window.initializeLucide = () => {
        if (window.lucide) {
        // Avbryt tidigare timer om en ny ändring sker snabbt
        clearTimeout(lucideTimer);
            
        lucideTimer = setTimeout(() => {
        window.lucide.createIcons();
        }, 100);
        }
        };
    </script>
</body>
</html>
<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8" />
    <title>SeedPlan | Din smarta såkalender & fröinventerare</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="SeedPlan hjälper dig planera din trädgård med smart såkalender baserad på ditt frostdatum. Håll koll dina fröer och sådder enkelt.">
    <meta name="keywords" content="såkalender, trädgårdsplanering, fröer, odling, plantera, sådatum, frökoll, fröinventering, fröapp, såplanering, försådd">
    <base href="/" />
    <link rel="preload" href="_framework/blazor.web.js" as="script" />
    <link rel="preload" href="_framework/dotnet.native.wasm" as="fetch" type="application/wasm" crossorigin="anonymous" />
    <link rel="preload" href="_framework/System.Private.CoreLib.wasm" as="fetch" type="application/wasm" crossorigin="anonymous" /> 
    <link rel="preload" href="small-logo.webp" as="image" />
    <!-- Preload main body font — breaks the fonts.css → woff2 cascade chain -->
    <link rel="preload" href="/fonts/inter-normal-latin.woff2" as="font" type="font/woff2" crossorigin>

    <!-- All CSS is async: the splash screen uses only inline styles,
         so no stylesheet is needed before Blazor hydrates. -->
    <link rel="stylesheet" href="fonts.css" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="fonts.css" /></noscript>

    <link href="_content/Cropper.Blazor/cropper.min.css" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="_content/Cropper.Blazor/cropper.min.css" rel="stylesheet"></noscript>

    <script src="notifications.js?v=4" defer></script>
    <script src="session-cleanup.js?v=5" defer></script>

    <link rel="stylesheet" href="app.css" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="app.css" /></noscript>

    <link rel="stylesheet" href="components.css" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="components.css" /></noscript>

    <link rel="stylesheet" href="SeedPlan.styles.css" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="SeedPlan.styles.css" /></noscript>

    <link href="_content/Blazicons/css/blazicons.min.css" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="_content/Blazicons/css/blazicons.min.css" rel="stylesheet"></noscript>
    <link rel="manifest" href="manifest.webmanifest">
    <script type="application/ld+json">
        {
        "context": "https://schema.org",
        "type": "WebApplication",
        "name": "SeedPlan",
        "url": "https://seedplan.app",
        "logo": "https://seedplan.se/icon-512.png",
        "description": "Smart trädgårdsapp för såddplanering",
        "applicationCategory": "LifestyleApplication",
        "operatingSystem": "Any",
        "availableLanguage": "Swedish",
        "areaServed": {
        "type": "Country",
        "name": "Sweden"
        }
        }
    </script>

    <HeadOutlet @rendermode="new InteractiveWebAssemblyRenderMode(prerender: false)" />

    <style>
        /* CSS for the splash loading spinner */
        @@keyframes sp-spin {
        0% {
        transform: rotate(0deg);
        }

        100% {
        transform: rotate(360deg);
        }
        }
    </style>
</head>
<body>
    <div id="blazor-splash" style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; background-color: #f8fafc; font-family: sans-serif; text-align: center; padding: 20px;">
        <img src="small-logo.webp" alt="SeedPlan Logotyp" width="100" height="100" style="margin-bottom: 20px;" fetchpriority="high" loading="eager">
        <h1 style="color: #2c5e3b; margin: 0; font-size: 2rem;">SeedPlan</h1>
        <p style="color: #64748b; margin-top: 10px;">Laddar din digitala trädgård...</p>
        <div style="margin-top: 24px; width: 40px; height: 40px; border: 4px solid #e2e8f0; border-top-color: #2c5e3b; border-radius: 50%; animation: sp-spin 1s linear infinite;"></div>
    </div>

    <div id="app">
        <Routes @rendermode="new InteractiveWebAssemblyRenderMode(prerender: false)" />
    </div>
    <script src="_framework/blazor.web.js"></script>

    <script>
        // Looks for the app-shell class rendered by MainLayout.razor
        var checkAppLoaded = setInterval(function() {
        if(document.querySelector('.app-shell') || document.querySelector('.planner-shell')) {
        var splash = document.getElementById('blazor-splash');
        if(splash) {
        splash.style.display = 'none';
        }
        clearInterval(checkAppLoaded);
        }
        }, 50); // Check every 50 milliseconds
    </script>

    <script>
        if ('serviceWorker' in navigator && window.location.hostname === 'localhost') {
        navigator.serviceWorker.getRegistrations().then(regs => {
        regs.forEach(reg => reg.unregister());
        });
        }
    </script>
    <script src="_content/Cropper.Blazor/cropper.min.js" type="module"></script>
</body>

</html>

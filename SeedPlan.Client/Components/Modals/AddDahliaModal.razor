@inject IUserDahliaService UserDahliaService
@inject Supabase.Client Supabase
@inject IDahliaService DahliaService
@inject IJSRuntime JS
@using Cropper.Blazor.Components
@using Cropper.Blazor.Exceptions
@using Cropper.Blazor.Models
@using System.Text.RegularExpressions

@if (IsVisible)
{
    <div class="modal-overlay" @onclick="Close">
        <div class="modal-card fade-in" @onclick:stopPropagation>
            <header class="modal-header">
                <h2 class="serif-title">Lägg till dahlia</h2>
            </header>

            <div class="modal-body">
                <div class="input-block">
                    <label>NAMN</label>
                    @if (selectedDahlia == null)
                    {
                        <input type="text" @bind="searchText" @bind:event="oninput"
                               placeholder="T.ex. Lindas baby" class="sp-input" />
                        
                        @if (!string.IsNullOrEmpty(searchText))
                        {
                            <div class="sp-dropdown">
                                @foreach (var dahlia in GetSearchResults())
                                {
                                    <div class="sp-dropdown-item" @onclick="() => SelectResult(dahlia)">
                                        <span>@dahlia.Name</span>
                                    </div>
                                }
                           
                            <div class="sp-dropdown-item create-new-item" @onclick="PrepareToCreateNew">
                                <span>➕ Skapa ny sort: "@searchText"</span>
                            </div>
                            </div>
                        }
                    }
                    @if (isDahliaSelected && !isCreatingNewVariety)
                    {
                        <div class="readonly-box">
                            <span>@selectedDahlia.Name</span>
                            <span class="sp-change-link" @onclick="ChangePlant">Byt</span>
                        </div>
                        <div class="info-grid">
                            <div class="info-box">
                                <label>FÄRG</label>
                                <span>@selectedDahlia.Color</span>
                            </div>
                            <div class="info-box">
                                <label>TYP</label>
                                <span>@selectedDahlia.GetTypeName();</span>
                            </div>
                            <div class="info-box">
                                <label>HÖJD</label>
                                <span>@selectedDahlia.Height cm</span>
                            </div>
                            <div class="info-box">
                                <label>BLOMSTORLEK</label>
                                <span>@selectedDahlia.GetSize();</span>
                            </div>
                        </div>
                    }
                    else if (isCreatingNewVariety)
                    {
                    <div class="readonly-box" style="background: #eef8f1; border-color: #4CAF50;">
                        <span>Ny sort: @customVariety.Name</span>
                        <span class="sp-change-link" @onclick="ChangePlant">Avbryt</span>
                    </div>
    
                    <div class="info-grid custom-inputs">
                        <div class="input-block">
                            <label>FÄRG</label>
                            <input type="text" @bind="customVariety.Color" placeholder="T.ex. Rosa/Vit" />
                        </div>
                        <div class="input-block">
                            <label>HÖJD (cm)</label>
                            <input type="number" @bind="customVariety.Height" />
                        </div>
                        <div class="input-block">
                            <label>BLOMSTORLEK</label>
                                <select @bind="customVariety.Size" class="sp-input">
                                    <option value="">Välj en storleksgrupp</option>
                                    @foreach (DahliaSize size in Enum.GetValues(typeof(DahliaSize)))
                                    {
                                        <option value="@size">@GetSizeName(size)</option>
                                    }
                                </select>
                        </div>
                            <div class="input-block">
                                <label>BLOMTYP</label>
                                <select @bind="customVariety.Type" class="sp-input">
                                    <option value="">Välj en kategori</option>
                                    @foreach (DahliaType type in Enum.GetValues(typeof(DahliaType)))
                                    {
                                        <option value="@type">@GetTypeName(type)</option>
                                    }
                                </select>
                            </div>
                    </div>
                    }
                </div>
                <ImageCropperUploader TItem="UserDahlia"
                                      Item="newDahlia"
                                      BucketName="dahlia-images" />

               

                <div class="sp-grid-2">
                    <div class="input-block">
                        <label>BETYG</label>
                        <StarRating @bind-Rating="@newDahlia.Rating" />
                    </div>
                    <div class="input-block">
                        <label>ANTAL</label>
                        <div class="qty-wrapper">
                            <input type="number" @bind="newDahlia.HaveQty" />
                            <span class="unit-tag"> st</span>
                        </div>
                    </div>
                    
                </div>

                <div class="sp-grid-2">
                    <div class="input-block">
                        <label>PLATS</label>
                        <input type="text" @bind="newDahlia.Location" placeholder="I förrådet, köksfönstret etc." />
                    </div>
                    <div class="sp-input-block">
                        <label>INKÖPSSTÄLLE</label>
                        <input type="text" @bind="newDahlia.Source" />
                    </div>
                </div>

                <div class="input-block">
                    <label>ANTECKNINGAR</label>
                    <textarea @bind="newDahlia.Notes" placeholder="Nybeställd, favorit, virus?"></textarea>
                </div>
                
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <p class="error-msg" style="color: red; text-align:center;">@errorMessage</p>
                }
                
                <button type="button" class="sp-save-btn" @onclick="Save">Spara dahlia</button>
                <button type="button" class="sp-cancel-btn" @onclick="Close">Avbryt</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private bool isCreatingNewVariety = false;
    private Dahlia customVariety = new Dahlia(); 
    private string searchText = "";
    private bool isDahliaSelected = false;
    private List<Dahlia> allDahlias = new();
    private Dahlia? selectedDahlia;
    private UserDahlia newDahlia = new UserDahlia();
    private string errorMessage = "";
    private bool isUploadingImage = false;
    private bool hasAcceptedImageTerms = false;
    private bool hasCheckedTerms = false;


    protected override async Task OnParametersSetAsync()
    {
        await Task.Delay(50);
    }

    protected override async Task OnInitializedAsync()
    {
        allDahlias = await DahliaService.GetAllDahliasAsync();

    }

    private List<Dahlia>GetSearchResults()
    {
        if(string.IsNullOrWhiteSpace(searchText))
        {
            return new List<Dahlia>();
        }
        var term = searchText.Trim().ToLower();
        return DahliaService.SearchDahliasAsync(term).Result.ToList();
    }

    private void SelectResult(Dahlia res)
    {
        selectedDahlia = res;
        newDahlia.VarietyId = res.Id;
        newDahlia.Variety = res;
        searchText = "";
        isDahliaSelected = true;
    }

    private void ChangePlant()
    {
        selectedDahlia = null;
        newDahlia.Id = 0;
        newDahlia.VarietyId = ""; 
        newDahlia.Variety = null;
        isDahliaSelected = false;
    }

    public class SearchResult
    {
        public Dahlia? Dahlia { get; set; }
        public string DisplayName { get; set; } = "";
    }

    private void Close() => OnClose.InvokeAsync();

    private void PrepareToCreateNew()
    {
        errorMessage = "";

        if (IsNameTooSimilar(searchText))
        {
            errorMessage = "Det verkar redan finnas en sort med det namnet (eller ett väldigt likt namn). Leta i listan igen!";
            return;
        }

        customVariety = new Dahlia { Name = searchText }; 
        isCreatingNewVariety = true;
        searchText = "";
    }

    private async Task Save()
    {
        try
        {
            errorMessage = "";
            if(isCreatingNewVariety)
            {
                if (string.IsNullOrWhiteSpace(customVariety.Color) || customVariety.Height <= 0 || customVariety.Size == null )
                {
                    errorMessage = "Du måste fylla i färg, höjd, typ och storlek för den nya sorten.";
                    return;
                }
                customVariety.IsApproved = false;
                var insertedVariety = await DahliaService.AddDahliaVarietyAsync(customVariety);

                newDahlia.VarietyId = insertedVariety.Id;

                await JS.InvokeVoidAsync("alert", $"Tack! Din nya sort '{customVariety.Name}' har lagts till bland dina knölar. Den skickas också till admin för granskning innan den blir sökbar för andra.");

            }
            else if (selectedDahlia == null)
            {
                await JS.InvokeVoidAsync("alert", "Du måste välja eller skapa en sort först.");
                return;
            }

            if (newDahlia.HaveQty <= 0)
            {
                await JS.InvokeVoidAsync("alert", "Antal knölar kan inte vara under 0.");
                return;
            }

            await UserDahliaService.AddUserDahliaAsync(newDahlia);

            newDahlia = new UserDahlia();
            selectedDahlia = null;
            searchText = "";
            isDahliaSelected = false;

            await OnSaved.InvokeAsync();
            Close();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
    private bool IsNameTooSimilar(string proposedName)
    {
        
        var cleanProposed = Regex.Replace(proposedName.ToLower(), @"[^a-zåäö]", "");

        return allDahlias.Any(d =>
        {
            var cleanExisting = Regex.Replace(d.Name.ToLower(), @"[^a-zåäö]", "");
            return cleanExisting == cleanProposed;
        });
    }
    public string GetSizeName(DahliaSize size) => size switch
    {
        DahliaSize.Under5 => "5 <",
        DahliaSize.Size5to10 => "5 - 10",
        DahliaSize.Size10to15 => "10 - 15",
        DahliaSize.Size15to20 => "15 - 20",
        DahliaSize.Size20to25 => "20 - 25",
        DahliaSize.Over25 => "25 <",
        _ => size.ToString()
    };

    public string GetTypeName(DahliaType type) => type switch
    {
        DahliaType.Decorative => "Dekorativ",
        DahliaType.DecorativeGiants => "Dekorativ Jätte",
        DahliaType.DecorativeDwarfs => "Dekorativ Dvärg",
        DahliaType.DecorativeSmall => "Dekorativ Liten",
        DahliaType.DecorativeLarge => "Dekorativ Stor",
        DahliaType.Anemone => "Anemon",
        DahliaType.Ball => "Boll",
        DahliaType.Cactus => "Kaktus",
        DahliaType.SemiCactus => "Semikaktus",
        DahliaType.DwarfCactus => "Dvärgkaktus",
        DahliaType.Pompon => "Pompon",
        DahliaType.Waterlily => "Näckros",
        DahliaType.Mignon => "Mignon",
        DahliaType.Collarette => "Halskrås",
        DahliaType.Exclusive => "Esklusiva",
        DahliaType.Fringed => "Fransade",
        DahliaType.Orchid => "Orkide",
        DahliaType.Other => "Övriga",
        DahliaType.Peony => "Pion",
        DahliaType.Single => "Enkla",
        DahliaType.Stellar => "Stellar",
        _ => type.ToString()
    };
}
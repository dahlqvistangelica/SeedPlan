@inject IJSRuntime JS 

@if (Seed != null)
{
    <div class="seed-card @(SeedInventoryHelper.IsOutOfStock(Seed.Quantity) ? "low-stock" : "")" @onclick="HandleCardClick">
        <div class="seed-info">
            <h3>@(string.IsNullOrEmpty(Seed.VarietyName) ? Seed.Name : Seed.VarietyName)</h3>

            <div class="seed-meta">
                @if (Seed.PurchaseDate.HasValue)
                {
                    <span class="seed-meta-line">Köpt @Seed.PurchaseDate.Value.ToString("yyyy-MM-dd")</span>
                }

                @if (!string.IsNullOrWhiteSpace(Seed.PurchaseLocation))
                {
                    <span class="seed-meta-line">@Seed.PurchaseLocation</span>
                }

                @if (Seed.GerminationRate.HasValue)
                {
                    <span class="seed-meta-line">Grobarhet: @Seed.GerminationRate.Value%</span>
                }
            </div>

            @if (SeedInventoryHelper.IsOutOfStock(Seed.Quantity))
            {
                <span class="expiry-tag low-stock">
                    Slut i lager
                </span>
            }
            else if (SeedInventoryHelper.IsExpired(Seed.ExpiryDate))
            {
                var expiryDate = Seed.ExpiryDate!.Value;
                <span class="expiry-tag expired">
                    Utgångsdatum: @expiryDate.ToString("yyyy-MM-dd")
                </span>
            }
            else if (SeedInventoryHelper.IsExpiringSoon(Seed.ExpiryDate, Seed.Quantity))
            {
                var expiryDate = Seed.ExpiryDate!.Value;
                <span class="expiry-tag warning">
                    Utgångsdatum: @expiryDate.ToString("yyyy-MM-dd")
                </span>
            }

            @if (SeedInventoryHelper.ParseTags(Seed.PlantTags).Any())
            {
                <div class="seed-tags">
                    @foreach (var tag in SeedInventoryHelper.ParseTags(Seed.PlantTags))
                    {
                        <span class="seed-tag-chip">@tag</span>
                    }
                </div>
            }
        </div>
        <div class="seed-actions">
            <div class="qty-badge @(SeedInventoryHelper.IsOutOfStock(Seed.Quantity) ? "out-of-stock" : "")" onclick="Open">
                <Blazicon Svg="MdiIcon.SeedOutline" />
                <span class="qty">@Seed.Quantity st</span>
            </div>
            <div class="arrow-icon"><Blazicon Svg="Lucide.ChevronRight" /></div>
            @* DELETEBUTTON. *@
            <button class="delete-seed-btn" @onclick="() => HandleDelete(Seed)" @onclick:stopPropagation="true">
                <Blazicon Svg="Lucide.Trash2" />
            </button>
        </div>
    </div>
}
@code {
    [Parameter] public SeedView Seed { get; set; } = new();
    [Parameter] public EventCallback<SeedView> OnDelete { get; set; }
    [Parameter] public EventCallback<SeedView> OnClick { get; set; }

    private async Task HandleCardClick()
    {
        if (OnClick.HasDelegate)
        {
            await OnClick.InvokeAsync(Seed);
        }
    }

    private async Task HandleDelete(SeedView seed)
    {
        await OnDelete.InvokeAsync(seed);
    }

}

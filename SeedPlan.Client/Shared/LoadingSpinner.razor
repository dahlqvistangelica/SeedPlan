<div class="loading-container">
    <div class="sp-spinner"></div>
    @if (!string.IsNullOrWhiteSpace(Text))
    {
        <p class="loading-text">@Text</p>
    }
</div>

@code {
    // Gör att du kan skicka in valfri text, t.ex. <LoadingSpinner Text="Hämtar fröer..." />
    [Parameter]
    public string Text { get; set; } = "Laddar...";
}
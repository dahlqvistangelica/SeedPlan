@using System.ComponentModel.DataAnnotations
@using SeedPlan.Client.Services
@inject AuthService Auth
@inject NavigationManager Nav

<div class="auth-container">
    <h3>Skapa konto</h3>
    <p>Börja planera din trädgård genom att registrera dig nedan.</p>

    <EditForm Model="@regData" OnValidSubmit="HandleRegister">
        <DataAnnotationsValidator />
        
        <div class="form-group">
            <label>Förnamn</label>
            <InputText @bind-Value="regData.FirstName" class="form-control" placeholder="Ditt förnamn" />
            <ValidationMessage For="@(() => regData.FirstName)" />
        </div>

        <div class="form-group">
            <label>Efternamn</label>
            <InputText @bind-Value="regData.LastName" class="form-control" placeholder="Ditt efternamn" />
            <ValidationMessage For="@(() => regData.LastName)" />
        </div>

        <div class="form-group">
            <label>E-post</label>
            <InputText @bind-Value="regData.Email" class="form-control" type="email" placeholder="din@epost.se" />
            <ValidationMessage For="@(() => regData.Email)" />
        </div>

        <div class="form-group">
            <label>Lösenord</label>
            <InputText @bind-Value="regData.Password" class="form-control" type="password" placeholder="******" />
            <ValidationMessage For="@(() => regData.Password)" />
        </div>

        <div class="form-group">
            <label>Bekräfta lösenord</label>
            <InputText @bind-Value="regData.ConfirmPassword" class="form-control" type="password" placeholder="******" />
            <ValidationMessage For="@(() => regData.ConfirmPassword)" />
        </div>
        @if (showConfirmationMessage)
        {
            <div class="confirmation-message">
                <p>🌱 Konto skapat! Kolla din mejl för att bekräfta din adress.</p>
            </div>
        }
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" style="color: red; margin-top:10px;">@errorMessage</div>
        }

        <button type="submit" class="btn-primary" disabled="@isSubmitting" style="margin-top:15px;">
            @(isSubmitting ? "Skapar konto..." : "Registrera konto")
        </button>

    </EditForm>
</div>

@code {
    private LocalRegisterData regData = new();
    private string? errorMessage;
    private bool isSubmitting = false;
    private bool showConfirmationMessage = false;

    private async Task HandleRegister()
    {
        if (regData.Password != regData.ConfirmPassword)
        {
            errorMessage = "Lösenorden matchar inte.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        // Using the new AuthService-engine instead of talking with supabase directly. 
        var result = await Auth.RegisterAsync(regData.Email, regData.Password, regData.FirstName!, regData.LastName!);
        
        if (result.IsSuccess)
        {
            // Istället för Nav.NavigateTo("/")
            showConfirmationMessage = true;
        }
        else
        {
            errorMessage = result.Errors.First().Message;
        }

        isSubmitting = false;
    }


    public class LocalRegisterData
    {
        [Required(ErrorMessage = "Förnamn krävs")]
        public string? FirstName { get; set; }

        [Required(ErrorMessage = "Efternamn krävs")]
        public string? LastName { get; set; }

        [Required(ErrorMessage = "E-post krävs")]
        [EmailAddress(ErrorMessage = "Ogiltig e-post")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Lösenord krävs")]
        [MinLength(6, ErrorMessage = "Minst 6 tecken")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Bekräfta lösenord")]
        public string ConfirmPassword { get; set; } = "";
    }
}
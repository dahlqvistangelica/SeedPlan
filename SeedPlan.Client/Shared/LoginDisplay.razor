@using Microsoft.AspNetCore.Components.Authorization
@using SeedPlan.Client.Services
@inject AuthService Auth

<AuthorizeView>
    <Authorized>
        <div class="user-header-widget">
            @* Läs namnet direkt från minnet (Claims). Finns det inte, visa e-postens förled *@
            <span class="user-display-name">
                @(context.User.FindFirst("full_name")?.Value ??
                  context.User.Identity?.Name?.Split('@')[0] ?? "Odlare")
            </span>
            
            <button class="logout-icon-btn" @onclick="HandleLogout" title="Logga ut">
                <Blazicon Svg="Lucide.LogOut" />
            </button>
        </div>
    </Authorized>
</AuthorizeView>

@code {
    private async Task HandleLogout()
    {
        // AuthService sköter nu utloggning, rensning av minne och omladdning av sidan
        await Auth.LogoutAsync();
    }
}
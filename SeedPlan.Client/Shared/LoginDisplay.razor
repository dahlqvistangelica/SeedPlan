@using Microsoft.AspNetCore.Components.Authorization
@using SeedPlan.Client.Pages
@using SeedPlan.Client.Services
@inject AuthService Auth
@inject FeedbackModalService FeedbackModalService

<AuthorizeView>
    <Authorized>
        <div class="user-header-widget">
            <span class="user-display-name">
                @(context.User.FindFirst("full_name")?.Value ??
                  context.User.Identity?.Name?.Split('@')[0] ?? "Odlare")
            </span>
            <button type="button" class="feedback-icon-btn" @onclick="() => FeedbackModalService.Open()" title="Ge Feedback">
                <Blazicon Svg="Lucide.MessageCircleWarning" />
            </button>
            <button type="button" class="logout-icon-btn" @onclick="HandleLogout" title="Logga ut">
                <Blazicon Svg="Lucide.LogOut" />
            </button>
        </div>
    </Authorized>
</AuthorizeView>

@code {
    private async Task HandleLogout()
    {
        await Auth.LogoutAsync();
    }
}
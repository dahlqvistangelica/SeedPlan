<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(Program).Assembly"
            AdditionalAssemblies="new[] { typeof(SeedPlan.Client._Imports).Assembly }">
        <Found Context="routeData">
            @* USE AuthorizeRouteView to handle [Authorize] correct. *@
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                
                @* Shows while SupabaseAuthStateProvice is running InitializeAsync*@
                <Authorizing>
                    <div class="loading-screen">
                        <p>Verifierar inloggning... 🛡️</p>
                    </div>
                </Authorizing>

                @* This shows if you try to enter a [Authorize]-page without beeing signed in*@
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated != true)
                    {
                        @* Sends the user to login or show a message *@
                        <div class="auth-error">
                            <h2>Hoppsan!</h2>
                            <p>Du måste vara inloggad för att se denna sida.</p>
                            <a href="/login" class="btn-primary">Logga in</a>
                        </div>
                    }
                    else
                    {
                        <p role="alert">Du har inte behörighet att se denna sida.</p>
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(MainLayout)">
                <p role="alert">Sidan hittades inte.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
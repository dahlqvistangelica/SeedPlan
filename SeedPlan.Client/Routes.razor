<Router AppAssembly="typeof(Program).Assembly" AdditionalAssemblies="new[] { typeof(SeedPlan.Client._Imports).Assembly }">
    <Found Context="routeData">
        @* Vi använder RouteView istället för AuthorizeRouteView *@
        @* Din MainLayout har redan <AuthorizeView> så den skyddar ändå sidan! *@
        <RouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(MainLayout)">
            <p role="alert">Sidan hittades inte.</p>
        </LayoutView>
    </NotFound>
</Router>
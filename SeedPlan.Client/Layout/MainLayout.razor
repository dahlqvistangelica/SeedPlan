@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject FeedbackModalService FeedbackService
@inject AuthService Auth
@implements IDisposable

<SeoHead Title="Såkalender & Fröhantering - SeedPlan"
         Description="Planera din odling med SeedPlans såkalender, få överblick över aktiva sådder och håll koll på vad som behöver göras nu."
         Keywords="såkalender, fröhantering, odlingsplanering, sådder, odling" />


<div class="app-shell">
    @* TOP-HEADER WITH ICON *@
    <header class="main-header">
        <div class="header-content">
            <div class="brand" @onclick='() => Nav.NavigateTo("/")'>
                <div class="logo-circle"><img src="small-logo.png"></div>
                <h1 class="app-title">SeedPlan</h1>
            </div>
            <div class="header-actions">
                <AuthorizeView>
                    <NotAuthorized>
                        <nav class="header-nav">
                            <a href="/om-oss" class="header-link">Om SeedPlan</a>
                            <a href="/guide-preview" class="header-link">Växtguide</a>
                        </nav>
                    </NotAuthorized>
                </AuthorizeView>
                <LoginDisplay />
            </div>
        </div>
    </header>

    <main class="main-container">
        <AuthorizeView>
            <Authorized>
                <div class="page-body">
                    @Body
                </div>
                
                @* BOTTOMMENU *@
                <BottomNav />
            </Authorized>
            <NotAuthorized>
                @if (IsRegisterPage || IsPublicPage)
                {
                    <div class="page-body">
                        @Body
                    </div>


                }
                else
                {
                    <div class="login-screen">
                        @if (!showLoginForm)
                        {
                            <div class="landing-page">
                                @* --- HERO SEKTION --- *@
                                <section class="hero-section">
                                    <div class="hero-content fade-in">
                                        <h1 class="hero-title">Planera och spåra din odling med SeedPlan</h1>
                                        <p class="hero-subtitle">
                                            Din ultimata digitala trädgårdspartner. Ha full koll på dina fröer,
                                            när de ska sås och hur de utvecklas, allt på ett och samma ställe.
                                        </p>

                                        <div class="hero-actions">
                                            <button class="btn-primary btn-large" style="border: 1px solid #e2e8f0; border-radius: 14px;" @onclick="LoginAsGuest">Tjuvkika!</button>
                                            <button class="btn-secondary btn-large" @onclick="() => showLoginForm = true">Logga in/Skapa konto</button>
                                        </div>

                                    </div>
                                </section>

                                @* --- FUNKTIONER (FOCUS SECTIONS) --- *@
                                <section class="features-focus-section">
                                    <div class="container">
                                        <div class="features-header">
                                            <h2>Allt du behöver för en lyckad skörd</h2>
                                            <p>Upptäck verktygen som gör odlandet enklare, roligare och mer framgångsrikt.</p>
                                        </div>

                                        @* Funktionsblock 1 - Växtguide *@
                                        <div class="feature-item">
                                            <div class="feature-image-wrapper">
                                                <img src="/images/screenshot-4.webp"
                                                     alt="Mockup av SeedPlans detaljerade Växtguide med Tomat-profil och skötselråd"
                                                     class="feature-image" />
                                            </div>
                                            <div class="feature-text-wrapper">
                                                <span class="feature-tag tag-knowledge">KUNSKAP</span>
                                                <h3>Din digitala botaniker</h3>
                                                <p>Få tillgång till detaljerad information om hundratals växter. Vi har samlat allt du behöver veta om optimala jordförhållanden, solljusbehov, rekommenderade plantavstånd och specifika skötselråd för varje gröda. Bli en expert på dina egna växter.</p>
                                                <ul class="feature-list">
                                                    <li>🌱 Omfattande växtdatabas</li>
                                                    <li>☀️ Specifika skötselråd</li>
                                                    <li>📐 Plantavstånd och djup</li>
                                                </ul>
                                            </div>
                                        </div>

                                        @* Funktionsblock 2 - Såkalender *@
                                        <div class="feature-item feature-reverse">
                                            <div class="feature-image-wrapper">
                                                <img srcset="/images/mockup1-sm.webp 400w,
                                                /images/mockup1-md.webp 800w,
                                                /images/mockup1-opt.webp 1200w"
                                                     sizes="(max-width: 768px) 100vw, 665px"
                                                     src="/images/mockup1-opt.webp"
                                                     alt="Mockup av SeedPlans Såkalender för APRIL med färgkodade så-datum"
                                                     width="665"
                                                     height="499"
                                                     loading="lazy"
                                                     class="feature-image">
                                            </div>
                                            <div class="feature-text-wrapper">
                                                <span class="feature-tag tag-timing">TIMING</span>
                                                <h3>Missa aldrig en sådd</h3>
                                                <p>Vår intelligenta såkalender anpassar sig efter ditt sista frostdatum. Få en tydlig överblick över när det är dags att förodla inomhus, skola om dina plantor och slutligen plantera ut dem. Timing är allt för en lyckad skörd.</p>
                                                <ul class="feature-list">
                                                    <li>📅 Automatiserat sår-schema</li>
                                                    <li>🌍 Klimatanpassade datum</li>
                                                    <li>🔔 Påminnelser i rätt tid</li>
                                                </ul>
                                            </div>
                                        </div>

                                        @* Funktionsblock 3 - Fröinventarie *@
                                        <div class="feature-item">
                                            <div class="feature-image-wrapper">
                                                <img src="/images/screenshot-2.webp"
                                                     alt="Mockup av SeedPlans Fröinventarie med lista över fröpåsar"
                                                     class="feature-image" />
                                            </div>
                                            <div class="feature-text-wrapper">
                                                <span class="feature-tag tag-order">ORDNING</span>
                                                <h3>Full koll på frölagret</h3>
                                                <p>Sluta köpa dubbletter. Med vårt fröinventarie har du alltid ditt frölager i fickan. Inventera snabbt, se exakt hur många fröer du har kvar, kontrollera hållbarhetsdatum och var du förvarar dem.</p>
                                                <ul class="feature-list">
                                                    <li>📦 Digitalt frölager</li>
                                                    <li>📉 Spåra antal</li>
                                                    <li>⌛ Koll på bäst-före-datum</li>
                                                </ul>
                                            </div>
                                        </div>

                                        @* Funktionsblock 4 - Sådd-spårning *@
                                        <div class="feature-item feature-reverse">
                                            <div class="feature-image-wrapper">
                                                <img srcset="/images/mockup2-sm.webp 400w,
                                                /images/mockup2-md.webp 800w,
                                                /images/mockup2-opt.webp 1200w"
                                                     sizes="(max-width: 768px) 100vw, 665px"
                                                     src="/images/mockup2-opt.webp"
                                                     alt="Mockup av SeedPlans Sådd-spårning med tidslinjevy"
                                                     width="665"
                                                     height="1442"
                                                     loading="lazy"
                                                     class="feature-image">
                                            </div>
                                            <div class="feature-text-wrapper">
                                                <span class="feature-tag tag-control">KONTROLL</span>
                                                <h3>Följ resan från frö till skörd</h3>
                                                <p>Logga varje viktigt steg i dina växters liv. Dokumentera när du sådde, när det första skottet dök upp (groning), när du omplanterade och när du äntligen fick skörda. Lär dig av dina tidigare säsonger för att optimera framtida skördar.</p>
                                                <ul class="feature-list">
                                                    <li>📈 Logga groningsdatum</li>
                                                    <li>🌱 Spåra omplanteringar</li>
                                                    <li>📊 Historik och statistik</li>
                                                </ul>
                                            </div>
                                        </div>

                                    </div>
                                </section>
                            </div>


                        }
                        else
                        {
                            <div class="login-card fade-in">
                                <button class="btn-back" @onclick="() => showLoginForm = false">
                                    <Blazicon Svg="Lucide.ChevronLeft" /> Tillbaka
                                </button>
                                <div class="login-icon"><Blazicon Svg="Lucide.Lock" /></div>
                                <h2>Fortsätt med din odlingsplan</h2>
                                <p>Logga in för att se dina såförslag, fröer och aktiva sädder.</p>
                                <LoginForm />
                            </div>
                        }
                    </div>
                }
            </NotAuthorized>

        </AuthorizeView>
    </main>
</div>


<FeedBackModal @rendermode="InteractiveAuto" />

@code {
    private const string CurrentAppVersion = "1.4.1";
    private bool IsRegisterPage => Nav.Uri.EndsWith("/register", StringComparison.OrdinalIgnoreCase);
    private bool IsPublicPage => Nav.Uri.EndsWith("/om-oss", StringComparison.OrdinalIgnoreCase) || Nav.Uri.EndsWith("/guide-preview", StringComparison.OrdinalIgnoreCase);
    private bool showLoginForm = false;
    private bool isLoadingDemo = false;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += HandleLocationChanged;

    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var noCacheUrl = $"appsettings.json?t={DateTime.Now.Ticks}";
                var onlineSettings = await Http.GetFromJsonAsync<VersionCheckModel>(noCacheUrl);
                if(onlineSettings != null && !string.IsNullOrEmpty(onlineSettings.AppVersion))
                {
                    if(onlineSettings.AppVersion != CurrentAppVersion)
                    {
                        Nav.NavigateTo(Nav.Uri, forceLoad: true);
                    }
                }
            }
            catch(Exception ex)
            {
                Console.WriteLine($"Kunde inte kolla version: {ex.Message}");
            }

            StateHasChanged();

        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }


    private async Task LoginAsGuest()
    {
        isLoadingDemo = true;
        StateHasChanged();
        var result = await Auth.LoginAsync("demo@seedplan.app", "DemoPassword123!", false);

        if (result != null && result.IsSuccess)
        {
            Nav.NavigateTo("/");
        }
        else
        {
            isLoadingDemo = false;
        }
    }
    public void Dispose()
    {

        Nav.LocationChanged -= HandleLocationChanged;
    }
}
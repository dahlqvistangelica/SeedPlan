@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject FeedbackModalService FeedbackService
@inject AuthService Auth
@inject AppState AppState
@inject Supabase.Client Supabase
@inject IFeatureService FeatureService
@implements IDisposable

<SeoHead Title="Såkalender & Fröhantering - SeedPlan"
         Description="Planera din odling med SeedPlans såkalender, få överblick över aktiva sådder och håll koll på vad som behöver göras nu."
         Keywords="såkalender, fröhantering, odlingsplanering, sådder, odling" />


<div class="app-shell @(AppState.CurrentMode == AppMode.DahliaBox ? "dahlia-theme" : "seedplan-theme")">
    @* TOP-HEADER WITH ICON *@
    <header class="main-header">
        <div class="header-content">
        
            <div class="brand" @onclick='() => Nav.NavigateTo("/")'>

                <div class="logo-circle">
                    <img src="small-logo.webp"
                         class="@(AppState.CurrentMode == AppMode.SeedPlan ? "active-logo" : "inactive-logo")"
                         width="50" height="50" decoding="async"
                         @onclick="() => SwitchMode(AppMode.SeedPlan)"
                         @onclick:stopPropagation="true"> 
                    </div>

                    <AuthorizeView>
                        <Authorized>
                            <div class="logo-circle">
                                <img src="dahlia-logo.jpg"
                                     class="@(AppState.CurrentMode == AppMode.DahliaBox ? "active-logo" : "inactive-logo")"
                                     width="50" height="50" decoding="async"
                                     @onclick="() => SwitchMode(AppMode.DahliaBox)"
                                     @onclick:stopPropagation="true">
                                </div>
                            </Authorized>
                        </AuthorizeView>
                    </div>

                    <div class="header-actions">
                        <nav class="header-nav">
                            <a href="/planner" target="_blank" rel="noopener" class="header-link header-link-icon">
                                <Blazicon Svg="MdiIcon.FloorPlan" />
                                <span>Planerare</span>
                            </a>
                            <AuthorizeView>
                                <NotAuthorized>
                                    <a href="/om-oss" class="header-link">Om SeedPlan</a>
                                    <a href="/guide-preview" class="header-link">Växtguide</a>
                                </NotAuthorized>
                            </AuthorizeView>
                        </nav>

                        <LoginDisplay />
                    </div>
        
                </div>
            </header>

    <main class="main-container">
        <AuthorizeView>
            <Authorized>
                <div class="page-body">
                    @Body
                </div>
                
                @* BOTTOMMENU *@
                <BottomNav />
            </Authorized>
            <NotAuthorized>
                @if (IsRegisterPage || IsPublicPage)
                {
                    <div class="page-body">
                        @Body
                    </div>
                }
                else
                {
                    <div class="login-screen">
                        @if (!showLoginForm)
                        {
                            <div class="landing-page">
                                @* --- HERO SEKTION --- *@
                                <section class="hero-section">
                                    <div class="hero-content fade-in">
                                        <h1 class="hero-title">Planera och spåra din odling med SeedPlan</h1>
                                        <p class="hero-subtitle">
                                            Din ultimata digitala trädgårdspartner. Ha full koll på dina fröer,
                                            när de ska sås och hur de utvecklas, allt på ett och samma ställe.
                                        </p>

                                        <div class="hero-actions">
                                            <button class="btn-primary btn-large" style="border: 1px solid #e2e8f0; border-radius: 14px;" @onclick="LoginAsGuest">Tjuvkika!</button>
                                            <button class="btn-secondary btn-large" @onclick="() => showLoginForm = true">Logga in/Skapa konto</button>
                                        </div>

                                    </div>
                                </section>

                                @* --- FUNKTIONER (FOCUS SECTIONS) --- *@
                                <section class="features-focus-section">
                                    <div class="container">
                                        <div class="features-header">
                                            <h2>Allt du behöver för en lyckad skörd</h2>
                                            <p>Upptäck verktygen som gör odlandet enklare, roligare och mer framgångsrikt.</p>
                                        </div>

                                        @* Comment translated to English. *@
                                        <div class="feature-item">
                                            <div class="feature-image-wrapper">
                                                <img src="/images/screenshot-4.webp"
                                                     alt="Mockup av SeedPlans detaljerade Växtguide med Tomat-profil och skötselråd"
                                                     class="feature-image"
                                                     loading="lazy"
                                                     decoding="async"
                                                     width="665"
                                                     height="400" />
                                            </div>
                                            <div class="feature-text-wrapper">
                                                <span class="feature-tag tag-knowledge">KUNSKAP</span>
                                                <h3>Din digitala botaniker</h3>
                                                <p>Få tillgång till detaljerad information om hundratals växter. Vi har samlat allt du behöver veta om optimala jordförhållanden, solljusbehov, rekommenderade plantavstånd och specifika skötselråd för varje gröda. Bli en expert på dina egna växter.</p>
                                                <ul class="feature-list">
                                                    <li>🌱 Omfattande växtdatabas</li>
                                                    <li>☀️ Specifika skötselråd</li>
                                                    <li>📐 Plantavstånd och djup</li>
                                                </ul>
                                            </div>
                                        </div>

                                        @* Comment translated to English. *@
                                        <div class="feature-item feature-reverse">
                                            <div class="feature-image-wrapper">
                                                <img srcset="/images/mockup1-sm.webp 400w,
                                                /images/mockup1-md.webp 800w,
                                                /images/mockup1-opt.webp 1200w"
                                                     sizes="(max-width: 768px) 100vw, 665px"
                                                     src="/images/mockup1-sm.webp"
                                                     alt="Mockup av SeedPlans Såkalender för APRIL med färgkodade så-datum"
                                                     width="665"
                                                     height="499"
                                                     loading="lazy"
                                                     decoding="async"
                                                     class="feature-image">
                                            </div>
                                            <div class="feature-text-wrapper">
                                                <span class="feature-tag tag-timing">TIMING</span>
                                                <h3>Missa aldrig en sådd</h3>
                                                <p>Vår intelligenta såkalender anpassar sig efter ditt sista frostdatum. Få en tydlig överblick över när det är dags att förodla inomhus, skola om dina plantor och slutligen plantera ut dem. Timing är allt för en lyckad skörd.</p>
                                                <ul class="feature-list">
                                                    <li>📅 Automatiserat sår-schema</li>
                                                    <li>🌍 Klimatanpassade datum</li>
                                                    <li>🔔 Påminnelser i rätt tid</li>
                                                </ul>
                                            </div>
                                        </div>

                                        @* Comment translated to English. *@
                                        <div class="feature-item">
                                            <div class="feature-image-wrapper">
                                                <img src="/images/screenshot-2.webp"
                                                     alt="Mockup av SeedPlans Fröinventarie med lista över fröpåsar"
                                                     class="feature-image"
                                                     loading="lazy"
                                                     decoding="async"
                                                     width="665"
                                                     height="400" />
                                            </div>
                                            <div class="feature-text-wrapper">
                                                <span class="feature-tag tag-order">ORDNING</span>
                                                <h3>Full koll på frölagret</h3>
                                                <p>Sluta köpa dubbletter. Med vårt fröinventarie har du alltid ditt frölager i fickan. Inventera snabbt, se exakt hur många fröer du har kvar, kontrollera hållbarhetsdatum och var du förvarar dem.</p>
                                                <ul class="feature-list">
                                                    <li>📦 Digitalt frölager</li>
                                                    <li>📉 Spåra antal</li>
                                                    <li>⌛ Koll på bäst-före-datum</li>
                                                </ul>
                                            </div>
                                        </div>

                                        @* Comment translated to English. *@
                                        <div class="feature-item feature-reverse">
                                            <div class="feature-image-wrapper">
                                                <img srcset="/images/mockup2-sm.webp 400w,
                                                /images/mockup2-md.webp 800w,
                                                /images/mockup2-opt.webp 1200w"
                                                     sizes="(max-width: 768px) 100vw, 665px"
                                                     src="/images/mockup2-sm.webp"
                                                     alt="Mockup av SeedPlans Sådd-spårning med tidslinjevy"
                                                     width="665"
                                                     height="1442"
                                                     loading="lazy"
                                                     decoding="async"
                                                     class="feature-image">
                                            </div>
                                            <div class="feature-text-wrapper">
                                                <span class="feature-tag tag-control">KONTROLL</span>
                                                <h3>Följ resan från frö till skörd</h3>
                                                <p>Logga varje viktigt steg i dina växters liv. Dokumentera när du sådde, när det första skottet dök upp (groning), när du omplanterade och när du äntligen fick skörda. Lär dig av dina tidigare säsonger för att optimera framtida skördar.</p>
                                                <ul class="feature-list">
                                                    <li>📈 Logga groningsdatum</li>
                                                    <li>🌱 Spåra omplanteringar</li>
                                                    <li>📊 Historik och statistik</li>
                                                </ul>
                                            </div>
                                        </div>

                                    </div>
                                </section>
                            </div>


                        }
                        else
                        {
                            <div class="login-card fade-in">
                                <button class="btn-back" @onclick="() => showLoginForm = false">
                                    <Blazicon Svg="Lucide.ChevronLeft" /> Tillbaka
                                </button>
                                <div class="login-icon"><Blazicon Svg="Lucide.Lock" /></div>
                                <h2>Fortsätt med din odlingsplan</h2>
                                <p>Logga in för att se dina såförslag, fröer och aktiva sädder.</p>
                                <LoginForm />
                            </div>
                        }
                    </div>
                }
            </NotAuthorized>

        </AuthorizeView>
    </main>
</div>

<FeatureModal IsVisible="showFeatureModal"
              Feature="latestFeature"
              OnCloseCallback="MarkFeatureAsSeen" />
<FeedBackModal @rendermode="InteractiveAuto" />

@code {
    private const string CurrentAppVersion = "1.5.2";
    private bool IsRegisterPage => Nav.Uri.Contains("/register", StringComparison.OrdinalIgnoreCase);

    private bool IsPublicPage =>
        Nav.Uri.Contains("/om-oss", StringComparison.OrdinalIgnoreCase) ||
        Nav.Uri.Contains("/guide-preview", StringComparison.OrdinalIgnoreCase) ||
        Nav.Uri.Contains("/forgot-password", StringComparison.OrdinalIgnoreCase) ||
        Nav.Uri.Contains("/update-password", StringComparison.OrdinalIgnoreCase);
    private bool showLoginForm = false;
    private bool isLoadingDemo = false;
    private AppFeature? latestFeature;
    private bool showFeatureModal = false;
    private bool isClosingModal = false;

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += StateHasChanged;
        Nav.LocationChanged += HandleLocationChanged;
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            

            var saveMode = await JS.InvokeAsync<string>("localStorage.getItem", "appMode");
            if(!string.IsNullOrEmpty(saveMode) && Enum.TryParse<AppMode>(saveMode, out var mode))
                if(AppState.CurrentMode != mode)
                {
                    AppState.SetMode(mode);
                    StateHasChanged();

                }
            await CheckForUpdates();
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }


    private async Task LoginAsGuest()
    {
        isLoadingDemo = true;
        StateHasChanged();
        var result = await Auth.LoginAsync("demo@seedplan.app", "DemoPassword123!", false);

        if (result != null && result.IsSuccess)
        {
            Nav.NavigateTo("/");
        }
        else
        {
            isLoadingDemo = false;
        }
    }

    private async Task SwitchMode(AppMode newMode)
    {
        AppState.SetMode(newMode);
        if(AppState.CurrentMode == AppMode.DahliaBox)
        {
            Nav.NavigateTo("/dahliabox-home");
        }
        else
        {
            Nav.NavigateTo("/");
        }
        await JS.InvokeVoidAsync("localStorage.setItem", "appMode", newMode.ToString());
    }

    private async Task CheckForUpdates()
    {

        await Task.Delay(500);

        var session = await Supabase.Auth.RetrieveSessionAsync();
        if (session?.User == null)
        {
            return;
        }


        latestFeature = await FeatureService.GetLatestActiveFeatureAsync();
        if (latestFeature == null)
        {
        }

        // If updated version, clear flag for next update.
        if (latestFeature.VersionTag == CurrentAppVersion)
        {
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "hasReloadedForUpdate");
        }

        if (latestFeature.IsMandatory && latestFeature.VersionTag != CurrentAppVersion)
        {
            var hasReloaded = await JS.InvokeAsync<string>("sessionStorage.getItem", "hasReloadedForUpdate");
        
            if (string.IsNullOrEmpty(hasReloaded))
            {
                // First try, set flag and reload. 
                await JS.InvokeVoidAsync("sessionStorage.setItem", "hasReloadedForUpdate", "true");
                await JS.InvokeVoidAsync("location.reload", true);
                return;
            }
            else
            {
                // If reload is done but still wrong version:
                // Show message for user. 
                Console.WriteLine("Webbläsaren vägrar släppa cachen trots omladdning.");
                
                return;
            }
        }

        // Show featuremodal for non-force news or if version is the same. 
        bool hasSeen = await FeatureService.HasUserSeenFeatureAsync(latestFeature.Id);
        if (!hasSeen)
        {
            showFeatureModal = true;
            StateHasChanged();
        }
    }

    private async Task MarkFeatureAsSeen()
    {
        if (isClosingModal) return;
    
        isClosingModal = true;
        try
        {

            await FeatureService.MarkFeatureAsSeenAsync(latestFeature.Id);
        }
        finally
        {
           
            showFeatureModal = false; 
            isClosingModal = false;   
            StateHasChanged();        
        }
    }

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
        AppState.OnChange -= StateHasChanged;
    }
}

@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

<div class="app-shell">
    @* Topp-header för logotyp *@
    <header class="main-header">
        <div class="header-content">
            <div class="brand" @onclick='() => Nav.NavigateTo("/")'>
                <div class="logo-circle"><i data-lucide="leaf"></i></div>
                <h1 class="app-title">SeedPlan</h1>
            </div>
            <div class="header-actions">
                <LoginDisplay />
            </div>
        </div>
    </header>

    <main class="main-container">
        <AuthorizeView>
            <Authorized>
                <div class="page-body">
                    @Body
                </div>
                
                @* DEN NYA BOTTENMENYN *@
                <nav class="bottom-nav">
                    <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                        <i data-lucide="sun"></i>
                        <span>ÖVERSIKT</span>
                    </NavLink>
                    <NavLink class="nav-item" href="seeds">
                        <i data-lucide="package"></i>
                        <span>FRÖER</span>
                    </NavLink>
                    <NavLink class="nav-item" href="sowings">
                        <i data-lucide="leaf"></i>
                        <span>SÅDDER</span>
                    </NavLink>
                    <NavLink class="nav-item" href="guide">
                        <i data-lucide="info"></i>
                        <span>GUIDE</span>
                    </NavLink>
                    <NavLink class="nav-item" href="profile">
                        <i data-lucide="settings"></i>
                        <span>INSTÄLLN.</span>
                    </NavLink>
                </nav>
            </Authorized>
            <NotAuthorized>
                @if (IsRegisterPage)
                {
                    <div class="page-body">
                        @Body
                    </div>
                }
                else
                {
                    <div class="login-screen">
                        <div class="login-card">
                            <div class="login-icon"><i data-lucide="lock"></i></div>
                            <h2>Välkommen tillbaka</h2>
                            <p>Logga in för att hantera din trädgård.</p>
                            <LoginForm />
                        </div>
                    </div>
                }
            </NotAuthorized>
        </AuthorizeView>
    </main>
</div>

@code {
    private bool IsRegisterPage => Nav.Uri.EndsWith("/register", StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {

        Nav.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initializeLucide");
    }

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
    }
}
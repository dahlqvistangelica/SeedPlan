@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

<div class="app-shell">
    @* TOP-HEADER WITH ICON *@
    <header class="main-header">
        <div class="header-content">
            <div class="brand" @onclick='() => Nav.NavigateTo("/")'>
                <div class="logo-circle"><Blazicon Svg="MdiIcon.LeafCircleOutline" /></div>
                <h1 class="app-title">SeedPlan</h1>
            </div>
            <div class="header-actions">
                <LoginDisplay />
            </div>
        </div>
    </header>

    <main class="main-container">
        <AuthorizeView>
            <Authorized>
                <div class="page-body">
                    @Body
                </div>
                
                @* BOTTOMMENU *@
                <nav class="bottom-nav">
                    <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                        <Blazicon Svg="Lucide.Sun" />
                        <span>ÖVERSIKT</span>
                    </NavLink>
                    <NavLink class="nav-item" href="seeds">
                        <Blazicon Svg="MdiIcon.SeedOutline" />
                        <span>FRÖER</span>
                    </NavLink>
                    <NavLink class="nav-item" href="sowings">
                        <Blazicon Svg="MdiIcon.Sprout" />
                        <span>SÅDDER</span>
                    </NavLink>
                    <NavLink class="nav-item" href="guide">
                        <Blazicon Svg="MdiIcon.InformationSlabCircleOutline" />
                        <span>GUIDE</span>
                    </NavLink>
                    <NavLink class="nav-item" href="settings">
                        <Blazicon Svg="Lucide.Settings" />
                        <span>INSTÄLLN.</span>
                    </NavLink>
                </nav>
            </Authorized>
            <NotAuthorized>
                @if (IsRegisterPage)
                {
                    <div class="page-body">
                        @Body
                    </div>
                }
                else
                {
                    <div class="login-screen">
                        @if (!showLoginForm)
                        {
                            <div class="landing-content fade-in">
                                <div class="landing-header">
                                    <div class="logo-circle-large"><Blazicon Svg="MdiIcon.LeafCircleOutline" /></div>
                                    <h2>Välkommen till SeedPlan 🌱</h2>
                                    <p>Planera rätt sådd i rätt tid, håll koll på dina fröer och följ varje odling steg för steg.</p>
                                </div>
                                
                                <div class="features-grid">
                                    <div class="feature-card current">
                                        <h3>🌟 Just nu i appen</h3>
                                        <ul>
                                            <li><strong>Personliga såförslag:</strong> Få rekommendationer baserat på ditt frostdatum.</li>
                                            <li><strong>Fröinventarie:</strong> Se lagersaldo, utgångsdatum och vad du har hemma.</li>
                                            <li><strong>Aktiva sådder:</strong> Följ utvecklingen från sådd till utplantering.</li>
                                            <li><strong>Växtguide:</strong> Hitta odlingsråd, härdighet och sådata för varje art.</li>
                                            <li><strong>Påminnelser:</strong> Få notiser när en sådd varit inaktiv för länge.</li>
                                            <li><strong>Mobilvänlig app:</strong> Installera SeedPlan som PWA på hemskärmen.</li>
                                            
                                        </ul>
                                    </div>

                                    <div class="feature-card upcoming">
                                        <h3>🚀 På gång</h3>
                                        <ul>
                                            <li><strong>Bättre startsida:</strong> Välj vilka växttyper du vill få förslag på.</li>
                                            <li><strong>Rikare frökort:</strong> Fler detaljer som inköpsdatum och inköpsställe.</li>
                                            <li><strong>Bättre såddhantering:</strong>Möjlighet att ändra pågående sådder.</li>
                                            <li><strong>Tydligare sårekommendationer:</strong> Mer vägledning för vad som bör sås nu och snart.</li>
                                            <li><strong>Mer odlingsinsikter:</strong> Statistik som hjälper dig följa resultat över säsongen.</li>
                                        </ul>
                                    </div>
                                </div>

                                <div class="landing-actions">
                                    <button class="sp-save-btn" @onclick="() => showLoginForm = true">Logga in</button>
                                    <button class="sp-cancel-btn" style="border: 1px solid #e2e8f0; border-radius: 14px;" @onclick='() => Nav.NavigateTo("/register")'>Skapa konto</button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="login-card fade-in">
                                <button class="btn-back" @onclick="() => showLoginForm = false">
                                    <Blazicon Svg="Lucide.ChevronLeft" /> Tillbaka
                                </button>
                                <div class="login-icon"><Blazicon Svg="Lucide.Lock" /></div>
                                <h2>Fortsätt med din odlingsplan</h2>
                                <p>Logga in för att se dina såförslag, fröer och aktiva sådder.</p>
                                <LoginForm />
                            </div>
                        }
                    </div>
                }
            </NotAuthorized>
        </AuthorizeView>
    </main>
</div>

@code {
    private bool IsRegisterPage => Nav.Uri.EndsWith("/register", StringComparison.OrdinalIgnoreCase);
    private bool showLoginForm = false;

    protected override void OnInitialized()
    {

        Nav.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        
    }

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
    }
}
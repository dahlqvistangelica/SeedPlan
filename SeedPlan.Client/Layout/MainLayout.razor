@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject FeedbackModalService FeedbackService
@implements IDisposable

<div class="app-shell">
    @* TOP-HEADER WITH ICON *@
    <header class="main-header">
        <div class="header-content">
            <div class="brand" @onclick='() => Nav.NavigateTo("/")'>
                <div class="logo-circle"><Blazicon Svg="MdiIcon.LeafCircleOutline" /></div>
                <h1 class="app-title">SeedPlan</h1>
            </div>
            <div class="header-actions">
                <AuthorizeView>
                    <NotAuthorized>
                        <nav class="header-nav">
                            <a href="/om-oss" class="header-link">Om SeedPlan</a>
                            <a href="/guide-preview" class="header-link">Växtguide</a>
                        </nav>
                    </NotAuthorized>
                </AuthorizeView>
                <LoginDisplay />
            </div>
        </div>
    </header>

    <main class="main-container">
        <AuthorizeView>
            <Authorized>
                <div class="page-body">
                    @Body
                </div>
                
                @* BOTTOMMENU *@
                <nav class="bottom-nav">
                    <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                        <Blazicon Svg="Lucide.Sun" />
                        <span>ÖVERSIKT</span>
                    </NavLink>
                    <NavLink class="nav-item" href="seeds">
                        <Blazicon Svg="MdiIcon.SeedOutline" />
                        <span>FRÖER</span>
                    </NavLink>
                    <NavLink class="nav-item" href="sowings">
                        <Blazicon Svg="MdiIcon.Sprout" />
                        <span>SÅDDER</span>
                    </NavLink>
                    <NavLink class="nav-item" href="guide">
                        <Blazicon Svg="MdiIcon.InformationSlabCircleOutline" />
                        <span>GUIDE</span>
                    </NavLink>
                    <NavLink class="nav-item" href="settings">
                        <Blazicon Svg="Lucide.Settings" />
                        <span>INSTÄLLN.</span>
                    </NavLink>
                </nav>
            </Authorized>
            <NotAuthorized>
                @if (IsRegisterPage || IsPublicPage)
                {
                    <div class="page-body">
                        @Body
                    </div>
                }
                else
                {
                    <div class="login-screen">
                        @if (!showLoginForm)
                        {
                            <div class="landing-content fade-in">
                                <div class="landing-header">
                                    <h2>Välkommen till SeedPlan 🌱</h2>
                                    <p>Planera rätt sådd i rätt tid, håll koll på dina fröer och följ varje sådd steg för steg.</p>
                                </div>

                                @* IMAGE CAROUSEL *@
                                <div class="image-carousel-container">
                                    <div class="carousel-track">
                                        @foreach (var (image, index) in screenshots.Select((img, i) => (img, i)))
                                        {
                                            <div class="carousel-slide @(currentImageSlide == index ? "active" : "")">
                                                <img src="@image" alt="SeedPlan screenshot @(index + 1)" class="carousel-image" />
                                            </div>
                                        }
                                    </div>

                                    <button class="carousel-btn prev" @onclick="PreviousImageSlide">
                                        <Blazicon Svg="Lucide.ChevronLeft" />
                                    </button>
                                    <button class="carousel-btn next" @onclick="NextImageSlide">
                                        <Blazicon Svg="Lucide.ChevronRight" />
                                    </button>

                                    <div class="carousel-dots">
                                        @for (int i = 0; i < screenshots.Count; i++)
                                        {
                                            var slideIndex = i;
                                            <button class="dot @(currentImageSlide == slideIndex ? "active" : "")" 
                                                    @onclick="() => SelectSlide(slideIndex)">
                                            </button>
                                        }
                                    </div>
                                </div>

                                <div class="landing-actions">
                                    <button class="sp-save-btn" @onclick="() => showLoginForm = true">Logga in</button>
                                    <button class="sp-cancel-btn" style="border: 1px solid #e2e8f0; border-radius: 14px;" @onclick='() => Nav.NavigateTo("/register")'>Skapa konto</button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="login-card fade-in">
                                <button class="btn-back" @onclick="() => showLoginForm = false">
                                    <Blazicon Svg="Lucide.ChevronLeft" /> Tillbaka
                                </button>
                                <div class="login-icon"><Blazicon Svg="Lucide.Lock" /></div>
                                <h2>Fortsätt med din odlingsplan</h2>
                                <p>Logga in för att se dina såförslag, fröer och aktiva sädder.</p>
                                <LoginForm />
                            </div>
                        }
                    </div>
                }
            </NotAuthorized>

        </AuthorizeView>
    </main>
</div>

<FeedBackModal @rendermode="InteractiveAuto" />

@code {
    private bool IsRegisterPage => Nav.Uri.EndsWith("/register", StringComparison.OrdinalIgnoreCase);
    private bool IsPublicPage => Nav.Uri.EndsWith("/om-oss", StringComparison.OrdinalIgnoreCase) || Nav.Uri.EndsWith("/guide-preview", StringComparison.OrdinalIgnoreCase);
    private bool showLoginForm = false;
    private int currentImageSlide = 0;
    private CancellationTokenSource autoplayTokenSource;
    private const int AutoplayIntervalMs = 5000; // 5 sekunder mellan slides

    private List<string> screenshots = new()
    {
        "/images/screenshot-1.png",
        "/images/screenshot-2.png",
        "/images/screenshot-3.png",
        "/images/screenshot-4.png",
        "/images/screenshot-5.png"
    };

    protected override void OnInitialized()
    {
        Nav.LocationChanged += HandleLocationChanged;

    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            StartAutoplay();
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    private void StartAutoplay()
    {
        autoplayTokenSource?.Cancel();
        autoplayTokenSource = new CancellationTokenSource();
        _ = AutoplayLoop(autoplayTokenSource.Token);
    }

    private async Task AutoplayLoop(CancellationToken cancellationToken)
    {
        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                await Task.Delay(AutoplayIntervalMs, cancellationToken);
                if (!cancellationToken.IsCancellationRequested)
                {
                    NextImageSlide();
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException)
            {
                break;
            }
        }
    }

    private void NextImageSlide()
    {
        currentImageSlide = (currentImageSlide + 1) % screenshots.Count;
        RestartAutoplay(); // Restart timer vid användarinteraktion
    }

    private void PreviousImageSlide()
    {
        currentImageSlide = (currentImageSlide - 1 + screenshots.Count) % screenshots.Count;
        RestartAutoplay(); // Restart timer vid användarinteraktion
    }

    private void SelectSlide(int index)
    {
        currentImageSlide = index;
        RestartAutoplay(); // Restart timer vid användarinteraktion
    }

    private void RestartAutoplay()
    {
        StartAutoplay();
    }

    // public async ValueTask DisposeAsync()
    // {
    //     autoplayTokenSource?.Cancel();
    //     autoplayTokenSource?.Dispose();
    //     Nav.LocationChanged -= HandleLocationChanged;
    //     FeedbackService.OnVisibilityChanged -= HandleFeedbackVisibilityChanged;
    // }

    public void Dispose()
    {
        autoplayTokenSource?.Cancel();
        autoplayTokenSource?.Dispose();
        Nav.LocationChanged -= HandleLocationChanged;
    }
}
@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

<div class="app-shell">
    @* TOP-HEADER WITH ICON *@
    <header class="main-header">
        <div class="header-content">
            <div class="brand" @onclick='() => Nav.NavigateTo("/")'>
                <div class="logo-circle"><Blazicon Svg="MdiIcon.LeafCircleOutline" /></div>
                <h1 class="app-title">SeedPlan</h1>
            </div>
            <div class="header-actions">
                <LoginDisplay />
            </div>
        </div>
    </header>

    <main class="main-container">
        <AuthorizeView>
            <Authorized>
                <div class="page-body">
                    @Body
                </div>
                
                @* BOTTOMMENU *@
                <nav class="bottom-nav">
                    <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                        <Blazicon Svg="Lucide.Sun" />
                        <span>ÖVERSIKT</span>
                    </NavLink>
                    <NavLink class="nav-item" href="seeds">
                        <Blazicon Svg="MdiIcon.SeedOutline" />
                        <span>FRÖER</span>
                    </NavLink>
                    <NavLink class="nav-item" href="sowings">
                        <Blazicon Svg="MdiIcon.Sprout" />
                        <span>SÅDDER</span>
                    </NavLink>
                    <NavLink class="nav-item" href="guide">
                        <Blazicon Svg="MdiIcon.InformationSlabCircleOutline" />
                        <span>GUIDE</span>
                    </NavLink>
                    <NavLink class="nav-item" href="settings">
                        <Blazicon Svg="Lucide.Settings" />
                        <span>INSTÄLLN.</span>
                    </NavLink>
                </nav>
            </Authorized>
            <NotAuthorized>
                @if (IsRegisterPage)
                {
                    <div class="page-body">
                        @Body
                    </div>
                }
                else
                {
                    <div class="login-screen">
                        @if (!showLoginForm)
                        {
                            <div class="landing-content fade-in">
                                <div class="landing-header">
                                    <div class="logo-circle-large"><Blazicon Svg="MdiIcon.LeafCircleOutline" /></div>
                                    <h2>Välkommen till SeedPlan 🌱</h2>
                                    <p>Din smarta trädgårdsassistent för att hålla koll på fröer och sådder.</p>
                                </div>
                                
                                <div class="features-grid">
                                    <div class="feature-card current">
                                        <h3>🌟 Just nu i appen</h3>
                                        <ul>
                                            <li><strong>Smart Såkalender:</strong> Få förslag på vad som ska sås baserat på ditt sista frostdatum.</li>
                                            <li><strong>Fröbibliotek:</strong> Håll koll på ditt lager, antal och utgångsdatum.</li>
                                            <li><strong>Sådd-spårning:</strong> Följ varje sådds status – från frö till utplantering.</li>
                                            <li><strong>Växtguide:</strong> Utforska databasen och hitta odlingsråd & härdighet.</li>
                                            <li><strong>PWA-stöd:</strong> Installera som en app på mobilen för smidig åtkomst i trädgården.</li>
                                            <li><strong>Kom ihåg mig:</strong> Slipp logga in varje gång du öppnar appen.</li>
                                            <li><strong>Påminnelser:</strong> Notiser om det är dags att skola om eller om sådden stått stilla länge.</li>
                                            
                                        </ul>
                                    </div>

                                    <div class="feature-card upcoming">
                                        <h3>🚀 Kommande funktioner</h3>
                                        <ul>
                                            <li><strong>Bättre data för grönsaker/frukt/örter:</strong> Utbyggnad av databasen för grönsaker/frukt/örter.</li>
                                            <li><strong>Gemensamma Såråd:</strong> Ta del av andras tips och råd från databasen.</li>
                                            <li><strong>Ändring av sådd:</strong> Möjlighet att ändra i befintliga sådder.</li>
                                            <li><strong>Fler Frödetaljer:</strong> Registrera inköpsställe, pris och egna anteckningar.</li>
                                            <li><strong>Automatisk såddspårning:</strong> Få påminnelser om sådderna grott/fått karaktärsblad/omskolats/avhärdnings påbörjats efter x antal veckor inaktiva.</li>
                                        </ul>
                                    </div>
                                </div>

                                <div class="landing-actions">
                                    <button class="sp-save-btn" @onclick="() => showLoginForm = true">Logga in</button>
                                    <button class="sp-cancel-btn" style="border: 1px solid #e2e8f0; border-radius: 14px;" @onclick='() => Nav.NavigateTo("/register")'>Skapa konto</button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="login-card fade-in">
                                <button class="btn-back" @onclick="() => showLoginForm = false">
                                    <Blazicon Svg="Lucide.ChevronLeft" /> Tillbaka
                                </button>
                                <div class="login-icon"><Blazicon Svg="Lucide.Lock" /></div>
                                <h2>Välkommen tillbaka</h2>
                                <p>Logga in för att hantera din trädgård.</p>
                                <LoginForm />
                            </div>
                        }
                    </div>
                }
            </NotAuthorized>
        </AuthorizeView>
    </main>
</div>

@code {
    private bool IsRegisterPage => Nav.Uri.EndsWith("/register", StringComparison.OrdinalIgnoreCase);
    private bool showLoginForm = false;

    protected override void OnInitialized()
    {

        Nav.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        
    }

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
    }
}
<nav class="bottom-nav">
    <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
        <Blazicon Svg="Lucide.Sun" />
        <span>ÖVERSIKT</span>
    </NavLink>

    <div class="nav-group">
        <div class="nav-anchor">
            <button type="button" class="nav-item" @onclick="ToggleInventory" aria-expanded="@isInventoryExpanded">
                <Blazicon Svg="Lucide.HouseHeart" />
                <span>LAGER</span>
            </button>
            @if (isInventoryExpanded)
            {
                <div class="bottom-submenu fade-in-up">
                    <NavLink class="submenu-item" href="seeds" @onclick="ToggleInventory">
                        <Blazicon Svg="MdiIcon.SeedOutline" /><span>Fröer</span>
                    </NavLink>
                    <NavLink class="submenu-item" href="tubers" @onclick="ToggleInventory">
                        <Blazicon Svg="BootstrapIcon.Flower1" /><span>Knölar</span>
                    </NavLink>
                </div>
            }
        </div>
    </div>

    <NavLink class="nav-item" href="sowings">
        <Blazicon Svg="MdiIcon.Sprout" />
        <span>SÅDDER</span>
    </NavLink>

    <div class="nav-group">
        <div class="nav-anchor">
            <button type="button" class="nav-item" @onclick="ToggleInfo" aria-expanded="@isInfoExpanded">
                <Blazicon Svg="MdiIcon.InformationSlabCircleOutline" />
                <span>GUIDER</span>
            </button>
            @if (isInfoExpanded)
            {
                <div class="bottom-submenu fade-in-up">
                    <NavLink class="submenu-item" href="guide" @onclick="ToggleInfo">
                        <Blazicon Svg="MdiIcon.BookOpenVariant" /><span>Växtguide</span>
                    </NavLink>
                    <NavLink class="submenu-item" href="dahlias" @onclick="ToggleInfo">
                        <Blazicon Svg="BootstrapIcon.Flower3" /><span>Dahlior</span>
                    </NavLink>
                </div>
            }
        </div>
    </div>

    <NavLink class="nav-item" href="settings">
        <Blazicon Svg="Lucide.Settings" />
        <span>INSTÄLLN.</span>
    </NavLink>
</nav>



@code {
    private bool isInventoryExpanded = false;
    private bool isInfoExpanded = false;

    private void ToggleInventory()
    {
        isInventoryExpanded = !isInventoryExpanded;
        // Stäng den andra menyn automatiskt!
        if (isInventoryExpanded) isInfoExpanded = false;
    }

    private void ToggleInfo()
    {
        isInfoExpanded = !isInfoExpanded;
        // Stäng den andra menyn automatiskt!
        if (isInfoExpanded) isInventoryExpanded = false;
    }
}

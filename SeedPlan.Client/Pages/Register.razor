@page "/register"
@using SeedPlan.Client.Shared
@inject NavigationManager Nav
@inject IJSRuntime JS

<SeoHead Title="Skapa konto - SeedPlan"
         Description="Skapa ett konto i SeedPlan och börja planera dina sådder med smart såkalender och frööversikt."
         Keywords="skapa konto, registrering, seedplan, såkalender, fröer" />

<div class="auth-page-container">
    <div class="auth-header">
        <button class="btn-back" @onclick="GoBack">
            <Blazicon Svg="Lucide.ChevronLeft" /> Tillbaka
        </button>
    </div>

    <RegisterForm />
</div>

@code {

    private void GoBack() => Nav.NavigateTo("/");

}
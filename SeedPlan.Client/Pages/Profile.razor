@page "/profile"
@using SeedPlan.Shared.Models
@inject IUserProfileService ProfileService
@inject AuthService Auth
@inject IAuthClient AuthClient
@inject HttpClient Http

<SeoHead Title="Profil - SeedPlan"
         Description="Hantera din profil i SeedPlan och uppdatera dina kontoinställningar för en bättre odlingsupplevelse."
         Keywords="profil, konto, inställningar, odling, seedplan" />
@if (isLoading)
{
    <LoadingSpinner Text="Laddar inställningar..." />
}
else
{
    <div class="profile-container">
        <header class="profile-header">
            <h1 class="serif-title">Profil <Blazicon Svg="MdiIcon.AccountEditOutline" /></h1>
            <p>Uppdatera din profil och kontoinställningar.</p>
        </header>

        <div class="settings-card">
            <h3>Profiluppgifter</h3>

            <div class="input-group">
                <label>Namn</label>
                <input type="text" @bind="userProfile.FullName" placeholder="Ditt namn" />
            </div>

            <div class="input-block">
                <label>Din ort (För vädervarningar)</label>
                <input type="text" @bind="userProfile.City" placeholder="T.ex. Örebro" autocomplete="off" />
                @if (userProfile.Latitude.HasValue)
                {
                    <span style="font-size: 0.75rem; color: #10b981; margin-top: 4px;">
                        <Blazicon Svg="Lucide.MapPin" /> @userProfile.City (@Math.Round(userProfile.Latitude.Value, 2), @Math.Round(userProfile.Longitude.Value, 2))
                    </span>
                }
            </div>

            <div class="input-group">
                <label>Visa såförslag för..</label>
                <div class="category-options">
                    @foreach (int i in Enum.GetValues(typeof(PlantCategory)))
                    {
                        <label class="category-option" for="@i">
                            <input type="checkbox"
                            id="@i"
                            name="@i"
                            value="@i"
                            checked="@userProfile.PreferredPlantCategories.Contains(i)"
                            @onchange="(ChangeEventArgs e) => ToggleCategory(i, e.Value)" />
                            <span>@GetPlantCategoryName(i)</span>
                        </label>
                    }
                </div>
            </div>

            <button class="btn-save" @onclick="SaveProfile" disabled="@isSavingProfile">
                <Blazicon Svg="Lucide.Save" /> <span>Spara profil</span>
            </button>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="status-alert" style="margin-top: 1rem;">@statusMessage</div>
            }
        </div>

        <div class="settings-card">
            <h3>Kontouppgifter</h3>
            @if (IsDemoUser)
            {
                <div class="alert alert-info">
                    <strong>Demo-läge:</strong> Kontoinställningar (som att byta lösenord och email) är inaktiverade för gästkontot. Du kan dock fortfarande ändra din profil (t.ex. namn och dina preferenser för såförslag)!
                </div>
            }
            else
            {

                <details class="expandable-item">
                    <summary>
                        <div class="summary-copy">
                            <span>Ändra e-post</span>
                            <small>Uppdatera din inloggningsadress</small>
                        </div>
                        <Blazicon class="chevron-icon" Svg="Lucide.ChevronDown" />
                    </summary>

                    <div class="expandable-content">
                        <div class="input-group">
                            <label>Ny e‑post</label>
                            <input type="email" @bind="newEmail" placeholder="ny@epost.se" />
                        </div>

                        <div class="input-group">
                            <label>Nuvarande lösenord</label>
                            <input type="password" @bind="currentEmailPassword" placeholder="Ange ditt nuvarande lösenord" />
                        </div>

                        <button class="btn-secondary" @onclick="UpdateEmail" disabled="@(!CanSubmitEmail())">
                            Spara e‑post
                        </button>
                    </div>
                </details>

                <details class="expandable-item">
                    <summary>
                        <div class="summary-copy">
                            <span>Ändra lösenord</span>
                            <small>Välj ett nytt säkert lösenord</small>
                        </div>
                        <Blazicon class="chevron-icon" Svg="Lucide.ChevronDown" />
                    </summary>

                    <div class="expandable-content">
                        <div class="input-group">
                            <label>Ditt gamla lösenord</label>
                            <input type="password" @bind="currentPassword" placeholder="Ange ditt nuvarande lösenord" />
                        </div>

                        <div class="input-group">
                            <label>Nytt lösenord</label>
                            <input type="password" @bind="newPassword" placeholder="Ange ett nytt lösenord" />
                            @if (!string.IsNullOrWhiteSpace(newPassword) && !MeetsPasswordComplexity(newPassword))
                            {
                                <span class="warning-text">⚠️ Minst 8 tecken och minst en stor + en liten bokstav krävs</span>
                            }
                        </div>

                        <div class="input-group">
                            <label>Bekräfta nytt lösenord</label>
                            <input type="password" @bind="confirmPassword" placeholder="Upprepa det nya lösenordet" />
                            @if (!string.IsNullOrEmpty(confirmPassword) && newPassword != confirmPassword)
                            {
                                <span class="warning-text">⚠️ Lösenorden matchar inte</span>
                            }
                        </div>

                        @if (isUpdatingPassword)
                        {
                            <div class="loading-text">⏳ Uppdaterar lösenord...</div>
                        }

                        <button class="btn-secondary" @onclick="UpdatePassword" disabled="@(!CanSubmitPassword())">
                            Spara lösenord
                        </button>

                        @if (!string.IsNullOrEmpty(passwordStatus))
                        {
                            <div class="status-alert" style="margin-top: 1rem;">@passwordStatus</div>
                        }
                    </div>
                </details>
            }
        </div>
    </div>
}
@code {
    private UserProfile userProfile = new();
    private bool isLoading = true;
    private string statusMessage = "";
    private bool IsDemoUser => AuthClient.CurrentUserEmail?.ToLower() == "demo@seedplan.app";
    private string newEmail = "";
    private string currentEmailPassword = "";
    private string currentPassword = "";
    private string newPassword = "";
    private string confirmPassword = "";
    private string passwordStatus = "";
    private bool isUpdatingPassword = false;
    private bool isSavingProfile = false;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if(firstRender)
        {
            try
            {
                var profile = await ProfileService.GetUserProfile();
                if(profile != null)
                {
                    userProfile = profile;
                }
                else
                {
                    userProfile.GrowingZone = 1;
                }
            }
            finally
            {
                isLoading = false;
                StateHasChanged();
            }
        }
    }  

    private void ToggleCategory(int i, object? checkedValue)
    {
        var isChecked = checkedValue switch
        {
            bool boolValue => boolValue,
            string stringValue when bool.TryParse(stringValue, out var parsed) => parsed,
            _ => false
        };

        var currentCategories = userProfile.PreferredPlantCategories ?? [];

        userProfile.PreferredPlantCategories = isChecked
            ? currentCategories.Append(i).Distinct().OrderBy(x => x).ToArray()
            : currentCategories.Where(x => x != i).Distinct().OrderBy(x => x).ToArray();
    }

    private async Task SaveProfile()
    {
        if (isSavingProfile)
        {
            return;
        }

        isSavingProfile = true;
        statusMessage = "Sparar...";

        userProfile.PreferredPlantCategories = userProfile.PreferredPlantCategories
            .Distinct()
            .OrderBy(x => x)
            .ToArray();

        try
        {
            if (!string.IsNullOrWhiteSpace(userProfile.City))
            {
                await FetchCoordinatesForCity(userProfile.City);
            }
            
            await ProfileService.UpsertUserProfile(userProfile);
            statusMessage = "Dina inställningar har sparats!";
        }
        catch
        {
            statusMessage = "Kunde inte spara inställningarna just nu.";
        }
        finally
        {
            isSavingProfile = false;
        }

        await Task.Delay(2500);
        statusMessage = "";
    }

    private bool CanSubmitEmail()
    {
        return !string.IsNullOrWhiteSpace(newEmail) &&
               !string.IsNullOrWhiteSpace(currentEmailPassword);
    }

    private bool CanSubmitPassword()
    {
        return !isUpdatingPassword &&
               !string.IsNullOrWhiteSpace(currentPassword) &&
               !string.IsNullOrWhiteSpace(newPassword) &&
               MeetsPasswordComplexity(newPassword) &&
               !string.IsNullOrWhiteSpace(confirmPassword) &&
               newPassword == confirmPassword;
    }

    private bool MeetsPasswordComplexity(string password)
    {
        return password.Length >= 8 &&
               password.Any(char.IsUpper) &&
               password.Any(char.IsLower);
    }

    private async Task UpdateEmail()
    {
        if (!CanSubmitEmail()) return;

        var requestedEmail = newEmail.Trim();
        var result = await Auth.UpdateEmailAsync(requestedEmail, currentEmailPassword);

        statusMessage = result.IsSuccess
            ? $"Ett bekräftelsemejl har skickats till {requestedEmail}."
            : result.Errors.First().Message;

        if (result.IsSuccess)
        {
            newEmail = "";
            currentEmailPassword = "";
        }

        await Task.Delay(2500);
        statusMessage = "";
    }

    private async Task UpdatePassword()
    {
        if (!CanSubmitPassword()) return;

        isUpdatingPassword = true;
        passwordStatus = "";

        var result = await Auth.UpdatePasswordAsync(currentPassword, newPassword);

        if (result.IsSuccess)
        {
            passwordStatus = "Lösenordet har uppdaterats ✨";
            currentPassword = "";
            newPassword = "";
            confirmPassword = "";
        }
        else
        {
            passwordStatus = result.Errors.First().Message;
        }

        isUpdatingPassword = false;
    }

    private async Task FetchCoordinatesForCity(string cityName)
    {
        try
        {
            string url=$"https://geocoding-api.open-meteo.com/v1/search?name={Uri.EscapeDataString(cityName)}&count=1&language=sv&format=json";

            var response = await Http.GetFromJsonAsync<OpenMeteoGeocodingResponse>(url);

            if(response?.Results != null && response.Results.Count > 0)
            {
                var firstResult = response.Results[0];

                userProfile.Latitude = firstResult.Latitude;
                userProfile.Longitude = firstResult.Longitude;
                userProfile.City = firstResult.Name;
            }
            else
            {
                Console.WriteLine("Kunde inte hitta koordinater för staden.");
            }
        }
        catch(Exception ex)
        {
            Console.WriteLine($"Ett fel uppstod vid geocoding: {ex.Message}");
        }
    }
    private string GetPlantCategoryName(int i)
    {
        return i switch
        {
        0 => "Grönsaker",
        1 => "Blommor",
        2 => "Örter",
        3 => "Frukt"
        };
    }
}
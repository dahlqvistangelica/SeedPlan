@page "/profile"
@using Microsoft.AspNetCore.Authorization
@using SeedPlan.Shared.Models
@attribute [Authorize]
@inject IUserProfileService ProfileService
@inject IJSRuntime JS

<PageTitle>Inställningar - SeedPlan</PageTitle>

<div class="profile-container">
    <header class="profile-header">
        <h1 class="serif-title">Inställningar <Blazicon Svg="MdiIcon.AccountCogOutline" /></h1>
        <p>Anpassa appen efter din trädgårds förutsättningar.</p>
    </header>

    <div class="settings-card">
        <div class="input-group">
            <label>Namn</label>
            <input type="text" @bind="userProfile.FullName" placeholder="Ditt namn" />
        </div>

        <div class="input-group">
            <label>Odlingszon (1-8)</label>
            <input type="number" min="1" max="8" @bind="userProfile.GrowingZone" />
        </div>

        <div class="input-group">
            <label>Beräknat datum för sista frost</label>
            <input type="date" @bind="userProfile.LastFrostDate" />
            <small>Detta datum används för att räkna ut när du ska börja så dina fröer.</small>
        </div>

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="status-alert">@statusMessage</div>
        }

        <button class="btn-save" @onclick="SaveProfile">
           <Blazicon Svg="Lucide.Save"/>
        </button>
    </div>
</div>

@code {
    private UserProfile userProfile = new();
    private string statusMessage = "";

    protected override async Task OnInitializedAsync()
    {
        var profile = await ProfileService.GetUserProfile();
        if (profile != null)
        {
            userProfile = profile;
            StateHasChanged();
        }
        else
        {
            // Standardvärden om profil saknas
            userProfile.LastFrostDate = new DateTime(DateTime.Now.Year, 5, 15);
            userProfile.GrowingZone = 1;
        }
    }

    private async Task SaveProfile()
    {
        if(userProfile.LastFrostDate.HasValue)
        {
            userProfile.LastFrostDate = DateTime.SpecifyKind(userProfile.LastFrostDate.Value.Date, DateTimeKind.Utc);
        }

        await ProfileService.UpsertUserProfile(userProfile);
        statusMessage = "Dina inställningar har sparats! ✨";
        StateHasChanged();


        await Task.Delay(3000);

        statusMessage = "";
        StateHasChanged();

    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
    }
}
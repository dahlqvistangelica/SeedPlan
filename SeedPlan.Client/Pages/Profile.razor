@page "/profile"
@using SeedPlan.Shared.Models
@using System.Text.Json
@inject IUserProfileService ProfileService
@inject IUserInventoryService InventoryService
@inject IUserSowingService SowingService
@inject NavigationManager Nav
@inject AuthService Auth
@inject IJSRuntime JS

<PageTitle>Profil - SeedPlan</PageTitle>

<div class="profile-container">
    <header class="profile-header">
        <h1 class="serif-title">Profil <Blazicon Svg="MdiIcon.AccountEditOutline" /></h1>
        <p>Uppdatera din profil och kontoinställningar.</p>
    </header>

    <div class="settings-card">
        <h3>Profiluppgifter</h3>
        
        <div class="input-group">
            <label>Namn</label>
            <input type="text" @bind="userProfile.FullName" placeholder="Ditt namn" />
        </div>

        <div class="input-group">
            <label>Odlingszon (1-8)</label>
            <input type="number" min="1" max="8" @bind="userProfile.GrowingZone" />
        </div>

        <hr style="margin: 1.5rem 0;" />

        <h3>Kontouppgifter</h3>

        <div class="input-group">
            <label>E‑post</label>
            <input type="email" @bind="newEmail" placeholder="ny@epost.se" />
            <div class="inline-action-group">
                <button class="btn-secondary" @onclick="UpdateEmail">Ändra e-post</button>
            </div>
        </div>

        <div class="input-group">
            <label>Lösenord</label>
            <div>
                <button class="btn-secondary" @onclick="() => showPasswordModal = true">
                    Ändra lösenord
                </button>
            </div>


            @* Dold tills exporten fungerar igen *@
            @* <button class="btn-secondary" @onclick="ExportBackup">Exportera data</button> *@
        </div>

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="status-alert" style="margin-top: 1rem;">@statusMessage</div>
        }
    </div>
</div>

@if (showPasswordModal)
{
    <div class="settings-modal-backdrop" @onclick="ClosePasswordModal">
        <div class="settings-modal" @onclick:stopPropagation="true">
            <h3>Byt lösenord</h3>
            
            <div class="input-group" style="margin-top: 1rem;">
                <label>Ditt gamla lösenord</label>
                <input type="password" @bind="currentPassword" placeholder="Ange ditt nuvarande lösenord" />
            </div>

            <div class="input-group">
                <label>Nytt lösenord</label>
                <input type="password" @bind="newPassword" placeholder="Ange ett nytt lösenord" />
            </div>

            <div class="input-group">
                <label>Bekräfta nytt lösenord</label>
                <input type="password" @bind="confirmPassword" placeholder="Upprepa det nya lösenordet" />
                @if (!string.IsNullOrEmpty(confirmPassword) && newPassword != confirmPassword)
                {
                    <span style="color: #dc2626; font-size: 0.85rem; margin-top: 4px;">Lösenorden matchar inte</span>
                }
            </div>

            <div style="display: flex; gap: 8px; margin-top: 1.5rem;">
                <button class="btn-primary" @onclick="UpdatePassword" disabled="@(!IsPasswordFormValid())">Spara lösenord</button>
                <button class="btn-secondary" @onclick="ClosePasswordModal">Avbryt</button>
            </div>

            @if (!string.IsNullOrEmpty(passwordStatus))
            {
                <div class="status-alert" style="margin-top: 1rem;">@passwordStatus</div>
            }
        </div>
    </div>
}

@code {
    private UserProfile userProfile = new();
    private string statusMessage = "";

    private bool showPasswordModal = false;
    private string newEmail = "";
    private string currentPassword = "";
    private string newPassword = "";
    private string confirmPassword = "";
    private string passwordStatus = "";

    protected override async Task OnInitializedAsync()
    {
        var profile = await ProfileService.GetUserProfile();
        if (profile != null)
        {
            userProfile = profile;
            StateHasChanged();
        }
        else
        {
            userProfile.GrowingZone = 1;
        }
    }

    private async Task SaveProfile()
    {
        await ProfileService.UpsertUserProfile(userProfile);
        statusMessage = "Dina inställningar har sparats! ✨";
        StateHasChanged();

        await Task.Delay(3000);
        statusMessage = "";
        StateHasChanged();
    }

    private void ClosePasswordModal()
    {
        showPasswordModal = false;
        passwordStatus = "";
        currentPassword = "";
        newPassword = "";
        confirmPassword = "";
    }

    private bool IsPasswordFormValid()
    {
        return !string.IsNullOrWhiteSpace(currentPassword) &&
               !string.IsNullOrWhiteSpace(newPassword) &&
               !string.IsNullOrWhiteSpace(confirmPassword) &&
               newPassword == confirmPassword;
    }

    private async Task UpdateEmail()
    {
        if (string.IsNullOrWhiteSpace(newEmail)) return;
        var result = await Auth.UpdateEmailAsync(newEmail.Trim());
        statusMessage = result.IsSuccess ? "E‑post uppdaterad (kolla din mejl)" : result.Errors.First().Message;
        newEmail = "";
        StateHasChanged();
    }

    private async Task UpdatePassword()
    {
        if (!IsPasswordFormValid())
        {
            passwordStatus = "Verifiera att alla fält är ifyllda och att lösenorden matchar";
            return;
        }

        var result = await Auth.UpdatePasswordAsync(currentPassword, newPassword);
        passwordStatus = result.IsSuccess ? "Lösenordet har uppdaterats ✨" : result.Errors.First().Message;
        
        if (result.IsSuccess)
        {
            currentPassword = "";
            newPassword = "";
            confirmPassword = "";
            await Task.Delay(2000);
            ClosePasswordModal();
        }
    }


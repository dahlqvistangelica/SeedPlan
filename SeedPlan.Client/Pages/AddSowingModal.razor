@inject IUserInventoryService SeedService
@inject IUserSowingService SowingService
@inject Supabase.Client _supabase
@inject IJSRuntime JS

@if (IsVisible)
{
    <div class="modal-overlay" @onclick="Close">
        <div class="modal-card fade-in" @onclick:stopPropagation>
            <div class="modal-body">
                
                @* 1. CHOOSE SEED *@
                <div class="input-block">
                        <label>VÄLJ FRÖ</label>
                    <select @bind="newSowing.SeedId" @bind:after="OnSeedChangedAsync" class="sp-input">
                            @if (InitialPlant != null)
                            {
                                <option value="0">Välj vilken sort av @InitialPlant.PlantName du sår..</option>
                            }
                            else
                            {
                                <option value="0">Välj ett frö från lagret...</option>
                            }
        
                            @foreach (var group in availableSeeds.GroupBy(s => s.PlantName))
                            {
                                <optgroup label="@group.Key">
                                    @foreach (var seed in group)
                                    {
                                        <option value="@seed.Id">
                                            @(string.IsNullOrEmpty(seed.VarietyName) ? seed.Name : seed.VarietyName)
                                        </option>
                                    }
                                </optgroup>
                            }
                        </select>
                    </div>
                    <div class="input-block">
                        <label>OMGÅNG</label>
                        <input type="text" class="sp-input" value="@(nextBatchNumber > 0 ? $"Omgång {nextBatchNumber}" : "Välj frö först")" readonly />
                    </div>
                @* 2. NUMBER OF SEEDS SOWN *@
                <div class="input-block">
                    <label>ANTAL SÅDDA FRÖER</label>
                    <input type="number" @bind="newSowing.Quantity" class="sp-input" />
                </div>


                @* 2. SOWING DATE *@
                <div class="input-block">
                    <label>SÅDATUM</label>
                    <input type="date" @bind="newSowing.SownDate" class="sp-input" />
                </div>

                @* 3. NOTES *@
                <div class="input-block">
                    <label>ANTECKNINGAR</label>
                    <textarea @bind="newSowing.Notes" class="sp-textarea" placeholder="Plats, jord, etc."></textarea>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <p class="error-msg">@errorMessage</p>
                }

                @* 4. START SOWING *@
                <div class="modal-actions">
                    
                    <button type="button" class="sp-submit-btn" @onclick="HandleSave">Starta sådd</button>
                    <button type="button" class="sp-cancel-btn" @onclick="Close">Avbryt</button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    private bool _wasVisible;
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public Plant? InitialPlant { get; set; }

    private List<SeedView> availableSeeds = new();
    private Sowing newSowing = new() { SownDate = DateTime.Now }; 
    private string errorMessage = "";
    private int nextBatchNumber;

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !_wasVisible)
        {
            _wasVisible = true;
            newSowing = new() { SownDate = DateTime.Now };
            errorMessage = "";
            nextBatchNumber = 0;

            var groupedSeeds = await SeedService.GetMySeedsGrouped();

            var allSeeds = groupedSeeds.SelectMany(g => g).ToList();
            if(InitialPlant != null)
            {
                availableSeeds = allSeeds.Where(s => s.PlantId == InitialPlant.Id).ToList();
                if(availableSeeds.Count == 1)
                {
                    newSowing.SeedId = availableSeeds.First().Id;
                    nextBatchNumber = await SowingService.GetNextBatchNumberAsync(newSowing.SeedId);
                }
                else
                {
                    newSowing.SeedId = 0;
                }
            }
            else
            {
                availableSeeds = allSeeds;
            }
        }
        else if(!IsVisible)
        {
            _wasVisible = false;
        }
        await Task.Delay(50);
    }

    private async Task OnSeedChangedAsync()
    {
        if (newSowing.SeedId <= 0)
        {
            nextBatchNumber = 0;
            return;
        }

        nextBatchNumber = await SowingService.GetNextBatchNumberAsync(newSowing.SeedId);
    }

    private async Task HandleSave()
    {
        if (newSowing.SeedId == 0)
        {
            errorMessage = "Du måste välja ett frö från lagret.";
            return;
        }

        try
        {
            // FIX 1: USE CORRECT ID TO FIND SEED IN STOCK
            var selectedView = availableSeeds.FirstOrDefault(s => s.Id == newSowing.SeedId);

            if (selectedView != null)
            {
                int sowingQty = newSowing.Quantity;
                // FIX 2: CHECK QUANTITY IN STOCK IS ENOUGH
                if (selectedView.Quantity < sowingQty)
                {
                    errorMessage = $"Du har bara {selectedView.Quantity} fröer kvar.";
                    return;
                }

                var seedToUpdate = new Seed
                {
                    Id = selectedView.Id,
                    UserId = selectedView.UserId,
                    Name = selectedView.Name,
                    VarietyName = selectedView.VarietyName ?? "", // Make sure string is not null
                    Quantity = selectedView.Quantity - sowingQty,
                    PlantId = selectedView.PlantId,
                    VarietyId = selectedView.VarietyId,
                    ExpiryDate = selectedView.ExpiryDate,
                    Notes = selectedView.Notes
                };

                await SeedService.UpdateSeed(seedToUpdate);

            }

            newSowing.UserId = _supabase.Auth.CurrentUser?.Id;
            newSowing.BatchNumber = nextBatchNumber > 0 ? nextBatchNumber : 1;
            await SowingService.AddSowing(newSowing); // Save sowing
            await OnSaved.InvokeAsync();
            await Close();
        }
        catch (Exception ex)
        {
            errorMessage = "Kunde inte spara: " + ex.Message;
        }
    }

    private Task Close() => OnClose.InvokeAsync();
}
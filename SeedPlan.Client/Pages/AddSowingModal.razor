@using SeedPlan.Shared.Models
@inject IUserInventoryService SeedService
@inject IUserSowingService SowingService
@inject IJSRuntime JS

@if (IsVisible)
{
    <div class="modal-overlay" @onclick="Close">
        <div class="modal-card fade-in" @onclick:stopPropagation>
            <div class="modal-body">
                
                @* 1. VÄLJ FRÖ *@
                <div class="input-block">
                    <label>VÄLJ FRÖ</label>
                    <select @bind="newSowing.SeedId" class="sp-input">
                        @if(InitialPlant != null)
                        {
                            <option value="0">Välj vilken sort av @InitialPlant.PlantName du sår..</option>
                        }
                        else
                        {
                            <option value="0">Välj ett frö från lagret...</option>
                        }
                        @foreach (var seed in availableSeeds)
                        {
                            @* Visa sortnamn (VarietyName) om det finns, annars fröets namn *@
                            <option value="@seed.Id">
                                @(string.IsNullOrEmpty(seed.VarietyName) ? seed.Name : seed.VarietyName)
                            </option>
                        }
                    </select>
                </div>

                @* 2. SÅDATUM *@
                <div class="input-block">
                    <label>SÅDATUM</label>
                    <input type="date" @bind="newSowing.SownDate" class="sp-input" />
                </div>

                @* 3. ANTECKNINGAR *@
                <div class="input-block">
                    <label>ANTECKNINGAR</label>
                    <textarea @bind="newSowing.Notes" class="sp-textarea" placeholder="Plats, jord, etc."></textarea>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <p class="error-msg">@errorMessage</p>
                }

                @* 4. STARTA SÅDD-KNAPP *@
                <button type="button" class="sp-submit-btn" @onclick="HandleSave">Starta sådd</button>

            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public Plant? InitialPlant { get; set; }

    private List<Seed> availableSeeds = new();
    private Sowing newSowing = new() { SownDate = DateTime.Now }; // Använder DateTime som du ändrat till
    private string errorMessage = "";

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible)
        {
            newSowing = new() { SownDate = DateTime.Now };
            errorMessage = "";

            var allOwnedSeeds = await SeedService.GetMySeeds(); // Hämtar dina fröer
            if(InitialPlant != null)
            {
                availableSeeds = allOwnedSeeds.Where(s => s.PlantId == InitialPlant.Id).ToList();
                if(availableSeeds.Count == 1)
                {
                    newSowing.SeedId = availableSeeds.First().Id;
                }
                else
                {
                    newSowing.SeedId = 0;
                }
            }
            else
            {
                availableSeeds = allOwnedSeeds;
            }
        }
    }

    private async Task HandleSave()
    {
        if (newSowing.SeedId == 0)
        {
            errorMessage = "Du måste välja ett frö från lagret.";
            return;
        }

        try
        {
            var selectedSeed = availableSeeds.FirstOrDefault(s => s.Id == newSowing.Id);
            if(selectedSeed != null)
            {
                if(selectedSeed.Quantity > 0)
                {
                    selectedSeed.Quantity--;
                    await SeedService.UpdateSeed(selectedSeed);
                }
            }

            await SowingService.AddSowing(newSowing); // Sparar sådden
            newSowing = new() { SownDate = DateTime.Now };
            await OnSaved.InvokeAsync();
            await Close();
        }
        catch (Exception ex)
        {
            errorMessage = "Kunde inte spara: " + ex.Message;
        }
    }

    private Task Close() => OnClose.InvokeAsync();
}
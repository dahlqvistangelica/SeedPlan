@page "/"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@inject IPlantLibraryService PlantService
@inject IUserSowingService SowingService
@inject IUserProfileService ProfileService
@inject IUserInventoryService InventoryService
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject NotificationService NotificationService

<PageTitle>Dashboard - SeedPlan</PageTitle>

<div class="dashboard-container">
    <header class="dashboard-header">
        
        <div class="header-top">
            <h1 class="serif-title">Välkommen tillbaka</h1>
            <div class="date-badge">
                <Blazicon Svg="Lucide.Calendar" />
                <span>@DateTime.Now.ToString("yyyy-MM-dd")</span>
            </div>
        </div>
        @if (staleSowings.Any())
        {
            <div class="notifications-section">
                <h2 class="section-title">BEHÖVER UPPMÄRKSAMHET</h2>
                <div class="notification-list">
                    @foreach (var sowing in staleSowings)
                    {
                        var warning = SowingHelper.GetStaleWarning(sowing.Status, sowing.StatusUpdatedAt, sowing.SownDate);
                        <div class="notification-card" @onclick='() => Nav.NavigateTo("/sowings")'>
                            <div class="notification-icon">
                                <Blazicon Svg="Lucide.TriangleAlert" />
                            </div>
                            <div class="notification-content">
                                <span class="notification-plant">@sowing.PlantName</span>
                                <span class="notification-message">@warning.message</span>
                            </div>
                            <Blazicon Svg="Lucide.ChevronRight" />
                        </div>
                    }
                </div>
            </div>
        }
    </header>

    @if (isLoading)
    {
        <div class="loading-spinner">Laddar din trädgård...</div>
    }
    else
    {
        @* ACTIVE SOWINGS (STATISTICS) *@
        @if (activeSowings != null && activeSowings.Any())
        {
            <div class="sowing-stats-section">
                <h2 class="section-title">AKTIVA SÅDDER</h2>
                <div class="stats-mini-grid">
                    <div class="mini-stat-card">
                        <div class="mini-icon blue"><Blazicon Svg="Lucide.Sprout" /></div>
                        <div class="mini-info">
                            <span class="mini-label">Grodda</span>
                            <span class="mini-value">@countGerminated</span>
                        </div>
                    </div>
                    <div class="mini-stat-card">
                        <div class="mini-icon green"><Blazicon Svg="MdiIcon.Shovel" /></div>
                        <div class="mini-info">
                            <span class="mini-label">Omskolade</span>
                            <span class="mini-value">@countRepotted</span>
                        </div>
                    </div>
                    <div class="mini-stat-card">
                        <div class="mini-icon yellow"><Blazicon Svg="MdiIcon.SunClockOutline" /></div>
                        <div class="mini-info">
                            <span class="mini-label">Avhärdade</span>
                            <span class="mini-value">@countAcclimated</span>
                        </div>
                    </div>
                    <div class="mini-stat-card">
                        <div class="mini-icon purple"><Blazicon Svg="MdiIcon.BeeFlower" /></div>
                        <div class="mini-info">
                            <span class="mini-label">Utplanterade</span>
                            <span class="mini-value">@countPlantedOut</span>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* SOWING WINDOW PASSED *@
        @if (overview?.Past != null && overview.Past.Any())
        {
            <details class="past-section">
                <summary>Redan passerat (@overview.Past.Count)</summary>
                <div class="plant-grid mini">
                    @foreach (var plant in overview.Past)
                    {
                        <div class="mini-card" @onclick="() => OpenPlantDetail(plant)">
                            <div class="mini-card-content">
                                <div class="mini-icon"><Blazicon Svg="Lucide.CalendarX" /></div>
                                <span>@plant.PlantName</span>
                            </div>
                        </div>
                    }
                </div>
            </details>
        }

        @* CURRENT SOWING WINDOW *@
        <h2 class="section-title">BÖR SÅS NU</h2>

        @if (userProfile?.LastFrostDate == null)
        {
            <div class="alert alert-info">
                <p>Inga såförslag hittades. Har du ställt in ditt <strong>sista frostdatum</strong> i profilen?</p>
                <a href="/profile" class="btn-link">Gå till profil</a>
            </div>
        }
        else if (sowingSuggestions == null || !sowingSuggestions.Any())
        {
            <div class="alert alert-success">
                <p>Du är i fas! Inget behöver sås just nu.</p>
            </div>
        }
        else
        {
            <div class="plant-grid">
                @foreach (var item in sowingSuggestions)
                {
                    <div class="plant-card @(item.IsShifted ? "shifted" : "")" @onclick="() => OpenPlantDetail(item.Plant)">

                        <div class="plant-main">
                            <div class="plant-icon-circle @GetPlantCategory(item.Plant.Category)">
                                <Blazicon Svg="@GetPlantBlazicon(item.Plant.Category)" />
                            </div>
                            <div class="plant-core-info">
                                <div class="plant-title-row">
                                    <span class="plant-name">@item.Plant.PlantName</span>
                                    @if (item.HasSeeds)
                                    {
                                        <button class="btn-sow-now" @onclick:stopPropagation="true" @onclick="() => StartSowing(item.Plant)">
                                            Så nu
                                        </button>
                                    }
                                    else
                                    {
                                       
                                        <span class="seed-status-tag">Frö</span>
                                        
                                    }
                                </div>
                                
                                @if (item.IsShifted)
                                {
                                    <span class="shifted-tag">Sent men möjligt</span>
                                }
                                @if (item.HarvestDateEarly.HasValue)
                                {
                                    <span class="harvest-info">
                                        <Blazicon Svg="Lucide.Calendar" class="icon-calendar"/>
                                        Skörd ~@item.HarvestDateEarly.Value.ToString("d MMM")
                                    </span>
                                }
                            </div>
                            @* HARDINESSBADGE *@
                            <div class="hardiness-badge @GetHardinessClass(item.Plant.HardinessLevel)">
                                <span class="full-text">@GetHardinessText(item.Plant.HardinessLevel)</span>
                                <span class="short-text">@GetShortHardinessText(item.Plant.HardinessLevel)</span>
                            </div>
                        </div>
                        <div class="plant-footer">
                            <div class="footer-icons">
                                @if (item.Plant.IsLightGerminating)
                                {
                                    <div class="feature-icon light" title="Ljusgroende">
                                    <Blazicon Svg="Lucide.Sparkles"/>
                                    </div>
                                }
                                @if (item.Plant.RequiresTopping)
                                {
                                    <div class="feature-icon topping" title="Ska toppas">
                                       <Blazicon Svg="Lucide.Scissors"/>
                                    </div>
                                }
                                
                            </div>
                            <Blazicon Svg="Lucide.ChevronRight" />
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

<PlantDetailModal IsVisible="showDetailModal" Plant="selectedPlant" OnClose="() => showDetailModal = false" OnSaved="HandleRefresh" />
<AddSowingModal IsVisible="showSowModal" InitialPlant="selectedPlantForSowing" OnClose="() => showSowModal = false" OnSaved="HandleRefresh" />

@code {
    private bool isLoading = true;
    private UserProfile? userProfile;
    private SowingOverview overview = new();
    private List<Sowing> activeSowings = new();
    private List<PlantSowingView> sowingSuggestions = new();
    private int countGerminated, countRepotted, countAcclimated, countPlantedOut;

    private bool showDetailModal = false;
    private bool showSowModal = false;
    private Plant? selectedPlant;
    private Plant? selectedPlantForSowing;
    // Ta bort: private List<SowingView> staleSowings = new();

    // Lägg till denna property istället
    private IEnumerable<SowingView> staleSowings =>
        allSowingViews.Where(s => SowingHelper.GetStaleWarning(
            s.Status,
            s.StatusUpdatedAt,
            s.SownDate).show);

    // Lägg till denna lista som backing field
    private List<SowingView> allSowingViews = new();

    protected override async Task OnInitializedAsync() 
    {
        await LoadData();
        
        await NotificationService.SubscribeToPushAsync();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            //Get profile
            userProfile = await ProfileService.GetUserProfile();
            if (userProfile?.LastFrostDate != null)
            {
                overview = await PlantService.GetSowingOverviewAsync(userProfile.LastFrostDate.Value);
                sowingSuggestions = await InventoryService.GetCurrentSowingCalendar();
            }
            //Get sowings
            var allSowings = await SowingService.GetMySowings() ?? new List<Sowing>();

            allSowingViews = await SowingService.GetMySowingViews();
            await NotificationService.CheckAndNotifyStaleAsync(allSowingViews);

            //Converting to int.
            activeSowings = allSowings.Where(s => (int)s.Status < 7).ToList();

            countGerminated = activeSowings.Count(s => (int)s.Status >= 1 && (int)s.Status <= 2);
            countRepotted = activeSowings.Count(s => (int)s.Status >= 3 && (int)s.Status <= 4);
            countAcclimated = activeSowings.Count(s => (int)s.Status == 5);
            countPlantedOut = activeSowings.Count(s => (int)s.Status == 6);

        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
            await Task.Delay(200);
        }
    }

    // HELPMETHODS
    private string GetFrostText(int weeks) => weeks <= 0 ? "planteras ut efter frost" : $"planteras ut {weeks} v. före frost";
    private string GetHardinessText(int level) => level switch { 0 => "Känslig", 1 => "Halvhärdig", 2 => "Härdig", _ => "" };
    private string GetHardinessClass(int level) => level switch { 0 => "sensitive", 1 => "half-hardy", 2 => "hardy", _ => "" };
    private string GetShortHardinessText(int level) => level switch { 0 => "K", 1 => "HH", 2 => "H", _ => "" };
    private string GetPlantCategory(PlantCategory category) => category switch { PlantCategory.Vegetable => "vegetable", PlantCategory.Flower => "flower", PlantCategory.Herb => "herb", PlantCategory.Fruit => "fruit" };
    private SvgIcon GetPlantBlazicon(PlantCategory category) => category switch
    {
        PlantCategory.Vegetable => Lucide.Carrot,
        PlantCategory.Flower => Lucide.Flower,
        PlantCategory.Herb => MdiIcon.Clover,
        PlantCategory.Fruit => Lucide.Apple

    };

    private void OpenPlantDetail(Plant plant) { selectedPlant = plant; showDetailModal = true;  }
    private void StartSowing(Plant plant) { selectedPlantForSowing = plant; showSowModal = true; }
    private async Task HandleRefresh() => await LoadData();
}
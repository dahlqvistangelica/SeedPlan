@page "/"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using SeedPlan.Shared.Models
@inject IPlantLibraryService PlantService
@inject IUserSowingService SowingService
@inject IUserProfileService ProfileService
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS

<PageTitle>Dashboard - SeedPlan</PageTitle>

<div class="dashboard-container">
    <header class="dashboard-header">
        <div class="header-top">
            <h1>Välkommen tillbaka</h1>
            <div class="date-badge">
                <i data-lucide="calendar"></i>
                <span>@DateTime.Now.ToString("yyyy-MM-dd")</span>
            </div>
        </div>
    </header>

    @if (isLoading)
    {
        <div class="loading-spinner">Laddar din trädgård...</div>
    }
    else
    {
        @* VISAS BARA OM DET FINNS AKTIVA SÅDDER *@
        @if (activeSowings.Any())
        {
            <div class="sowing-stats-section">
                <h2 class="section-title">AKTIVA SÅDDER</h2>
                <div class="stats-mini-grid">
                    <div class="mini-stat-card">
                        <div class="mini-icon blue"><i data-lucide="sprout"></i></div>
                        <div class="mini-info">
                            <span class="mini-label">SÅTIDER</span>
                            <span class="mini-value">@countSown</span>
                        </div>
                    </div>
                    <div class="mini-stat-card">
                        <div class="mini-icon green"><i data-lucide="check-circle"></i></div>
                        <div class="mini-info">
                            <span class="mini-label">GRODDA</span>
                            <span class="mini-value">@countGerminated</span>
                        </div>
                    </div>
                    <div class="mini-stat-card">
                        <div class="mini-icon yellow"><i data-lucide="leaf"></i></div>
                        <div class="mini-info">
                            <span class="mini-label">OMSKOLADE</span>
                            <span class="mini-value">@countRepotted</span>
                        </div>
                    </div>
                    <div class="mini-stat-card">
                        <div class="mini-icon purple"><i data-lucide="sun"></i></div>
                        <div class="mini-info">
                            <span class="mini-label">UTPLANTERADE</span>
                            <span class="mini-value">@countPlantedOut</span>
                        </div>
                    </div>
                </div>
            </div>
        }

        <h2 class="section-title">BÖR SÅS NU</h2>
        @if (!sowingSuggestions.Any())
        {
            <div class="empty-state">
                <p>Inga växter rekommenderas för sådd just nu. 🌱</p>
            </div>
        }
        else
        {
            <div class="plant-grid">
                @foreach (var plant in sowingSuggestions)
                {
                    <div class="plant-card">
                        <div class="plant-main">
                            <div class="plant-icon-circle"><i data-lucide="sprout"></i></div>
                            <div class="plant-core-info">
                                <span class="plant-name">@plant.PlantName</span>
                                <span class="frost-info">@plant.WeeksBeforeFrost v. före frost</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private bool isLoading = true;
    private List<Plant> sowingSuggestions = new();
    private List<Sowing> activeSowings = new();
    private int countSown, countGerminated, countRepotted, countPlantedOut;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            
            if (authState.User.Identity?.IsAuthenticated == true)
            {
                // Hämta och räkna sådder
                var allSowings = await SowingService.GetMySowings();
                activeSowings = allSowings.Where(s => s.Status < 7).ToList();

                countSown = activeSowings.Count(s => s.Status == 0);
                countGerminated = activeSowings.Count(s => s.Status >= 1 && s.Status <= 2);
                countRepotted = activeSowings.Count(s => s.Status >= 3 && s.Status <= 4);
                countPlantedOut = activeSowings.Count(s => s.Status >= 5 && s.Status <= 6);

                // Hämta förslag
                var lastFrost = await ProfileService.GetUserLastFrostDate() ?? new DateTime(DateTime.Now.Year, 5, 15);
                sowingSuggestions = await PlantService.GetGeneralSowingSuggestionsAsync(lastFrost);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initializeLucide");
    }
}
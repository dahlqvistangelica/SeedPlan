@page "/"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@inject IPlantLibraryService PlantService
@inject IUserSowingService SowingService
@inject IUserProfileService ProfileService
@inject IUserInventoryService InventoryService
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject NotificationService NotificationService
@inject AppState AppState

<SeoHead Title="Såkalender & Fröhantering - SeedPlan"
         Description="Planera din odling med SeedPlans såkalender, få överblick över aktiva sådder och håll koll på vad som behöver göras nu."
         Keywords="såkalender, fröhantering, odlingsplanering, sådder, odling" />

<div class="dashboard-container">
    <header class="dashboard-header">
        <div class="header-top">
            <h1 class="serif-title">Välkommen tillbaka</h1>
            <div class="date-badge">
                <Blazicon Svg="Lucide.Calendar" />
                <span>@DateTime.Now.ToString("yyyy-MM-dd")</span>
            </div>
        </div>
        @if (staleSowings.Any())
        {
            <div class="notifications-section">
                <h2 class="section-title">BEHÖVER UPPMÄRKSAMHET</h2>
                <div class="notification-list">
                    @foreach (var sowing in staleSowings)
                    {
                        var warning = SowingHelper.GetStaleWarning(sowing.Status, sowing.StatusUpdatedAt, sowing.SownDate);
                        <div class="notification-card" @onclick='() => Nav.NavigateTo("/sowings")'>
                            <div class="notification-icon">
                                <Blazicon Svg="Lucide.TriangleAlert" />
                            </div>
                            <div class="notification-content">
                                <span class="notification-plant">@sowing.PlantName - Omgång @sowing.BatchNumber</span>
                                <span class="notification-message">@warning.message</span>
                            </div>
                            <Blazicon Svg="Lucide.ChevronRight" />
                        </div>
                    }
                </div>
            </div>
        }
    </header>

    @if (isLoading)
    {
        <LoadingSpinner Text="Laddar inställningar..." />
    }
    else
    {
        @* ACTIVE SOWINGS STATISTICS *@
        @if (activeSowings != null && activeSowings.Any())
        {
            <div class="sowing-stats-section">
                <h2 class="section-title">AKTIVA SÅDDER</h2>
                <div class="stats-mini-grid">
                    <div class="mini-stat-card">
                        <div class="mini-icon blue"><Blazicon Svg="Lucide.Sprout" /></div>
                        <div class="mini-info">
                            <span class="mini-label">Grodda</span>
                            <span class="mini-value">@countGerminated</span>
                        </div>
                    </div>
                    <div class="mini-stat-card">
                        <div class="mini-icon green"><Blazicon Svg="MdiIcon.Shovel" /></div>
                        <div class="mini-info">
                            <span class="mini-label">Omskolade</span>
                            <span class="mini-value">@countRepotted</span>
                        </div>
                    </div>
                    <div class="mini-stat-card">
                        <div class="mini-icon yellow"><Blazicon Svg="MdiIcon.SunClockOutline" /></div>
                        <div class="mini-info">
                            <span class="mini-label">Avhärdade</span>
                            <span class="mini-value">@countAcclimated</span>
                        </div>
                    </div>
                    <div class="mini-stat-card">
                        <div class="mini-icon purple"><Blazicon Svg="MdiIcon.BeeFlower" /></div>
                        <div class="mini-info">
                            <span class="mini-label">Utplanterade</span>
                            <span class="mini-value">@countPlantedOut</span>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (userProfile?.PreferredPlantCategories?.Any() == false)
        {
            <div class="alert alert-info">
                Välj minst en kategori i inställningarna för att se såförslag.
            </div>
        }
        else if (userProfile?.LastFrostDate == null)
        {
            <div class="alert alert-info">
                <p>Inga såförslag hittades. Har du ställt in ditt <strong>sista frostdatum</strong> i profilen?</p>
                <a href="/profile" class="btn-link">Gå till profil</a>
            </div>
        }
        else
        {
            @* DAGS ATT SÅ — HAR FRÖN *@
            @if (sowingWithSeeds.Any())
            {
                <details class="sow-section" open>
                    <summary>
                        <span class="sow-section-name">Dags att så</span>
                        <span class="sow-section-badge badge-has-seeds">@sowingWithSeeds.Count har frön</span>
                    </summary>
                    <div class="plant-grid">
                        @foreach (var item in sowingWithSeeds)
                        {
                            <SowingSuggestionCard item="item" OnClick="() => OpenPlantDetail(item.Plant)" StartSowing="() => StartSowing(item.Plant)" />
                        }
                    </div>
                </details>
            }

            @* DAGS ATT SÅ — SAKNAR FRÖN *@
            @if (sowingWithoutSeeds.Any())
            {
                <details class="sow-section">
                    <summary>
                        <span class="sow-section-name">Dags att så</span>
                        <span class="sow-section-badge badge-no-seeds">@sowingWithoutSeeds.Count saknar frön</span>
                    </summary>
                    <div class="plant-grid">
                        @foreach (var item in sowingWithoutSeeds)
                        {
                            <SowingSuggestionCard item="item" OnClick="() => OpenPlantDetail(item.Plant)" StartSowing="() => StartSowing(item.Plant)" />
                        }
                    </div>
                </details>
            }

            @if (!sowingWithSeeds.Any() && !sowingWithoutSeeds.Any())
            {
                <div class="alert alert-success">
                    <p>Du är i fas! Inget behöver sås just nu.</p>
                </div>
            }

            @* SNART DAGS ATT SÅ *@
            @if (upcomingPlants.Any())
            {
                <details class="sow-section">
                    <summary>
                        <span class="sow-section-name">Snart dags att så</span>
                        <span class="sow-section-badge badge-upcoming">@upcomingPlants.Count</span>
                    </summary>
                    <div class="plant-grid mini">
                        @foreach (var plant in upcomingPlants)
                        {
                            var sowDate = userProfile.LastFrostDate!.Value.AddDays(-(plant.SowingLeadTime * 7));
                            <div class="mini-card" @onclick="() => OpenPlantDetail(plant)">
                                <div class="mini-card-content">
                                    <div class="mini-icon upcoming-icon"><Blazicon Svg="Lucide.CalendarClock" /></div>
                                    <div class="mini-card-text">
                                        <span>@plant.PlantName</span>
                                        <span class="mini-badge">från @sowDate.ToString("d MMM")</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </details>
            }

            @* REDAN PASSERAT *@
            @if (pastPlants.Any())
            {
                <details class="sow-section">
                    <summary>
                        <span class="sow-section-name">Redan passerat</span>
                        <span class="sow-section-badge badge-past">@pastPlants.Count</span>
                    </summary>
                    <div class="plant-grid mini">
                        @foreach (var plant in pastPlants)
                        {
                            <div class="mini-card" @onclick="() => OpenPlantDetail(plant)">
                                <div class="mini-card-content">
                                    <div class="mini-icon"><Blazicon Svg="Lucide.CalendarX" /></div>
                                    <span>@plant.PlantName</span>
                                </div>
                            </div>
                        }
                    </div>
                </details>
            }
        }
    }
</div>

<PlantDetailModal IsVisible="showDetailModal" Plant="selectedPlant" OnClose="() => showDetailModal = false" OnSaved="HandleRefresh" />
<AddSowingModal IsVisible="showSowModal" InitialPlant="selectedPlantForSowing" OnClose="() => showSowModal = false" OnSaved="HandleRefresh" />

@code {
    private bool isLoading = true;
    private UserProfile? userProfile;
    private SowingOverview overview = new();
    private List<Sowing> activeSowings = new();
    private List<PlantSowingView> sowingSuggestions = new();
    private int countGerminated, countRepotted, countAcclimated, countPlantedOut, countHarvested;

    private List<PlantSowingView> sowingWithSeeds = new();
    private List<PlantSowingView> sowingWithoutSeeds = new();
    private List<Plant> upcomingPlants = new();
    private List<Plant> pastPlants = new();

    private bool showDetailModal = false;
    private bool showSowModal = false;
    private Plant? selectedPlant;
    private Plant? selectedPlantForSowing;

    private IEnumerable<SowingView> staleSowings =>
        allSowingViews.Where(s => SowingHelper.GetStaleWarning(
            s.Status,
            s.StatusUpdatedAt,
            s.SownDate).show);

    private List<SowingView> allSowingViews = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity is not null && user.Identity.IsAuthenticated)
            {
                await LoadData();
                await ClearAppBadge();
                if (AppState.CurrentMode == AppMode.DahliaBox)
                {
                    Nav.NavigateTo("/dahliabox-home");
                }

                var userEmail = user.Identity.Name ?? user.FindFirst(c => c.Type == "email")?.Value;
                if (userEmail != "demo@seedplan.app")
                {
                    await NotificationService.SubscribeToPushAsync();
                }
            }
            else
            {
                isLoading = false;
            }

            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;

            var profileTask = ProfileService.GetUserProfile();
            var sowingsTask = SowingService.GetMySowings();
            var sowingViewsTask = SowingService.GetMySowingViews();

            userProfile = await profileTask;

            if (userProfile?.LastFrostDate != null)
            {
                var overviewTask = PlantService.GetSowingOverviewAsync(userProfile.LastFrostDate.Value);
                var suggestionsTask = InventoryService.GetCurrentSowingCalendar();

                await Task.WhenAll(overviewTask, suggestionsTask);

                overview = await overviewTask;

                sowingSuggestions = (await suggestionsTask)
                    .Where(p => userProfile.PreferredPlantCategories.Contains((int)p.Plant.Category))
                    .ToList();

                sowingWithSeeds = sowingSuggestions.Where(x => x.HasSeeds).ToList();
                sowingWithoutSeeds = sowingSuggestions.Where(x => !x.HasSeeds).ToList();

                // Exclude plants already shown in "dags att så" (shifted plants would otherwise duplicate into "passerat")
                var sowingSuggestionPlantIds = sowingSuggestions.Select(x => x.Plant.Id).ToHashSet();

                pastPlants = overview.Past
                    .Where(p => userProfile.PreferredPlantCategories.Contains((int)p.Category))
                    .Where(p => !sowingSuggestionPlantIds.Contains(p.Id))
                    .ToList();

                upcomingPlants = overview.Upcoming
                    .Where(p => userProfile.PreferredPlantCategories.Contains((int)p.Category))
                    .ToList();
            }

            var allSowings = await sowingsTask ?? new List<Sowing>();
            allSowingViews = await sowingViewsTask ?? new List<SowingView>();

            activeSowings = allSowings.Where(s => SowingStatusFlow.IsActive(s.Status)).ToList();

            countGerminated = activeSowings.Count(s => s.Status is >= 1 and <= 2);
            countRepotted = activeSowings.Count(s => s.Status == (int)SowingStatus.PottedOn);
            countAcclimated = activeSowings.Count(s => s.Status == (int)SowingStatus.HardeningOff);
            countPlantedOut = activeSowings.Count(s => s.Status == (int)SowingStatus.PlantedOut);
            countHarvested = activeSowings.Count(s => s.Status == (int)SowingStatus.Harvested);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ClearAppBadge()
    {
        try
        {
            await JS.InvokeVoidAsync("appBadging.clearBadge");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Kunde inte rensa badge: {ex.Message}");
        }
    }

    private void OpenPlantDetail(Plant plant) { selectedPlant = plant; showDetailModal = true; }
    private void StartSowing(Plant plant) { selectedPlantForSowing = plant; showSowModal = true; }
    private async Task HandleRefresh() => await LoadData();
}

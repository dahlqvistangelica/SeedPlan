@page "/"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using SeedPlan.Shared.Models
@using SeedPlan.Shared.Models.ViewModels
@using global::Shared.Models
@inject IPlantLibraryService PlantService
@inject IUserSowingService SowingService
@inject IUserProfileService ProfileService
@inject IUserInventoryService InventoryService
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS

<PageTitle>Dashboard - SeedPlan</PageTitle>

<div class="dashboard-container">
    <header class="dashboard-header">
        <div class="header-top">
            <h1 class="serif-title">Välkommen tillbaka</h1>
            <div class="date-badge">
                <i data-lucide="calendar"></i>
                <span>@DateTime.Now.ToString("yyyy-MM-dd")</span>
            </div>
        </div>
    </header>

    @if (isLoading)
    {
        <div class="loading-spinner">Laddar din trädgård...</div>
    }
    else
    {
        
        @* VISAS BARA OM DET FINNS AKTIVA SÅDDER *@
        @if (activeSowings.Any())
        {
            <div class="sowing-stats-section">
                <h2 class="section-title">AKTIVA SÅDDER</h2>
                <div class="stats-mini-grid">
                    <div class="mini-stat-card">
                        <div class="mini-icon blue"><i data-lucide="sprout"></i></div>
                        <div class="mini-info">
                            <span class="mini-label">Nysått</span>
                            <span class="mini-value">@countSown</span>
                        </div>
                    </div>
                    <div class="mini-stat-card">
                        <div class="mini-icon green"><i data-lucide="check-circle"></i></div>
                        <div class="mini-info">
                            <span class="mini-label">GRODDAT</span>
                            <span class="mini-value">@countGerminated</span>
                        </div>
                    </div>
                    <div class="mini-stat-card">
                        <div class="mini-icon yellow"><i data-lucide="leaf"></i></div>
                        <div class="mini-info">
                            <span class="mini-label">OMSKOLADE</span>
                            <span class="mini-value">@countRepotted</span>
                        </div>
                    </div>
                    <div class="mini-stat-card">
                        <div class="mini-icon purple"><i data-lucide="sun"></i></div>
                        <div class="mini-info">
                            <span class="mini-label">UTPLANTERADE</span>
                            <span class="mini-value">@countPlantedOut</span>
                        </div>
                    </div>
                </div>
            </div>
        }
        @* REDAN PASSERAT (Accodion) *@
        @if (overview.Past.Any())
    {
        <details class="past-section">
            <summary>Redan passerat (@overview.Past.Count)</summary>
            <div class="plant-grid mini">
                @foreach (var plant in overview.Past)
                {
                        <div class="mini-card" @onclick="() => OpenPlantDetail(plant)">
                            <div class="mini-card-content">
                                <i data-lucide="calendar-x" class="mini-icon"></i>
                                <span>@plant.PlantName</span>
                            </div>
                            <span class="mini-badge">Passerat</span>
                        </div>
                }
            </div>
        </details>
    }

        <h2 class="section-title">BÖR SÅS NU</h2>
        @if (!sowingSuggestions.Any())
        {
            <div class="empty-state">
                <p>Inga växter rekommenderas för sådd just nu. </p>
            </div>
        }
        else
        {
            <div class="plant-grid">
                @foreach (var item in sowingSuggestions)
                {
                    <div class="plant-card" @onclick="() => OpenPlantDetail(item.Plant)">
                        <div class="plant-main">
                            <div class="plant-icon-circle">
                                <i data-lucide="leaf"></i>
                            </div>
                            <div class="plant-core-info">
                                <div class="plant-title-row">
                                    <span class="plant-name">@item.Plant.PlantName</span>
                                    @* Här kommer lager-logiken! *@
                                    @if (item.HasSeeds)
                                    {
                                        @* stopPropagation hindrar att PlantDetailModal öppnas när man klickar på knappen *@
                                        <button class="btn-sow-now" @onclick:stopPropagation="true" @onclick="() => StartSowing(item.Plant)">
                                            Så nu
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="seed-status-tag">Saknar frö</span>
                                    }
                                </div>
                                <span class="frost-info">@GetFrostText(item.Plant.WeeksBeforeFrost)</span>

                            </div>
                
                            @* Härdighetsbadge *@
                            <div class="hardiness-badge @GetHardinessClass(item.Plant.HardinessLevel)">
                                @GetHardinessText(item.Plant.HardinessLevel)
                            </div>
                        </div>

                        <div class="plant-footer">
                            <div class="footer-icons">
                                @if (item.Plant.IsLightGerminating)
                                {
                                    <div class="feature-icon light" title="Ljusgroende">
                                        <i data-lucide="sparkles"></i>
                                    </div>
                                }
                                @if (item.Plant.RequiresTopping)
                                {
                                    <div class="feature-icon topping" title="Ska toppas">
                                        <i data-lucide="scissors"></i>
                                    </div>
                                }
                            </div>
                            <i data-lucide="chevron-right" class="arrow"></i>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>
<PlantDetailModal IsVisible="showDetailModal"
                  Plant="selectedPlant"
                  OnClose="() => showDetailModal = false"
                  OnSaved="HandleRefresh" />

<AddSowingModal IsVisible="showSowModal"
                InitialPlant="selectedPlantForSowing"
                OnClose="() => showSowModal = false"
                OnSaved="HandleRefresh" />

@code {
    private bool isLoading = true;
    private SowingOverview overview = new();
    private List<Sowing> activeSowings = new();
    private int countSown, countGerminated, countRepotted, countPlantedOut;
    private List<PlantSowingView> sowingSuggestions = new();

    private bool showSowModal = false;
    private Plant? selectedPlantForSowing;

    private string GetFrostText(int weeks)
    {
        if(weeks <= 0)
        {
            return "planteras ut efter sista frost";
        }
        return $"planteras ut {weeks}. v före sista frost";
    }
    private string GetHardinessText(int level) => level switch
    {
        0 => "Känslig",
        1 => "Halvhärdig",
        2 => "Härdig",
        _ => ""
    };
    private string GetHardinessClass(int level) => level switch
    {
        0 => "sensitive",
        1 => "half-hardy",
        2 => "hardy",
        _ => ""
    };
    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            var authState = await AuthProvider.GetAuthenticationStateAsync();

            if (authState.User.Identity?.IsAuthenticated == true)
            {
                // Hämta och räkna sådder
                var allSowings = await SowingService.GetMySowings();
                activeSowings = allSowings.Where(s => s.Status < 7).ToList();

                countSown = activeSowings.Count(s => s.Status == 0);
                countGerminated = activeSowings.Count(s => s.Status >= 1 && s.Status <= 2);
                countRepotted = activeSowings.Count(s => s.Status >= 3 && s.Status <= 4);
                countPlantedOut = activeSowings.Count(s => s.Status >= 5 && s.Status <= 6);


                // Hämta förslag
                var lastFrost = await ProfileService.GetUserLastFrostDate() ?? new DateTime(DateTime.Now.Year, 5, 15);
                var today = DateTime.Today;

                overview = await PlantService.GetSowingOverviewAsync(lastFrost);
                sowingSuggestions = await InventoryService.GetCurrentSowingCalendar();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initializeLucide");
    }
    //PLANT DETAIL MODAL CODE

    private bool showDetailModal = false;
    private Plant? selectedPlant;

    //Öppnar fönstret med plantdetails
    private void OpenPlantDetail(Plant plant)
    {
        selectedPlant = plant;
        showDetailModal = true;
    }
    private async Task HandleRefresh()
    {//Uppdaterar listan om man sparat ett nytt frö
        await OnInitializedAsync();
    }

    private void StartSowing(Plant plant)
    {
        selectedPlantForSowing = plant;
        showSowModal = true;
    }
}
@page "/seeds"
@using Microsoft.AspNetCore.Authorization
@inject IUserInventoryService SeedService
@inject IJSRuntime JS

<SeoHead Title="Mina fröer - SeedPlan"
         Description="Få överblick över ditt frölager i SeedPlan, organisera dina fröer och håll koll på din fröinventering."
         Keywords="fröer, fröinventering, frölager, odling, seedplan" />

<div class="seeds-container">
    <header class="seeds-header">
        <h1 class="serif-title">Mina Fröer</h1>
        <div class="control-button">
            <button class="btn-add-seed" title="Lägg till frö" @onclick="OpenAddSeed">
                <div class="btn-add-seed-icon"><Blazicon Svg="MdiIcon.SeedPlusOutline" /></div>
                <span>Nytt frö</span> @* Hides on mobile *@
            </button>
        </div>
    </header>

    @if (isLoading)
    {
        <LoadingSpinner Text="Laddar dina fröer..." />
    }
    else if (!groupedSeeds.Any())
    {
        <div class="empty-state">
            <p>Ditt fröbibliotek är tomt. Dags att fylla på! <Blazicon Svg="MdiIcon.SeedOutline"/></p>
            <button class="btn-primary" @onclick="OpenAddSeed">Lägg till ditt första frö</button>
        </div>
    }
    else
    {
        <div class="seed-list">
    @foreach (var group in groupedSeeds)
            {
                
                var isExpanded = expandedGroups.Contains(group.Key);

                <div class="plant-group-header" @onclick="() => ToggleGroup(group.Key)" style="cursor: pointer;">
                    <div class="plant-group-header-main">
                        <div class="chevron">
                        @* Chevron-icon to that changes with expansion. *@
                        @if(!isExpanded)
                        {
                                <Blazicon Svg="Lucide.ChevronRight" />
                        }
                        else
                        {
                                <Blazicon Svg="Lucide.ChevronDown" />
                        }
                        </div>
                        <h2 class="serif-title">@if (group.Key == "Övrigt")
                            {
                                @extraSeedGroup                   
                            }
                            else
                            {
                                @group.Key
                            }
                        </h2>
                    </div>
                    
                        @if(@group.Count() > 1)
                        {
                        <span class="seed-count">
                            @group.Count() sorter </span> }
                        else
                        {
                        <span class="seed-count">@group.Count() sort </span>
                        }
                    
                </div>
                @if (isExpanded)
                {
                    <div class="group-content fade-in">
                        @foreach (var seed in group)
                        {
                            
                            <SeedCard Seed="seed" OnDelete="() => HandleDelete(seed)" OnClick="() => OpenEditSeed(seed)"/>
                            
                        }
                    </div>
                    }
            }
</div>
    }
</div>
<AddSeedModal IsVisible="showAddModal" 
              OnClose="() => showAddModal = false" 
              OnSaved="RefreshSeeds" />
<EditSeedModal IsVisible="showEditModal"
               Seed="selectedSeed"
               OnClose="() => showEditModal = false"
               OnSaved="RefreshSeeds"/>

@code {
    private IEnumerable<IGrouping<string, SeedView>> groupedSeeds = Enumerable.Empty<IGrouping<string, SeedView>>();
    private bool isLoading = true;
    private bool showEditModal = false;
    private Seed? selectedSeed;
    private HashSet<string> expandedGroups = new();
    private bool showAddModal = false;
    private string extraSeedGroup ="Blandade fröer";

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if(firstRender)
        {
            try
            {
                await RefreshSeeds();
            }
            finally
            {
                isLoading = false;
                StateHasChanged();
            }
        }

    }
    /// <summary>
    /// Method that opens the modal for adding a seed to the collection.
    /// </summary>
    private void OpenAddSeed() => showAddModal = true;

    /// <summary>
    /// Toggles the expansion state of a plant group in the UI.
    /// </summary>
    /// <param name="plantName">The name of the plant group to expand or collapse.</param>
    /// <returns>A task representing the asynchronous toggle operation.</returns>

    private async Task ToggleGroup(string plantName)
    {
        if(expandedGroups.Contains(plantName))
        {
            expandedGroups.Remove(plantName);
        }
        else
        {
            expandedGroups.Add(plantName);
        }
        await Task.Delay(1);
    }
    /// <summary>
    /// Refreshes the list of seeds by fetching grouped seed data from the service.
    /// </summary>
    /// <returns>A task representing the asynchronous refresh operation.</returns>
    private async Task RefreshSeeds()
    {
        isLoading = true;
        groupedSeeds = await SeedService.GetMySeedsGrouped();
        isLoading = false;
        StateHasChanged();
    }

    /// <summary>
    /// Persists the updated seed information to the database and refreshes the current view.
    /// </summary>
    /// <returns>A task representing the asynchronous save operation.</returns>
    private async Task SaveQuantity()
    {
        if(selectedSeed != null)
        {
            await SeedService.UpdateSeed(selectedSeed);
            await RefreshSeeds();
            showEditModal = false;
        }
    }

    /// <summary>
    /// Prepares a seed for editing by mapping the view model to a seed entity and opening the edit modal.
    /// </summary>
    /// <param name="seed">The seed view model containing the data to be edited.</param>
    private void OpenEditSeed(SeedView seed)
    {
        selectedSeed = new Seed
        {
            Id = seed.Id,
            Name = seed.Name,
            VarietyName = seed.VarietyName ?? "",
            Quantity = seed.Quantity,
            PlantId = seed.PlantId,
            VarietyId = seed.VarietyId,
            Notes = seed.Notes,
            ExpiryDate = seed.ExpiryDate
        };
        showEditModal = true;
    }


    /// <summary>
    /// Displays a confirmation dialog and deletes the specified seed if the user confirms.
    /// </summary>
    /// <param name="seed">The seed view model to be deleted.</param>
    /// <returns>A task representing the asynchronous delete operation.</returns>

    private async Task HandleDelete(SeedView seed)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Vill du verkligen ta bort {seed.VarietyName ?? seed.Name} ?");
        if (confirmed)
        {
            await SeedService.DeleteSeed(seed.Id);
            await RefreshSeeds();
        }
    }
}
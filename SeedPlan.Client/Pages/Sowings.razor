@page "/sowings"
@using Microsoft.AspNetCore.Authorization
@inject IUserSowingService SowingService
@inject IJSRuntime JS

<SeoHead Title="Mina sådder - SeedPlan"
         Description="Följ dina aktiva sådder i SeedPlan, gruppera efter status och håll ordning på hela din såplanering."
         Keywords="sådder, såplanering, odling, fröer, seedplan" />

<div class="sowings-container">
    <header class="sowings-header">
        <h1 class="serif-title">Mina Sådder</h1>
        <div class="group-controls">
        <div class="control-button">
            <button class="btn-add-sowing" title="Lägg till sådd" @onclick="OpenAddSowing">
                <Blazicon Svg="Lucide.Sprout" />
                <span>Ny sådd</span> @* Comment translated to English. *@
            </button>
            </div>
        </div>
    </header>
        @* GROUPCONTROLS *@
        <div class="toolbar">
                <div class="search-box">
                    <input type="text"
                           @bind="searchTerm"
                           @bind:event="oninput"
                           placeholder="Sök växt eller sort..."
                           class="search-input" />
                    @if (!string.IsNullOrEmpty(searchTerm))
                    {
                        <button class="clear-btn" @onclick="@(() => searchTerm = "")">
                            <Blazicon Svg="Lucide.CircleX" />
                        </button>
                    }
                </div>
            <div class="control-select">
                <select @bind="currentGrouping" class="group-select">
                    <option value="none">Ingen gruppering</option>
                    <option value="status">Gruppera efter såstatus</option>
                    <option value="plant">Gruppera efter växt</option>
                    <option value="date">Gruppera efter sådatum</option>
                </select>
            </div>
        </div>

    <AddSowingModal IsVisible="showAddModal"
                    OnClose="() => showAddModal = false"
                    OnSaved="LoadSowings" />

    @if (isLoading)
    {
        <LoadingSpinner Text="Hämtar dina sådder..." />
    }
    else if (!mySowings.Any())
    {
        <div class="empty-state">
            <p>Du har inga aktiva sådder just nu. 🌱</p>
        </div>
    }
    else
    {
       
      @foreach (var group in GetGroupedSowings())
            {
                @if (currentGrouping != "none")
                {
                    <h2 class="group-header">@group.Key</h2>
                }
                <div class="sowing-grid">
                @foreach (var sowing in group)
                {
                    <SowingCard sowing="sowing" OnClick="OpenDetailView" />
                }
                </div>
            }
        
    }
    @if (!string.IsNullOrWhiteSpace(statusErrorMessage))
    {
        <div class="warning-box">
            <Blazicon Svg="Lucide.TriangleAlert" />
            <span>@statusErrorMessage</span>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(deleteInfoMessage))
    {
        <div class="info-box">
            <Blazicon Svg="Lucide.Info" />
            <span>@deleteInfoMessage</span>
        </div>
    }
</div>

<SowingDetailsModal IsVisible="showDetailModal"
                    Sowing="selectedSowing"
                    OnClose="() => showDetailModal = false"
                    OnUpdateNeeded="LoadSowings"
                    OnDeleted="LoadSowings" />


@code {
    private List<SowingView> mySowings = new();
    private string currentGrouping = "none";
    private bool isLoading = true;
    private bool showAddModal = false;
    private string searchTerm = "";

    private string statusErrorMessage = "";
    private bool isStatusUpdating;
    private int? updatingSowingId;
    private string? deleteInfoMessage;
    private readonly Dictionary<int, List<SowingEvent>> sowingEventsBySowingId = new();
    private readonly HashSet<int> loadingEventSowingIds = new();
    private SowingView? selectedSowing;
    private bool showDetailModal;

    private void OpenDetailView(SowingView sowing)
    {
        selectedSowing = sowing;
        showDetailModal = true;
        StateHasChanged();
    }

    private void OpenAddSowing()
    {
        showAddModal = true;
    }

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if(firstRender)
        {
            try
            {
                await LoadSowings();
            }
            finally
            {
                isLoading = false;
                StateHasChanged();
            }
        }

    }  

    private async Task LoadSowings()
    {
        isLoading = true;
        mySowings = await SowingService.GetMySowingViews();
        deleteInfoMessage = null;
        isLoading = false;

        StateHasChanged();
    }

    private IEnumerable<SowingView> GetFilteredSowings()
    {
        if(string.IsNullOrWhiteSpace(searchTerm))
        {
            return mySowings;
        }
        return mySowings.Where(s => (s.PlantName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) || (s.VarietyName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));
    }

    private IEnumerable<IGrouping<string, SowingView>> GetGroupedSowings()
    {
        var filtreredList = GetFilteredSowings();

        if (currentGrouping == "status")
        {
            return filtreredList
            .OrderBy(s => s.Status)
            .GroupBy(s => GetStatusText(s.Status));
        }
        if (currentGrouping == "plant")
        {
            return filtreredList
            .OrderBy(s => s.PlantName)
            .GroupBy(s => s.PlantName ?? "Ospecifierat");
        }
        if (currentGrouping == "date")
        {
            return filtreredList
            .OrderBy(s => s.SownDate)
            .GroupBy(s => s.SownDate.ToString("yyyy-MM-dd"));
        }
        return filtreredList
            .OrderByDescending(s => s.SownDate)
            .GroupBy(s => "");
    }

 
    /// <summary>
    /// Converts a numerical status code into its corresponding localized display text.
    /// </summary>
    /// <param name="status">The status code representing the plant's growth stage.</param>
    /// <returns>A string representation of the growth stage (e.g., Sowing, Sprout, True Leaves).</returns>
    private string GetStatusText(int status) => status switch
    {
        0 => "SÅDD",
        1 => "GRODD",
        2 => "KARAKTÄRSBLAD",
        3 => "OMSKOLNING",
        4 => "AVHÄRDNING",
        5 => "UTPLANTERAD",
        6 => "SKÖRDAD",
        7 => "AVSLUTAD",
        99 => "MISSLYCKAD",
        _ => "OKÄND"
    };
}

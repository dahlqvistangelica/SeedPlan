@page "/sowings"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IUserSowingService SowingService
@inject IJSRuntime JS

<PageTitle>Mina Sådder - SeedPlan</PageTitle>

<div class="sowings-container">
    <header class="sowings-header">
        <h1 class="serif-title">Mina Sådder</h1>
        
        @* GROUPCONTROLS *@
        <div class="group-controls">
            <div class="control-select">
            <select @bind="currentGrouping" class="group-select">
                <option value="none">Ingen gruppering</option>
                <option value="status">Gruppera efter såstatus</option>
                <option value="plant">Gruppera efter växtnamn</option>
                <option value="date">Gruppera efter sådatum</option>
            </select>
            </div>
            <div class="control-button">
                <button class="btn-add-sowing" title="Lägg till sådd" @onclick="OpenAddSowing">
                    <Blazicon Svg="Lucide.Sprout" />
                    <span>Ny sådd</span> @* HIDE on mobilescreen *@
                </button>
            </div>
        </div>
    </header>
    <AddSowingModal IsVisible="showAddModal"
                    OnClose="() => showAddModal = false"
                    OnSaved="LoadSowings" />

    @if (isLoading)
    {
        <div class="loading">Hämtar dina sådder...</div>
    }
    else if (!mySowings.Any())
    {
        <div class="empty-state">
            <p>Du har inga aktiva sådder just nu. 🌱</p>
        </div>
    }
    else
    {
        <div class="sowing-list">
            @foreach (var group in GetGroupedSowings())
            {
                @if (currentGrouping != "none")
                {
                    <h2 class="group-header">@group.Key</h2>
                }
                @foreach (var sowing in group)
                {
                    <div class="sowing-card fade-in">
                        <div class="card-header">
                            <div class="header-main">
                                <div class="icon-box hide-on-mobile">
                                   <Blazicon Svg="@GetStatusIcon(sowing.Status)"/>
                                </div>
                                <div class="title-area">
                                    <h3>
                                        @sowing.PlantName
                                        <span class="variety-name">(@(sowing.VarietyName ?? "Okänd sort"))</span>
                                    </h3>
                                    <p class="sown-date">
                                        <Blazicon Svg="Lucide.Calendar" />
                                        @* CCS-CLASS TO HIDE ON MOBILE *@
                                        <span class="hide-on-mobile">Sådd den </span>
                                        @(sowing.SownDate.ToString("yyyy-MM-dd"))
                                        <span class="sown-quantity">(@sowing.Quantity st)</span>
                                    </p>
                                </div>
                                
                            </div>
                            <div class="header-actions">
                                <span class="status-badge hide-on-mobile">@GetStatusText(sowing.Status)</span>
                                <button class="delete-btn" @onclick="() => HandleDelete(sowing.Id)">
                                    <Blazicon Svg="Lucide.Trash2" />
                                </button>
                            </div>
                            </div>
                            @* INTERACTIVE STATUSLINE *@
                            <div class="progress-container">
                                <div class="progress-line"></div>
                                <div class="progress-steps">
                                    <div class="step @(sowing.Status == 0 ? "active" : "")" @onclick="() => UpdateStatus(sowing, 0)"> @* SOWING *@
                                        <Blazicon Svg="MdiIcon.SeedOutline" />
                                    </div>
                                    <div class="step @(sowing.Status == 1 ? "active" : "")" @onclick="() => UpdateStatus(sowing, 1)"> @* SPROUT *@
                                       <Blazicon Svg="Lucide.Sprout" />
                                    </div>
                                    <div class="step @(sowing.Status == 2 ? "active" : "")" @onclick="() => UpdateStatus(sowing, 2)"> @*TRUE LEAVES*@
                                        <Blazicon Svg="Lucide.Leaf"/>
                                    </div>
                                    <div class="step @(sowing.Status == 4 ? "active" : "")" @onclick="() => UpdateStatus(sowing, 4)"> @*TRANSPLANTING*@
                                    <Blazicon Svg="MdiIcon.Shovel" />
                                    </div>
                                    <div class="step @(sowing.Status == 5 ? "active" : "")" @onclick="() => UpdateStatus(sowing, 5)"> @*HARDENING OFF*@
                                        <Blazicon Svg="MdiIcon.SunThermometerOutline"/>
                                    </div>
                                    <div class="step @(sowing.Status == 6 ? "active" : "")" @onclick="() => UpdateStatus(sowing, 6)"> @*PLANTED OUT*@
                                    <Blazicon Svg="MdiIcon.BeeFlower" />
                                    </div>
                                </div>
                            </div>

                            @* Statusboxes that shows up when alerted. *@
                            @if (sowing.Status == 0)
                            {
                                <div class="info-box">
                                    <Blazicon Svg="Lucide.Info" />
                                    <span>
                                    Sås på <strong>@(sowing.SowingDepth ?? 0) mm djup</strong>.
                                        @(sowing.IsLightGerminating == true ? $"{sowing.PlantName} är ljusgroende." : "")
                                    </span>
                                </div>
                            }
                            @if (sowing.Status == 2 && sowing.RequiresTopping == true)
                            {
                                <div class="info-box">
                                    <Blazicon Svg="Lucide.Info" />
                                    <span>
                                        @(sowing.PlantName ?? "Växten") bör toppas!
                                    </span>
                                </div>
                            }
                            @{var warning = SowingHelper.GetStaleWarning(sowing.Status, sowing.StatusUpdatedAt, sowing.SownDate);}
                            @if (warning.show)
                            {
                                <div class="warning-box">
                                    <Blazicon Svg="Lucide.TriangleAlert" />
                                    <span>@warning.message</span>
                                </div>
                            }
                        </div>
                    
                }
            }
        </div>
    }
</div>

@code {
    private List<SowingView> mySowings = new();
    private string currentGrouping = "none";
    private bool isLoading = true;
    private bool showAddModal = false;

    private void OpenAddSowing()
    {
        showAddModal = true;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadSowings();
    }

    private async Task LoadSowings()
    {
        isLoading = true;
        mySowings = await SowingService.GetMySowingViews();
        isLoading = false;

        StateHasChanged();
    }
    /// <summary>
    /// Groups the collection of sowings according to the current grouping criteria.
    /// </summary>
    /// <remarks>The grouping is determined by the value of the current grouping setting. If the
    /// grouping is by status, sowings are grouped by their status text. If by plant, sowings are grouped by plant
    /// name, with unspecified names grouped under "Ospecifierat". If by date, sowings are grouped by the sowing
    /// date in "yyyy-MM-dd" format. If no recognized grouping is set, all sowings are returned in a single
    /// group.</remarks>
    /// <returns>A sequence of groupings of sowings, where each group key represents the selected grouping criterion such as
    /// status, plant name, or sowing date.</returns>
    private IEnumerable<IGrouping<string, SowingView>> GetGroupedSowings()
    {
        if(currentGrouping == "status")
        {
            return mySowings
            .OrderBy(s => s.Status)
            .GroupBy(s => GetStatusText(s.Status));
        }
        if(currentGrouping == "plant")
        {
            return mySowings
            .OrderBy(s => s.PlantName)
            .GroupBy(s => s.PlantName ?? "Ospecifierat");
        }
        if(currentGrouping == "date")
        {
            return mySowings
            .OrderBy(s => s.SownDate)
            .GroupBy(s => s.SownDate.ToString("yyyy-MM-dd"));
        }
        return mySowings
            .OrderByDescending(s => s.SownDate)
            .GroupBy(s => "");
    }

    /// <summary>
    /// Converts a numerical status code into its corresponding localized display text.
    /// </summary>
    /// <param name="status">The status code representing the plant's growth stage.</param>
    /// <returns>A string representation of the growth stage (e.g., Sowing, Sprout, True Leaves).</returns>
    private string GetStatusText(int status) => status switch
    {
        0 => "SÅDD",
        1 => "GRODD",
        2 => "KARAKTÄRSBLAD",
        3 or 4 => "OMSKOLNING",
        5 => "AVHÄRDNING",
        6 => "UTPLANTERAD",
        _ => "AKTIV"
    };

    /// <summary>
    /// Retrieves the appropriate icon for a given status to be used in the UI.
    /// </summary>
    /// <param name="status">The status code for which to find an icon.</param>
    /// <returns>An SvgIcon representing the specific growth phase.</returns>

    private SvgIcon GetStatusIcon(int status) => status switch
    {
        0 => MdiIcon.SeedOutline,
        1 => Lucide.Sprout,
        2 => Lucide.Leaf,
        3 => MdiIcon.Shovel,
        5 => MdiIcon.SunClockOutline,
        6 => MdiIcon.BeeFlower,
        _ => Lucide.Sprout
    };
    /// <summary>
    /// Updates the status of a specific sowing record and persists the change via the service.
    /// </summary>
    /// <param name="sowing">The sowing view model to update.</param>
    /// <param name="newStatus">The new status code to assign.</param>
    /// <returns>A task representing the asynchronous update operation.</returns>

    private async Task UpdateStatus(SowingView sowing, int newStatus)
    {
        sowing.Status = newStatus;
        sowing.StatusUpdatedAt = DateTime.Now;
        await SowingService.UpdateSowingStatus(sowing.Id, newStatus);

        StateHasChanged();
    }


    /// <summary>
    /// Prompts the user for confirmation and deletes a sowing record if confirmed.
    /// </summary>
    /// <param name="id">The unique identifier of the sowing to delete.</param>
    /// <returns>A task representing the asynchronous delete operation.</returns>
    private async Task HandleDelete(int id)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Är du säker på att du vill ta bort den här sådden? Det går inte att ångra.");
        if (confirmed)
        {
            await SowingService.DeleteSowing(id);
            await LoadSowings();
        }
    }


}
@page "/dahlias"
@using Microsoft.AspNetCore.Authorization
@using System.Text.Json
@inject IDahliaService DahliaService
@inject IJSRuntime JS

<SeoHead Title="Dahlior - SeedPlan"
         Description="Hitta nya dahliasorter!"
         Keywords="fröer, fröinventering, frölager, odling, seedplan" />

  <div class="dahlia-container">
    <header class="dahlia-header">
        <h1 class="serif-title">Dahliavarianter</h1>
        <button class="filter-toggle @(showFilters ? "active" : "")" @onclick="ToggleFilters">
            <Blazicon Svg="Lucide.Funnel" />
        </button>
    </header>

    @* SEARCHFIELD *@
    <div class="search-section">
        <div class="search-wrapper">
            <input type="text" 
                @bind="searchText" 
               @bind:after="OnFilterChanged" 
               placeholder="Sök på namn..." 
               class="search-input" />
        </div>
    </div>

    @* FILTERPANEL *@
    @if (showFilters)
    {
        <div class="filter-panel fade-in">
            
            @* DAHLIATYP *@
            <div class="filter-accordion">
                <button class="accordion-toggle" @onclick="ToggleTypeExpanded">
                    <span class="accordion-title">DAHLIATYP @(activeTypes.Any() ? $"({activeTypes.Count})" : "")</span>
                    <div class="chevron">
                        @if (!isTypeExpanded)
                        {
                            <Blazicon Svg="Lucide.ChevronRight" />
                        }
                        else
                        {
                            <Blazicon Svg="Lucide.ChevronDown" />
                        }
                    </div>
                </button>
                
                @if (isTypeExpanded)
                {
                    <div class="accordion-content">
                        <label class="checkbox-label">
                            <input type="checkbox" checked="@(!activeTypes.Any())" @onchange="ClearTypes" />
                            <span>Alla typer</span>
                        </label>
                        @foreach (DahliaType type in Enum.GetValues(typeof(DahliaType)))
                        {
                            <label>
                                <input type="checkbox"
                                       checked="@activeTypes.Contains(type)"
                                       @onchange="@(e => ToggleType(type, (bool?)e.Value))" />
                                @GetTypeName(type)
                            </label>
                        }
                    </div>
                }
            </div>

            @* BLOMSTORLEK *@
            <div class="filter-accordion">
                <button class="accordion-toggle" @onclick="ToggleSizeExpanded">
                    <span class="accordion-title">BLOMSTORLEK @(activeSizes.Any() ? $"({activeSizes.Count})" : "")</span>
                    <div class="chevron">
                        @if (!isSizeExpanded)
                        {
                            <Blazicon Svg="Lucide.ChevronRight" />
                        }
                        else
                        {
                            <Blazicon Svg="Lucide.ChevronDown" />
                        }
                    </div>
                </button>
                
                @if (isSizeExpanded)
                {
                    <div class="accordion-content">
                        <label class="checkbox-label">
                            <input type="checkbox" checked="@(!activeSizes.Any())" @onchange="ClearSizes" />
                            <span>Alla storlekar</span>
                        </label>
                        @foreach (DahliaSize size in Enum.GetValues(typeof(DahliaSize)))
                        {
                                <label>
                                    <input type="checkbox"
                                           checked="@activeSizes.Contains(size)"
                                           @onchange="@(e => ToggleSize(size, (bool?)e.Value))" />
                                    @GetSizeName(size)
                                </label>
                        }
                    </div>
                }
            </div>

            @* FÄRG *@
            <div class="filter-accordion">
                <button class="accordion-toggle" @onclick="ToggleColorExpanded">
                    <span class="accordion-title">FÄRG @(activeColors.Any() ? $"({activeColors.Count})" : "")</span>
                    <div class="chevron">
                        @if (!isColorExpanded)
                        {
                            <Blazicon Svg="Lucide.ChevronRight" />
                        }
                        else
                        {
                            <Blazicon Svg="Lucide.ChevronDown" />
                        }
                    </div>
                </button>
                
                @if (isColorExpanded)
                {
                    <div class="accordion-content">
                        <label class="checkbox-label">
                            <input type="checkbox" checked="@(!activeColors.Any())" @onchange="ClearColors" />
                            <span>Alla färger</span>
                        </label>
                        @foreach (var color in availableColors)
                        {
                            <label class="checkbox-label">
                                <input type="checkbox" checked="@activeColors.Contains(color)" @onchange="(e => ToggleColor(color, (bool?)e.Value))" />
                                <span>@color</span>
                            </label>
                        }
                    </div>
                }
            </div>

            <div class="filter-group height-group">
                <label class="accordion-title">HÖJD</label>
                <div class="input-row">
                    <div class="input-block">
                        <label>Min (cm)</label>
                        <input type="number" @bind="minHeight" />
                    </div>
                    <div class="input-block">
                        <label>Max (cm)</label>
                        <input type="number" @bind="maxHeight" />
                    </div>
                </div>
            </div>
            <div class="filter-footer">
                <button class="reset-btn" @onclick="ResetFilters">NOLLSTÄLL FILTER</button>
        </div>
        </div>
    }

   


    <div class="group-content fade-in sp-gallery-grid" >
        @if (pagedDahlias == null)
        {
            <LoadingSpinner Text="Laddar dahlior.."/>
        }
        else if (!pagedDahlias.Any())
        {
            <p>Hittade inga dahlior som matchar dina filter.</p>
        }
        else
        {
            @foreach (var dahlia in pagedDahlias)
            {
                <DahliaCard Dahlia="dahlia"/>
            }
        }
    </div>

    @if (totalPages > 1)
    {
        <div class="pagination-controls" style="margin-top: 20px; display: flex; gap: 15px; align-items: center;">
            <button class="sp-btn" disabled="@(currentPage == 1)" @onclick="PreviousPage">⬅️ Föregående</button>
            
            <span>Sida <strong>@currentPage</strong> av <strong>@totalPages</strong> (@totalDahlias träffar totalt)</span>
            
            <button class="sp-btn" disabled="@(currentPage == totalPages)" @onclick="NextPage">Nästa ➡️</button>
        </div>
    }
    </div>

@code {
    //Pagination variables.
    private List<Dahlia> pagedDahlias;
    private int currentPage = 1;
    private int pageSize = 24;
    private int totalDahlias = 0;
    private int totalPages => (int)Math.Ceiling((double)totalDahlias / pageSize);


    //Filtervariables.
    private string searchText = "";
    private bool showFilters = false;
    private int? maxHeight = null;
    private int? minHeight = null;
    private CancellationTokenSource? _searchCts;
    private HashSet<DahliaType> activeTypes = new();
    private HashSet<DahliaSize> activeSizes = new();
    private bool isTypeExpanded = false;
    private bool isSizeExpanded = false;
    private bool isColorExpanded = false;
    private List<string> activeColors = new();
    private List<string> availableColors = new();

    private const string StorageKey = "dahlia_filters";

    protected override async Task OnInitializedAsync()
    {
        searchText = "";
        availableColors = await DahliaService.GetAvailableColorsAsync();
        await LoadDahliasPageAsync();
    }

    private async Task LoadDahliasPageAsync()
    {
        var result = await DahliaService.GetPagedDahliasAsync(currentPage, pageSize, searchText, activeTypes.ToList(), activeSizes.ToList(), activeColors.ToList(), maxHeight, minHeight);
        pagedDahlias = result.Dahlias;
        totalDahlias = result.TotalCount;
    }

    private void ToggleFilters() => showFilters = !showFilters;
    private void ToggleTypeExpanded() => isTypeExpanded = !isTypeExpanded;
    private void ToggleSizeExpanded() => isSizeExpanded = !isSizeExpanded;
    private void ToggleColorExpanded() => isColorExpanded = !isColorExpanded;

    private async Task ClearColors()
    {
        activeColors.Clear();
        StateHasChanged();
        await SaveFilters();
    }
    private async Task ClearTypes()
    {
        activeTypes.Clear();
        StateHasChanged();
        await SaveFilters();
    }
    private async Task ClearSizes()
    {
        activeSizes.Clear();
        StateHasChanged();
        await SaveFilters();
    }

    public void Dispose()
    {
        _searchCts?.Cancel();
        _searchCts?.Dispose();
        searchText = "";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if(firstRender)
        {
            try
            {
                
                
                await LoadFilters();
            }
            finally
            {
                StateHasChanged();
            }
        }
    }

    private async Task ResetFilters()
    {
        searchText = "";
        activeSizes.Clear();
        activeTypes.Clear();
        activeColors.Clear();
        minHeight = null;
        maxHeight = null;
        await JS.InvokeVoidAsync("localStorage.removeItem", StorageKey);
    }

    private async Task SaveFilters()
    {
        var filterData = new
        {
            SearchText = searchText,
            MinHeight = minHeight,
            MaxHeight = maxHeight,
            DahliaTypes = activeTypes.ToList(),
            DahliaSizes = activeSizes.ToList(),
            Colors = activeColors.ToList(),
        };

        var json = JsonSerializer.Serialize(filterData);
        await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, json);
    }

    private async Task LoadFilters()
    {
        var json = await JS.InvokeAsync<string>("localStorage.getItem", StorageKey);
        if (string.IsNullOrEmpty(json)) return;

        try
        {
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;
            if (root.TryGetProperty("SearchText", out var s)) searchText = s.GetString() ?? "";
            if (root.TryGetProperty("MinHeight", out var miH))
            {
                minHeight = miH.ValueKind == JsonValueKind.Null ? null : miH.GetInt32();
            }
            if (root.TryGetProperty("MaxHeight", out var maH))
            {
                maxHeight = maH.ValueKind == JsonValueKind.Null ? null : maH.GetInt32();
            }
            if (root.TryGetProperty("DahliaTypes", out var t) && t.ValueKind == JsonValueKind.Array)
            {
                activeTypes.Clear();
                foreach (var item in t.EnumerateArray())
                {
                    if (item.TryGetInt32(out int TypeInt))
                    {
                        activeTypes.Add((DahliaType)TypeInt);
                    }
                }

            }
            if (root.TryGetProperty("DahliaSizes", out var dS) && dS.ValueKind == JsonValueKind.Array)
            {
                activeSizes.Clear();
                foreach (var item in dS.EnumerateArray())
                {
                    if (item.TryGetInt32(out int SizeInt))
                    {
                        activeSizes.Add((DahliaSize)SizeInt);
                    }
                }

            }
            if (root.TryGetProperty("Colors", out var c) && c.ValueKind == JsonValueKind.Array)
            {
                activeColors.Clear();
                foreach (var item in c.EnumerateArray())
                {
                    var color = item.GetString();
                    if (!string.IsNullOrWhiteSpace(color))
                        activeColors.Add(color);
                }
            }
            StateHasChanged();
        }
        catch
        {

        }
    }

    public string GetTypeName(DahliaType type) => type switch
    {
        DahliaType.Decorative => "Dekorativ",
        DahliaType.DecorativeGiants => "Dekorativ Jätte",
        DahliaType.DecorativeDwarfs => "Dekorativ Dvärg",
        DahliaType.DecorativeSmall => "Dekorativ Liten",
        DahliaType.DecorativeLarge => "Dekorativ Stor",
        DahliaType.Anemone => "Anemon",
        DahliaType.Ball => "Boll",
        DahliaType.Cactus => "Kaktus",
        DahliaType.SemiCactus => "Semikaktus",
        DahliaType.DwarfCactus => "Dvärgkaktus",
        DahliaType.Pompon => "Pompon",
        DahliaType.Waterlily => "Näckros",
        DahliaType.Mignon => "Mignon",
        DahliaType.Collarette => "Halskrås",
        DahliaType.Exclusive => "Esklusiva",
        DahliaType.Fringed => "Fransade",
        DahliaType.Orchid => "Orkide",
        DahliaType.Other => "Övriga",
        DahliaType.Peony => "Pion",
        DahliaType.Single => "Enkla",
        DahliaType.Stellar => "Stellar",
        _ => "Okänd"
    };

    public string GetSizeName(DahliaSize size) => size switch
    {
        DahliaSize.Under5 => "5 <",
        DahliaSize.Size5to10 => "5 - 10",
        DahliaSize.Size10to15 => "10 - 15",
        DahliaSize.Size15to20 => "15 - 20",
        DahliaSize.Size20to25 => "20 - 25",
        DahliaSize.Over25 => "25 <",
        _ => "Okänd"
    };
    
    // TRIGGAS NÄR ETT FILTER ÄNDRAS
    private async Task OnFilterChanged()
    {
        // Viktigt: Om man är på sida 5 och byter filter, måste vi hoppa tillbaka till sida 1!
        currentPage = 1;
        await LoadDahliasPageAsync();
    }

    // --- Hjälpfunktioner för checkboxarna ---
    private async Task ToggleType(DahliaType type, bool? isChecked)
    {
        if (isChecked == true) activeTypes.Add(type);
        else activeTypes.Remove(type);
        
        await OnFilterChanged();
    }

    private async Task ToggleSize(DahliaSize size, bool? isChecked)
    {
        if (isChecked == true) activeSizes.Add(size);
        else activeSizes.Remove(size);
        
        await OnFilterChanged();
    }
    // --- Hjälpfunktioner för checkboxarna ---
    private async Task ToggleColor(string color, bool? isChecked)
    {
        if (isChecked == true) activeColors.Add(color);
        else activeColors.Remove(color);
        
        await OnFilterChanged();
    }
    // --- Paginering-knapparna ---
    private async Task NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            await LoadDahliasPageAsync();
            // Valfritt: Om du vill skrolla upp till toppen av sidan när de byter sida
        }
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadDahliasPageAsync();
        }
    }
    
}
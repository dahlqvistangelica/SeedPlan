@page "/om-oss"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]

<PageTitle>Om SeedPlan - Smart Trädgårdsplanering</PageTitle>
<SeoHead Title="Om SeedPlan - Din digitala trädgårdsassistent"
         Description="SeedPlan hjälper svenska odlare att planera sådd med smart kalender baserad på lokalt frostdatum. Gratis att använda."
         Keywords="om seedplan, trädgårdsapp, svensk odling, frostdatum, såddplanering" />

<div class="content-page">
    <h1>Om SeedPlan</h1>
    
    <article>
        <h2>Din digitala trädgårdsassistent</h2>
        <p>
            SeedPlan är en svensk webbapp skapad för att förenkla fröinventering och försådd.
            Med hjälp av ditt lokala frostdatum får du personliga rekommendationer
            om när du ska så dina fröer, när de kan skördas och hjälp att hålla ordning på alla dina pågående sådder.
        </p>
        
        <div class="section-header">
            <div class="star-icon">
                <Blazicon Svg="MdiIcon.StarCheck" />
            </div>
            <h2>Funktioner just nu</h2>
        </div>
        <ul>
            <li><strong>Personliga såförslag:</strong> Få rekommendationer baserat på ditt frostdatum.</li>
            <li><strong>Fröinventarie:</strong> Se lagersaldo, utgångsdatum och vad du har hemma.</li>
            <li><strong>Aktiva sådder:</strong> Följ utvecklingen från sådd till utplantering.</li>
            <li><strong>Växtguide:</strong> Hitta odlingsråd, härdighet och sådata för varje art.</li>
            <li><strong>Påminnelser:</strong> Få notiser när en sådd varit inaktiv för länge.</li>
            <li><strong>Bättre startsida:</strong> Välj vilka växttyper du vill få förslag på.</li>
        </ul>

        <div class="section-header">
            <div class="rocket-icon">
                <Blazicon Svg="MdiIcon.RocketLaunch" />
            </div>
            <h2>På gång</h2>
        </div>
        <ul>
            <li><strong>Rikare frökort:</strong> Fler detaljer som inköpsdatum och inköpsställe.</li>
            <li><strong>Bättre såddhantering:</strong> Möjlighet att ändra pågående sådder.</li>
            <li><strong>Tydligare sårekommendationer:</strong> Mer vägledning för vad som bör sås nu och snart.</li>
            <li><strong>Mer odlingsinsikter:</strong> Statistik som hjälper dig följa resultat över säsongen.</li>
            <li><strong>Odlingsråd:</strong> Odlingsråd från användarna.</li>
        </ul>
        
        <h2>Utvecklare</h2>
        <p>
            SeedPlan är helt gratis att använda och utvecklas av Angelica Dahlqvist. <br />
            Kontakt: <a href="mailto: info@SeedPlan.app">info@seedplan.app</a>
        </p>
    </article>
</div>
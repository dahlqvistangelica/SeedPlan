@using SeedPlan.Shared.Models
@inject IPlantLibraryService PlantService
@inject IUserInventoryService SeedService
@inject IJSRuntime JS

@if (IsVisible)
{
    <div class="sp-modal-body">
        <div class="sp-form-content">
        
            <div class="sp-input-block">
                <label>VÄXTNAMN</label>
                <div class="sp-readonly-box">
                    @selectedPlant?.PlantName
                    <span class="sp-change-link" @onclick="ChangePlant">Byt</span>
                </div>
            </div>

            <div class="sp-input-block">
                <label>SORT / NAMN</label>
                <input type="text" @bind="newSeed.Name" class="sp-input" placeholder="T.ex. katz purple" />
            </div>

            <div class="sp-grid-2">
                <div class="sp-input-block">
                    <label>ANTAL FRÖER</label> @* ÄNDRAT FRÅN PÅSAR TILL FRÖER *@
                    <div class="qty-wrapper">
                        <input type="text" @bind="newSeed.Quantity" class="sp-input" />
                        <span class="unit-tag">st</span>
                    </div>
                </div>
                <div class="sp-input-block">
                    <label>UTGÅNGSDATUM</label>
                    <input type="date" @bind="newSeed.ExpiryDate" class="sp-input" />
                </div>
            </div>

            <button class="sp-save-btn" @onclick="Save">Spara frö</button>
            <button class="sp-cancel-btn" @onclick="Close">Avbryt</button>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private string searchText = "";
    private List<Plant> allPlants = new();
    private List<Variety> allVarieties = new();
    private Plant? selectedPlant;
    private Seed newSeed = new() { ExpiryDate = DateTime.Now.AddYears(2) };

    protected override async Task OnInitializedAsync()
    {
        allPlants = await PlantService.GetAllPlantsAsync();
        allVarieties = await PlantService.GetAllVarietiesAsync();
    }

    private IEnumerable<SearchResult> GetSearchResults()
    {
        if (string.IsNullOrWhiteSpace(searchText)) return Enumerable.Empty<SearchResult>();
        var term = searchText.ToLower();

        var plantMatches = allPlants.Where(p => p.PlantName.ToLower().Contains(term))
            .Select(p => new SearchResult { Plant = p, DisplayName = p.PlantName });

        var varietyMatches = allVarieties.Where(v => v.VarietyName.ToLower().Contains(term))
            .Select(v => {
                var p = allPlants.FirstOrDefault(x => x.Id == v.PlantId);
                return new SearchResult { Plant = p, Variety = v, DisplayName = $"{v.VarietyName} ({p?.PlantName})" };
            });

        return plantMatches.Concat(varietyMatches).Take(5);
    }

    private void SelectResult(SearchResult res)
    {
        selectedPlant = res.Plant;
        newSeed.PlantId = res.Plant?.Id ?? 0;
        newSeed.Name = res.Variety?.VarietyName ?? "";
        searchText = "";
    }

    private async Task Save()
    {
        await SeedService.AddSeed(newSeed);
        newSeed = new() { ExpiryDate = DateTime.Now.AddYears(2) };
        selectedPlant = null;
        await OnSaved.InvokeAsync();
        Close();
    }

    private void Close() => OnClose.InvokeAsync();

    public class SearchResult {
        public Plant? Plant { get; set; }
        public Variety? Variety { get; set; }
        public string DisplayName { get; set; } = "";
    }
    private void ChangePlant()
    {
        selectedPlant = null;
        newSeed.PlantId = 0;
        newSeed.Name = "";
        searchText = "";
    }
}
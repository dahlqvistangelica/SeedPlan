@using SeedPlan.Shared.Models
@inject IPlantLibraryService PlantService
@inject IUserInventoryService SeedService
@inject IJSRuntime JS

@if (IsVisible)
{
    <div class="sp-modal-overlay" @onclick="Close">
        <div class="sp-modal-card fade-in" @onclick:stopPropagation>
            <header class="sp-modal-header">
                <h2>Lägg till frö <span><Blazicon Svg="MdiIcon.Seed" /></span></h2>
            </header>

            <div class="sp-modal-body">
                <div class="sp-form-content">
                    @* 1. PLANTNAME *@
                    <div class="sp-input-block">
                        <label>VÄXTNAMN</label>
                        @if (selectedPlant == null)
                        {
                            <input type="text" @bind="searchText" @bind:event="oninput"
                                   placeholder="T.ex. Lejongap" class="sp-input" />
                            @if (!string.IsNullOrEmpty(searchText))
                            {
                                <div class="sp-dropdown">
                                    @foreach (var result in GetSearchResults())
                                    {
                                        <div class="sp-dropdown-item" @onclick="() => SelectResult(result)">
                                            <span>@result.DisplayName</span>
                                        </div>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <div class="sp-readonly-box">
                                <span>@selectedPlant.PlantName</span>
                                <span class="sp-change-link" @onclick="ChangePlant">Byt</span>
                            </div>
                        }
                    </div>

                    @* 2. PLANTKIND/NAME - WITH SEARCHFUNCTION *@
                    <div class="sp-input-block">
                        <label>SORT / NAMN</label>
                        <input type="text" @bind="newSeed.VarietyName" @bind:event="oninput"
                               placeholder="T.ex. Katz Purple" class="sp-input" />
                        
                        @if (selectedPlant != null && !string.IsNullOrEmpty(newSeed.Name) && !isVarietySelected)
                        {
                            var varietySuggestions = allVarieties
                                .Where(v => v.PlantId == selectedPlant.Id &&
                                           v.VarietyName.Contains(newSeed.VarietyName, StringComparison.OrdinalIgnoreCase))
                                .Take(5);

                            @if (varietySuggestions.Any())
                            {
                                <div class="sp-dropdown">
                                    @foreach (var v in varietySuggestions)
                                    {
                                        <div class="sp-dropdown-item" @onclick="() => SelectVariety(v)">
                                            <span>@v.VarietyName</span>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>

                    @* QUANTITY, EXPIRYDATE, NOTES *@
                    <div class="sp-grid-2">
                        <div class="sp-input-block">
                            <label>ANTAL FRÖER</label>
                            <div class="qty-wrapper">
                                <input type="number" @bind="newSeed.Quantity" class="sp-input" />
                                <span class="unit-tag">st</span>
                            </div>
                        </div>
                        <div class="sp-input-block">
                            <label>UTGÅNGSDATUM</label>
                            <input type="date" @bind="newSeed.ExpiryDate" class="sp-input" />
                        </div>
                    </div>

                    <div class="sp-input-block">
                        <label>ANTECKNINGAR</label>
                        <textarea @bind="newSeed.Notes" class="sp-textarea" placeholder="Färg, smak, etc."></textarea>
                    </div>
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <p class="error-msg" style="color: red; text-align: center;">@errorMessage</p>
                    }
                    <button type="button" class="sp-save-btn" @onclick="Save">Spara frö</button>
                    <button type="button" class="sp-cancel-btn" @onclick="Close">Avbryt</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private string searchText = "";
    private bool isVarietySelected = false;
    private List<Plant> allPlants = new();
    private List<Variety> allVarieties = new();
    private Plant? selectedPlant;
    private Seed newSeed = new() { ExpiryDate = DateTime.Now.AddYears(2) };
    private string errorMessage = "";

    protected override async Task OnParametersSetAsync()
    {
        await Task.Delay(50);

    }

    protected override async Task OnInitializedAsync()
    {
        allPlants = await PlantService.GetAllPlantsAsync();
        allVarieties = await PlantService.GetAllVarietiesAsync();
    }

    private IEnumerable<SearchResult> GetSearchResults()
    {
        if (string.IsNullOrWhiteSpace(searchText)) return Enumerable.Empty<SearchResult>();
        var term = searchText.ToLower();
        return allPlants.Where(p => p.PlantName.ToLower().Contains(term))
            .Select(p => new SearchResult { Plant = p, DisplayName = p.PlantName }).Take(5);
    }

    private void SelectResult(SearchResult res)
    {
        selectedPlant = res.Plant;
        newSeed.PlantId = res.Plant?.Id;

        newSeed.Name = res.Plant?.PlantName ?? "";
        searchText = "";
        isVarietySelected = res.Variety != null;
        if(isVarietySelected)
        {
            newSeed.VarietyId = res.Variety?.Id;
            newSeed.VarietyName = res.Variety?.VarietyName ?? "";
        }
    }

    private void SelectVariety(Variety v)
    {
        newSeed.VarietyName = v.VarietyName;
        newSeed.VarietyId = v.Id;
        isVarietySelected = true;
    }

    private void ChangePlant()
    {
        selectedPlant = null;
        newSeed.PlantId = 0;
        newSeed.Name = "";
        newSeed.VarietyName = "";
        newSeed.VarietyId = null;
        isVarietySelected = false;
    }

    private async Task Save()
    {
        try
        {
            errorMessage = "";
            if (selectedPlant == null)
            {
                await JS.InvokeVoidAsync("alert", "Du måste välja en växt i listan först.");
                return;
            }
            if(newSeed.Quantity <= 0)
            {
                await JS.InvokeVoidAsync("alert", "Antalet fröer kan inte vara under 0.");
                return;
            }
            if(!string.IsNullOrWhiteSpace(newSeed.VarietyName))
            {
                newSeed.VarietyName = newSeed.VarietyName.Trim();

                // Make sure that variant name can't be less than 3 letters.
                if (newSeed.VarietyName.Count(char.IsLetter) < 3)
                {
                    await JS.InvokeVoidAsync("alert", "Namnet på sorten måste innehålla minst tre bokstäver.");
                    return;
                }
            }
            if (selectedPlant != null && !isVarietySelected && !string.IsNullOrWhiteSpace(newSeed.VarietyName))
            {
                var existingVariety = allVarieties.FirstOrDefault(v => v.PlantId == selectedPlant.Id && v.VarietyName.Equals(newSeed.VarietyName, StringComparison.OrdinalIgnoreCase));

                if (existingVariety == null)
                {
                    var newVarietyObj = new Variety
                        {
                            PlantId = selectedPlant.Id,
                            VarietyName = newSeed.VarietyName
                        };

                    var savedVariety = await PlantService.AddVarietyAsync(newVarietyObj);
                    newSeed.VarietyId = savedVariety.Id;

                    // Lägg till denna rad för att kontrollera:
                    await JS.InvokeVoidAsync("console.log", $"Steg 2 klar! Nytt VarietyId: {savedVariety.Id}");

                    allVarieties.Add(savedVariety);
                }
                else
                {
                    newSeed.VarietyId = existingVariety.Id;
                }
            }

            await SeedService.AddSeed(newSeed);
            newSeed = new() { ExpiryDate = DateTime.Now.AddYears(2) };
            selectedPlant = null;
            searchText = "";
            isVarietySelected = false;

            await OnSaved.InvokeAsync();
            Close();
        }
        catch(Exception ex)
        {
            errorMessage = ex.Message;
            await JS.InvokeVoidAsync("console.error", "Kunde inte spara:", ex.Message);
        }
    }

    private void Close() => OnClose.InvokeAsync();

    public class SearchResult
    {
        public Plant? Plant { get; set; }
        public Variety? Variety { get; set; }
        public string DisplayName { get; set; } = "";
    }
}
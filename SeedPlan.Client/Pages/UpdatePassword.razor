@page "/update-password"
@inject Supabase.Client Supabase
@inject NavigationManager Nav

<div class="auth-container">
    <div class="card-box" style="max-width: 400px; margin: 0 auto; padding: 2rem;">
        <h2 class="serif-title">Skapa nytt lösenord</h2>

        @if (!isAuthorizedToReset && string.IsNullOrEmpty(errorMessage))
        {
            <p>Laddar säkerhetskontroll...</p>
        }
        else if (!isAuthorizedToReset && !string.IsNullOrEmpty(errorMessage))
        {
            <div style="color: red; margin-bottom: 1rem;">@errorMessage</div>
        }
        else if (isSuccess)
        {
            <div class="success-message" style="color: green; font-weight: bold; margin-bottom: 1rem;">
                Ditt lösenord har uppdaterats! Du loggas nu in...
            </div>
        }
        else
        {
            <div class="input-block">
                <label>Nytt lösenord (Minst 6 tecken)</label>
                <input type="@(showPassword ? "text" : "password")" @bind="newPassword" @bind:event="oninput" class="sp-input" />
            </div>

            <div class="input-block" style="margin-top: 1rem;">
                <label>Bekräfta nytt lösenord</label>
                <input type="@(showPassword ? "text" : "password")" @bind="confirmPassword" @bind:event="oninput" class="sp-input" />
            </div>

            <div style="margin-top: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
                <input type="checkbox" id="show-pwd" @bind="showPassword" style="cursor: pointer;" />
                <label for="show-pwd" style="font-size: 0.9rem; cursor: pointer; color: var(--text-muted);">Visa lösenord</label>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div style="color: red; margin-top: 1rem; font-size: 0.9rem;">@errorMessage</div>
            }

            <button class="btn-primary" style="width: 100%; margin-top: 1.5rem;" @onclick="SaveNewPassword" disabled="@isLoading">
                @(isLoading ? "Sparar..." : "Spara lösenord")
            </button>
        }
    </div>
</div>

@code {
    private string newPassword = "";
    private string confirmPassword = "";
    private string errorMessage = "";
    
    private bool isLoading = false;
    private bool isSuccess = false;
    private bool isAuthorizedToReset = false;
    private bool showPassword = false; // Styr synligheten på lösenordet

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var currentUri = new Uri(Nav.Uri);
            var session = await Supabase.Auth.GetSessionFromUrl(currentUri);
            
            if (session != null && session.User != null)
            {
                isAuthorizedToReset = true;
            }
            else
            {
                errorMessage = "Länken är ogiltig eller har gått ut. Vänligen begär en ny.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Kunde inte läsa länken. Vänligen begär en ny.";
            Console.WriteLine(ex.Message);
        }
    }

    private async Task SaveNewPassword()
    {
        
        errorMessage = "";

        
        if (newPassword.Length < 8)
        {
            errorMessage = "Lösenordet måste vara minst 6 tecken långt.";
            return;
        }

        
        if (newPassword != confirmPassword)
        {
            errorMessage = "Lösenorden matchar inte varandra.";
            return;
        }

        isLoading = true;

        try
        {
            var attrs = new Supabase.Gotrue.UserAttributes { Password = newPassword };
            await Supabase.Auth.Update(attrs);
            
            isSuccess = true;
            
            await Task.Delay(2000);
            Nav.NavigateTo("/"); 
        }
        catch (Exception ex)
        {
            
            errorMessage = ParseSupabaseError(ex.Message);
            Console.WriteLine("Supabase Error: " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    
    private string ParseSupabaseError(string originalError)
    {
        
        if (originalError.Contains("New password should be different from the old password", StringComparison.OrdinalIgnoreCase) ||
            originalError.Contains("same as the old", StringComparison.OrdinalIgnoreCase))
        {
            return "Det nya lösenordet får inte vara samma som ditt gamla lösenord.";
        }
        
        if (originalError.Contains("Password should be at least", StringComparison.OrdinalIgnoreCase))
        {
            return "Lösenordet uppfyller inte säkerhetskraven (för kort).";
        }

        
        return $"Ett fel uppstod: {originalError}";
    }
}
    private void ApplyPreset(CultivationArea area, int w, int l)
    {
        area.WidthCm = w;
        area.LengthCm = l;
    }

    private int GetFillPercent(CultivationArea area)
    {
        if (area.Crops.Count == 0) return 0;
        double usedCm2 = area.Crops.Sum(c =>
        {
            double r = (c.Plant.PlantSpacing ?? 20) / 2.0;
            return Math.PI * r * r;
        });
        double totalCm2 = area.WidthCm * area.LengthCm;
        return Math.Min(100, (int)(usedCm2 / totalCm2 * 100));
    }

    // ── Plant search ───────────────────────────────────────────────────────────
    private async Task HandleSearch()
    {
        if (searchQuery.Length > 1)
            searchResults = await PlantLibrary.SearchPlantsAsync(searchQuery);
        else
            searchResults.Clear();
    }

    private void SelectPlant(Plant plant)
    {
        pendingPlant = plant;
        pendingQty = 1;
        searchQuery = string.Empty;
        searchResults.Clear();
    }

    private void SelectPlantFromSowing(Plant plant, int maxQty)
    {
        pendingPlant = plant;
        pendingQty = maxQty;
        searchResults.Clear();
    }

    private void AddPendingToArea()
    {
        if (pendingPlant == null || selectedArea == null) return;
        var spacing = pendingPlant.PlantSpacing ?? 20;
        for (int i = 0; i < pendingQty; i++)
        {
            var pos = FindFreePosition(selectedArea, spacing);
            if (!pos.HasValue) break;
            selectedArea.Crops.Add(new PlantedCrop { Plant = pendingPlant, CenterX = pos.Value.x, CenterY = pos.Value.y });
        }
        pendingPlant = null;
        pendingQty = 1;
    }

    private void AddPlantToArea(Plant plant, CultivationArea area)
    {
        var spacing = plant.PlantSpacing ?? 20;
        var pos = FindFreePosition(area, spacing);
        if (pos.HasValue)
        {
            area.Crops.Add(new PlantedCrop { Plant = plant, CenterX = pos.Value.x, CenterY = pos.Value.y });
        }
        searchQuery = string.Empty;
        searchResults.Clear();
    }

    private void AutoFill(CultivationArea area)
    {
        var existing = area.Crops.GroupBy(c => c.Plant.Id)
            .ToDictionary(g => g.Key, g => (plant: g.First().Plant, count: g.Count()));
        area.Crops.Clear();

        foreach (var (_, info) in existing)
        {
            int spacing = info.plant.PlantSpacing ?? 20;
            for (int i = 0; i < info.count; i++)
            {
                var pos = FindFreePosition(area, spacing);
                if (!pos.HasValue) break;
                area.Crops.Add(new PlantedCrop
                {
                    Plant = info.plant,
                    CenterX = pos.Value.x,
                    CenterY = pos.Value.y
                });
            }
        }
    }

    private (double x, double y)? FindFreePosition(CultivationArea area, int spacing)
    {
        double half = spacing / 2.0;
        double step = Math.Max(1.0, spacing / 2.0);

        for (double y = half; y <= area.LengthCm - half; y += step)
            for (double x = half; x <= area.WidthCm - half; x += step)
                if (!area.Crops.Any(c =>
                {
                    double minD = ((c.Plant.PlantSpacing ?? 20) + spacing) / 2.0;
                    double dx = c.CenterX - x, dy = c.CenterY - y;
                    return Math.Sqrt(dx * dx + dy * dy) < minD;
                }))
                    return (x, y);
        return null;
    }

    // ── Drag & drop (cross-area) ───────────────────────────────────────────────
    private void StartDrag(PlantedCrop crop, CultivationArea sourceArea, PointerEventArgs e)
    {
        draggedCrop = crop;
        dragSourceArea = sourceArea;
        dragTargetArea = sourceArea;
        int spacing = crop.Plant.PlantSpacing ?? 20;
        double dPx = spacing * Scale;
        dragOffsetX = e.ClientX - (crop.CenterX * Scale - dPx / 2);
        dragOffsetY = e.ClientY - (crop.CenterY * Scale - dPx / 2);
        lastPointerX = e.ClientX;
        lastPointerY = e.ClientY;
    }

    private void OnBedEnter(CultivationArea area)
    {
        if (draggedCrop == null) return;
        dragTargetArea = area;
        StateHasChanged();
    }

    private void OnBedLeave(CultivationArea area)
    {
        if (draggedCrop == null) return;
        if (dragTargetArea == area)
        {
            dragTargetArea = dragSourceArea;
            StateHasChanged();
        }
    }

    private void HandlePointerMove(PointerEventArgs e)
    {
        if (draggedCrop == null) return;
        lastPointerX = e.ClientX;
        lastPointerY = e.ClientY;

        // Always move within source area — cross-area transfer happens on pointer up
        var area = dragSourceArea!;
        int spacing = draggedCrop.Plant.PlantSpacing ?? 20;
        double dPx = spacing * Scale;
        double half = spacing / 2.0;
        double newX = Math.Clamp((e.ClientX - dragOffsetX + dPx / 2) / Scale, half, area.WidthCm - half);
        double newY = Math.Clamp((e.ClientY - dragOffsetY + dPx / 2) / Scale, half, area.LengthCm - half);

        draggedCrop.CenterX = newX;
        draggedCrop.CenterY = newY;
        StateHasChanged();
    }

    private void HandlePointerUp(PointerEventArgs e)
    {
        if (draggedCrop == null) return;

        if (dragTargetArea != null && dragTargetArea != dragSourceArea)
        {
            var spacing = draggedCrop.Plant.PlantSpacing ?? 20;
            var pos = FindFreePosition(dragTargetArea, spacing);
            if (pos.HasValue)
            {
                // Move crop to new area only if there is room — avoids placing
                // the crop at source-area coordinates inside the target bed,
                // which could make it land off-canvas and impossible to grab.
                dragSourceArea!.Crops.Remove(draggedCrop);
                draggedCrop.CenterX = pos.Value.x;
                draggedCrop.CenterY = pos.Value.y;
                dragTargetArea.Crops.Add(draggedCrop);
            }
        }

        draggedCrop = null;
        dragSourceArea = null;
        dragTargetArea = null;
        StateHasChanged();
    }

    private bool IsOverlapping(PlantedCrop moved, CultivationArea area, double x, double y)
    {
        foreach (var other in area.Crops)
        {
            if (other.Id == moved.Id) continue;
            double minD = ((moved.Plant.PlantSpacing ?? 20) + (other.Plant.PlantSpacing ?? 20)) / 2.0;
            double dx = other.CenterX - x, dy = other.CenterY - y;
            if (Math.Sqrt(dx * dx + dy * dy) < minD) return true;
        }
        return false;
    }

    // ── Count mode ─────────────────────────────────────────────────────────────
    private int GetPlantCountInGarden(Plant plant) =>
        activeGarden?.Areas.Sum(a => a.Crops.Count(c => c.Plant.Id == plant.Id)) ?? 0;

    private async Task ToggleSowingPanel()
    {
        if (showSowingPanel) { showSowingPanel = false; return; }
        await LoadSowingPlants();
        showSowingPanel = true;
    }

    private async Task LoadSowingPlants()
    {
        isImporting = true;
        StateHasChanged();
        try
        {
            var sowings = await SowingService.GetMySowingViews();
            sowingPlants = sowings
                .GroupBy(s => s.PlantName?.Trim(), StringComparer.OrdinalIgnoreCase)
                .Where(g => !string.IsNullOrEmpty(g.Key))
                .Select(g =>
                {
                    var plant = plantLibrary.FirstOrDefault(p =>
                        string.Equals(p.PlantName, g.Key, StringComparison.OrdinalIgnoreCase));
                    return (Plant: plant, Quantity: g.Sum(s => s.Quantity ?? 1));
                })
                .Where(x => x.Plant != null)
                .Select(x => (x.Plant!, x.Quantity))
                .ToList();
        }
        finally
        {
            isImporting = false;
            StateHasChanged();
        }
    }

    private async Task ImportFromSowings()
    {
        await LoadSowingPlants();
        foreach (var (plant, qty) in sowingPlants)
        {
            var existing = countRows.FirstOrDefault(r => r.Plant.Id == plant.Id);
            if (existing != null)
                existing.Quantity += qty;
            else
                countRows.Add(new CountRow { Plant = plant, Quantity = qty });
        }
        StateHasChanged();
    }

    private void AddToCountList(Plant plant)
    {
        if (!countRows.Any(r => r.Plant.Id == plant.Id))
            countRows.Add(new CountRow { Plant = plant, Quantity = 1 });
        searchQuery = string.Empty;
        searchResults.Clear();
    }

    private void RemoveCountRow(CountRow row) => countRows.Remove(row);
    private void RecalcCount() => StateHasChanged();

    private void BuildGardenFromCount()
    {
        // Pick standard pallkrage as the default bed type
        int bedW = 80, bedL = 120;
        double bedCm2 = bedW * bedL;

        // Distribute plants across beds greedily
        activeGarden!.Areas.Clear();
        var remaining = countRows
            .Where(r => r.Quantity > 0)
            .Select(r => (plant: r.Plant, left: r.Quantity))
            .ToList();

        int bedIndex = 0;
        while (remaining.Any(r => r.left > 0))
        {
            bedIndex++;
            var area = new CultivationArea
            {
                Name = $"Pallkrage {bedIndex}",
                WidthCm = bedW,
                LengthCm = bedL,
                Color = AreaColors[(bedIndex - 1) % AreaColors.Length],
                GardenId = activeGarden.Id,
                SortOrder = bedIndex - 1
            };

            double x = 0, y = 0, rowH = 0;
            for (int i = 0; i < remaining.Count; i++)
            {
                var (plant, left) = remaining[i];
                int spacing = plant.PlantSpacing ?? 20;
                while (left > 0)
                {
                    if (x + spacing > bedW) { x = 0; y += rowH; rowH = 0; }
                    if (y + spacing > bedL) break; // bottom edge outside bed
                    area.Crops.Add(new PlantedCrop
                    {
                        Plant = plant,
                        CenterX = x + spacing / 2.0,
                        CenterY = y + spacing / 2.0
                    });
                    x += spacing;
                    if (spacing > rowH) rowH = spacing;
                    left--;
                }
                remaining[i] = (plant, left);
            }

            if (!area.Crops.Any()) break; // safety: nothing fits
            activeGarden.Areas.Add(area);
        }

        selectedArea = activeGarden.Areas.FirstOrDefault();
        plannerMode = PlannerMode.ByArea;
    }

    // ── Save / Delete ──────────────────────────────────────────────────────────
    private async Task SaveGarden()
    {
        if (userId == null || activeGarden == null) return;
        isSaving = true;
        saveMessage = null;
        StateHasChanged();
        try
        {
            await PlanService.SaveFullGardenAsync(activeGarden, userId);
            gardens = await PlanService.GetUserGardensAsync(userId);
            saveMessage = "Sparat!";
        }
        catch
        {
            saveMessage = "Fel vid sparning.";
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
            // Clear message after 3 s
            await Task.Delay(3000);
            saveMessage = null;
            StateHasChanged();
        }
    }

    private void ConfirmDeleteGarden(Garden g) { gardenToDelete = g; showDeleteConfirm = true; }

    private async Task DeleteGarden()
    {
        if (gardenToDelete == null) return;
        await PlanService.DeleteGardenAsync(gardenToDelete.Id);
        gardens.Remove(gardenToDelete);
        gardenToDelete = null;
        showDeleteConfirm = false;
    }


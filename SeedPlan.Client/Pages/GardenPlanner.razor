@page "/planner"
@layout PlannerLayout
@using SeedPlan.Shared.Models
@using SeedPlan.Client.Layout
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider
@inject IPlantLibraryService PlantLibrary
@inject IUserSowingService SowingService
@inject GardenPlanService PlanService
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

@if (showMobileWarning)
{
    <div class="modal-backdrop" @onclick="DismissMobileWarning">
        <div class="modal-card" @onclick:stopPropagation="true">
            <h3>Bäst på större skärm</h3>
            <p>Trädgårdsplaneraren är utformad för surfplatta eller dator. På mobilskärmar kan det vara svårt att dra och placera växter med precision.</p>
            <div class="modal-actions">
                <button class="btn-secondary" @onclick="DismissMobileWarning">Fortsätt ändå</button>
            </div>
        </div>
    </div>
}

@if (isLoading)
{
    <div class="planner-loading">
        <div class="spinner"></div>
        <p>Laddar planeraren…</p>
    </div>
}
else if (activeGarden == null)
{
    <!-- ══════════════════════════════════════════════════════════
         GARDEN LIST / START SCREEN
    ══════════════════════════════════════════════════════════════ -->
    <div class="planner-start">
        <div class="start-header">
            <img src="small-logo.webp" width="36" height="36" alt="SeedPlan" />
            <h1 class="serif-title">Trädgårdsplanerare</h1>
        </div>

        @if (userId != null)
        {
            <!-- Saved gardens -->
            @if (gardens.Any())
            {
                <section class="garden-list">
                    <h2>Dina planeringar</h2>
                    @foreach (var g in gardens)
                    {
                        <div class="garden-card" @onclick="() => OpenGarden(g)">
                            <div class="garden-card-info">
                                <strong>@g.Name</strong>
                                <span>@g.Year · @g.Areas.Count @(g.Areas.Count != 1 ? "ytor" : "yta")</span>
                            </div>
                            <button class="btn-icon danger" @onclick:stopPropagation="true"
                                    @onclick="() => ConfirmDeleteGarden(g)">
                                <Blazicon Svg="Lucide.Trash2" />
                            </button>
                        </div>
                    }
                </section>
            }

            <button class="btn-primary" @onclick="StartNewGarden">
                <Blazicon Svg="Lucide.Plus" /> Ny planering
            </button>
        }
        else
        {
            <div class="guest-banner">
                <p>Du är inte inloggad. Du kan använda planeraren fritt, men måste logga in för att spara.</p>
                <a href="/" target="_blank" rel="noopener" class="btn-primary" style="text-decoration:none;">Logga in</a>
                <button class="btn-secondary" @onclick="StartNewGarden">Fortsätt utan att spara</button>
            </div>
        }
    </div>

    @if (showDeleteConfirm && gardenToDelete != null)
    {
        <div class="modal-backdrop" @onclick="() => showDeleteConfirm = false">
            <div class="modal-card" @onclick:stopPropagation="true">
                <h3>Ta bort planering?</h3>
                <p>«@gardenToDelete.Name» och alla dess ytor raderas permanent.</p>
                <div class="modal-actions">
                    <button class="btn-secondary" @onclick="() => showDeleteConfirm = false">Avbryt</button>
                    <button class="btn-danger" @onclick="DeleteGarden">Ta bort</button>
                </div>
            </div>
        </div>
    }
}
else if (plannerMode == PlannerMode.ModeSelect)
{
    <!-- ══════════════════════════════════════════════════════════
         MODE SELECTION
    ══════════════════════════════════════════════════════════════ -->
    <div class="mode-select">
        <button class="btn-icon back-btn" @onclick="BackToStart"><Blazicon Svg="Lucide.ArrowLeft" /></button>
        <h2 class="serif-title">Hur vill du planera?</h2>

        <div class="mode-cards">
            <div class="mode-card" @onclick="() => StartMode(PlannerMode.ByArea)">
                <Blazicon Svg="MdiIcon.FloorPlan" />
                <h3>Efter yta</h3>
                <p>Skapa dina planteringsytor (pallkragar, friland) och placera ut växter visuellt med drag-och-släpp.</p>
            </div>
            <div class="mode-card" @onclick="() => StartMode(PlannerMode.ByCount)">
                <Blazicon Svg="Lucide.Calculator" />
                <h3>Efter antal växter</h3>
                <p>Ange vilka växter och hur många du vill odla — planeraren beräknar hur mycket yta du behöver.</p>
            </div>
        </div>
    </div>
}
else if (plannerMode == PlannerMode.ByCount)
{
    <!-- ══════════════════════════════════════════════════════════
         PLANT COUNT CALCULATOR
    ══════════════════════════════════════════════════════════════ -->
    <div class="planner-count">
        <div class="count-header">
            <button class="btn-icon back-btn" @onclick="() => plannerMode = PlannerMode.ModeSelect"><Blazicon Svg="Lucide.ArrowLeft" /></button>
            <h2 class="serif-title">Beräkna ytbehov</h2>
        </div>

        <!-- Import from sowings -->
        @if (userId != null)
        {
            <button class="btn-import-sowings" @onclick="ImportFromSowings" disabled="@isImporting">
                @if (isImporting)
                {
                    <span class="spinner-sm"></span><span>Hämtar…</span>
                }
                else
                {
                    <Blazicon Svg="Lucide.Download" /><span>Hämta från mina sådder</span>
                }
            </button>
        }

        <!-- Plant search + add row -->
        <div class="count-search" style="position:relative;">
            <input class="form-input" placeholder="Sök växt att lägga till…"
                   value="@searchQuery" @oninput="OnSearchInput" />
            @if (searchResults.Any())
            {
                <div class="dropdown">
                    @foreach (var p in searchResults)
                    {
                        <div class="dropdown-item" @onclick="() => AddToCountList(p)">
                            <strong>@p.PlantName</strong>
                            <span>@p.PlantSpacing cm</span>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Plant/count rows -->
        @if (countRows.Any())
        {
            <div class="count-rows">
                @foreach (var row in countRows)
                {
                    <div class="count-row">
                        <span class="color-dot" style="background:@GetColor(row.Plant.Id)"></span>
                        <span class="count-plant-name">@row.Plant.PlantName</span>
                        <span class="count-spacing">(@row.Plant.PlantSpacing cm)</span>
                        <input type="number" class="form-input count-qty" min="1"
                               @bind="row.Quantity" @oninput="RecalcCount" />
                        <button class="btn-icon" @onclick="() => RemoveCountRow(row)"><Blazicon Svg="Lucide.X" /></button>
                    </div>
                }
            </div>

            <!-- Calculation result -->
            <div class="count-result">
                <h3>Ytbehov</h3>
                <div class="result-grid">
                    @foreach (var row in countRows.Where(r => r.Quantity > 0))
                    {
                        int spacing = row.Plant.PlantSpacing ?? 25;
                        double areaCm2 = row.Quantity * (double)spacing * spacing;
                        <div class="result-row">
                            <span>@row.Plant.PlantName × @row.Quantity</span>
                            <span>@((areaCm2 / 10000.0).ToString("F2")) m²</span>
                        </div>
                    }
                    <div class="result-total">
                        <strong>Totalt</strong>
                        <strong>@(TotalAreaM2.ToString("F2")) m²</strong>
                    </div>
                </div>

                <div class="bed-suggestions">
                    <h4>Förslag på ytor</h4>
                    @foreach (var sug in BedSuggestions)
                    {
                        <div class="bed-suggestion">
                            <Blazicon Svg="MdiIcon.FloorPlan" />
                            <span>@sug.Count st @sug.Label (@sug.WidthCm×@sug.LengthCm cm) — @((sug.Count * sug.WidthCm * sug.LengthCm / 10000.0).ToString("F1")) m² totalt</span>
                        </div>
                    }
                </div>

                <button class="btn-primary" @onclick="BuildGardenFromCount" style="margin-top:16px;">
                    <Blazicon Svg="Lucide.LayoutGrid" /> Skapa plan och placera ut växter
                </button>
            </div>
        }
        else
        {
            <p class="hint">Sök och lägg till de växter du vill odla ovan.</p>
        }
    </div>
}
else
{
    <!-- ══════════════════════════════════════════════════════════
         VISUAL PLANNER (ByArea mode or after ByCount generation)
    ══════════════════════════════════════════════════════════════ -->
    <div class="planner-workspace">

        @if (!sidebarOpen)
        {
            <a href="/" target="_blank" rel="noopener" class="back-to-app">
                <img src="small-logo.webp" width="22" height="22" decoding="async" alt="SeedPlan" />
                SeedPlan
            </a>
        }

        <!-- ── Sidebar ──────────────────────────────────────────── -->
        <aside class="planner-sidebar @(sidebarOpen ? "open" : "")">
            <div class="sidebar-top">
                <button class="btn-icon back-btn" @onclick="BackToStart"><Blazicon Svg="Lucide.ArrowLeft" /></button>
                <input class="garden-name-input" @bind="activeGarden!.Name" placeholder="Namn på planering" />
            </div>

            <!-- ── Collapsible: Ytor ───────────────────────────── -->
            <div class="sidebar-section no-pad">
                <button class="section-toggle" @onclick='() => ToggleSection("areas")'>
                    <span>Ytor (@activeGarden!.Areas.Count)</span>
                    <div class="toggle-right">
                        <button class="btn-icon" @onclick="AddArea" @onclick:stopPropagation="true">
                            <Blazicon Svg="Lucide.Plus" />
                        </button>
                        <Blazicon Svg="@(openSections.Contains("areas") ? Lucide.ChevronUp : Lucide.ChevronDown)" />
                    </div>
                </button>
                @if (openSections.Contains("areas"))
                {
                    <div class="section-body">
                        @foreach (var area in activeGarden!.Areas)
                        {
                            <div class="area-item @(selectedArea == area ? "active" : "")" @onclick="() => SelectArea(area)">
                                <span class="color-dot" style="background:@area.Color"></span>
                                <span class="area-item-name">@area.Name</span>
                                <span class="area-fill">@GetFillPercent(area)%</span>
                                <button class="btn-icon danger" @onclick:stopPropagation="true" @onclick="() => RemoveArea(area)">
                                    <Blazicon Svg="Lucide.Trash2" />
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>

            @if (selectedArea != null)
            {
                <!-- ── Collapsible: Inställningar ──────────────────── -->
                <div class="sidebar-section no-pad">
                    <button class="section-toggle" @onclick='() => ToggleSection("settings")'>
                        <span>Inställningar</span>
                        <Blazicon Svg="@(openSections.Contains("settings") ? Lucide.ChevronUp : Lucide.ChevronDown)" />
                    </button>
                    @if (openSections.Contains("settings"))
                    {
                        <div class="section-body area-settings">
                            <label>Namn</label>
                            <input class="form-input" @bind="selectedArea.Name" />

                            <label>Färg</label>
                            <div class="color-picker">
                                @foreach (var c in AreaColors)
                                {
                                    <button class="color-swatch @(selectedArea.Color == c ? "selected" : "")"
                                            style="background:@c"
                                            @onclick="() => selectedArea.Color = c"></button>
                                }
                            </div>

                            <div class="dim-row">
                                <div class="input-block">
                                    <label>Bredd (cm)</label>
                                    <input type="number" class="form-input" min="10" @bind="selectedArea.WidthCm" />
                                </div>
                                <div class="input-block">
                                    <label>Längd (cm)</label>
                                    <input type="number" class="form-input" min="10" @bind="selectedArea.LengthCm" />
                                </div>
                            </div>

                            <div class="preset-btns">
                                <button class="btn-chip" @onclick='() => ApplyPreset(selectedArea, 80, 120)'>Pallkrage</button>
                                <button class="btn-chip" @onclick='() => ApplyPreset(selectedArea, 80, 60)'>Halvpallkrage</button>
                                <button class="btn-chip" @onclick='() => ApplyPreset(selectedArea, 120, 240)'>Friland 1,2×2,4</button>
                            </div>
                        </div>
                    }
                </div>

                <!-- ── Collapsible: Växter i ytan ──────────────────── -->
                <div class="sidebar-section no-pad">
                    <button class="section-toggle" @onclick='() => ToggleSection("plants")'>
                        <span>@selectedArea.Name (@selectedArea.Crops.Count st)</span>
                        <Blazicon Svg="@(openSections.Contains("plants") ? Lucide.ChevronUp : Lucide.ChevronDown)" />
                    </button>
                    @if (openSections.Contains("plants"))
                    {
                        <div class="section-body">
                            @if (selectedArea.Crops.Any())
                            {
                                <div class="crops-list">
                                    @foreach (var crop in selectedArea.Crops.ToList())
                                    {
                                        <div class="crop-list-item">
                                            <span class="color-dot" style="background:@GetColor(crop.Plant.Id)"></span>
                                            <span class="crop-list-name">@crop.Plant.PlantName</span>
                                            <button class="btn-icon danger" @onclick="() => RemoveCrop(selectedArea, crop)">
                                                <Blazicon Svg="Lucide.X" />
                                            </button>
                                        </div>
                                    }
                                </div>
                                <button class="btn-secondary btn-sm danger" style="margin-top:6px;width:100%;"
                                        @onclick="() => selectedArea.Crops.Clear()">
                                    <Blazicon Svg="Lucide.Trash2" /> Rensa alla
                                </button>
                            }
                            else
                            {
                                <p class="hint" style="font-size:.8rem;margin:0;">Inga växter tillagda än.</p>
                            }
                        </div>
                    }
                </div>

                <!-- ── Collapsible: Lägg till växter ──────────────── -->
                <div class="sidebar-section no-pad" style="position:relative;">
                    <button class="section-toggle" @onclick='() => ToggleSection("add")'>
                        <span>Lägg till växter</span>
                        <Blazicon Svg="@(openSections.Contains("add") ? Lucide.ChevronUp : Lucide.ChevronDown)" />
                    </button>
                    @if (openSections.Contains("add"))
                    {
                        <div class="section-body">
                            <input class="form-input" placeholder="Sök växt…"
                                   value="@searchQuery" @oninput="OnSearchInput" />
                            @if (searchResults.Any())
                            {
                                <div class="dropdown">
                                    @foreach (var p in searchResults)
                                    {
                                        <div class="dropdown-item" @onclick="() => SelectPlant(p)">
                                            <strong>@p.PlantName</strong>
                                            <span>@p.PlantSpacing cm</span>
                                        </div>
                                    }
                                </div>
                            }
                            @if (pendingPlant != null)
                            {
                                <div class="pending-plant-row">
                                    <span class="color-dot" style="background:@GetColor(pendingPlant.Id)"></span>
                                    <span class="pending-plant-name">@pendingPlant.PlantName</span>
                                    <div class="qty-stepper">
                                        <button class="qty-btn" @onclick="() => { if (pendingQty > 1) pendingQty--; }">−</button>
                                        <input type="number" class="qty-input" min="1" @bind="pendingQty" />
                                        <button class="qty-btn" @onclick="() => pendingQty++">+</button>
                                    </div>
                                    <button class="btn-approve" @onclick="AddPendingToArea">Lägg till</button>
                                    <button class="btn-icon" @onclick="() => pendingPlant = null"><Blazicon Svg="Lucide.X" /></button>
                                </div>
                            }

                            <div class="area-util">
                                <span>Utnyttjad: <strong>@GetFillPercent(selectedArea)%</strong></span>
                                <button class="btn-secondary btn-sm" @onclick="() => AutoFill(selectedArea)">
                                    <Blazicon Svg="Lucide.LayoutGrid" /> Fyll automatiskt
                                </button>
                            </div>

                            @if (userId != null)
                            {
                                <button class="btn-import-sowings" style="margin-top:10px;"
                                        @onclick="ToggleSowingPanel" disabled="@isImporting">
                                    @if (isImporting)
                                    {
                                        <span class="spinner-sm"></span><span>Hämtar…</span>
                                    }
                                    else
                                    {
                                        <Blazicon Svg="Lucide.Download" />
                                        <span>@(showSowingPanel ? "Dölj sådder" : "Hämta från sådder")</span>
                                    }
                                </button>

                                @if (showSowingPanel && sowingPlants.Any())
                                {
                                    <div class="sowing-panel">
                                        @foreach (var (plant, qty) in sowingPlants)
                                        {
                                            int placed = GetPlantCountInGarden(plant);
                                            int remaining = qty - placed;
                                            bool done = remaining <= 0;
                                            <div class="sowing-item @(done ? "disabled" : "")"
                                                 @onclick="() => { if (!done) SelectPlantFromSowing(plant, remaining); }">
                                                <span class="color-dot" style="background:@GetColor(plant.Id)"></span>
                                                <span class="sowing-item-name">@plant.PlantName</span>
                                                @if (done)
                                                {
                                                    <span class="sowing-item-tag">klart</span>
                                                }
                                                else
                                                {
                                                    <span class="sowing-item-qty">@remaining av @qty kvar</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                                else if (showSowingPanel)
                                {
                                    <p class="hint" style="font-size:.8rem;margin-top:8px;">Inga matchande sådder hittades.</p>
                                }
                            }
                        </div>
                    }
                </div>
            }

            <!-- Save -->
            <div class="sidebar-save">
                @if (userId != null)
                {
                    <button class="btn-primary" @onclick="SaveGarden" disabled="@isSaving">
                        @if (isSaving) { <span>Sparar…</span> } else { <Blazicon Svg="Lucide.Save" /><span> Spara</span> }
                    </button>
                    @if (saveMessage != null)
                    {
                        <span class="save-msg">@saveMessage</span>
                    }
                }
                else
                {
                    <p class="hint">Logga in för att spara.</p>
                }
            </div>
        </aside>

        <!-- Mobile sidebar toggle -->
        <button class="sidebar-toggle" @onclick="() => sidebarOpen = !sidebarOpen">
            <Blazicon Svg="@(sidebarOpen ? Lucide.X : Lucide.Settings2)" />
        </button>

        <!-- ── Canvas ────────────────────────────────────────────── -->
        <div class="planner-canvas" @onpointermove="HandlePointerMove" @onpointerup="HandlePointerUp" @onpointerleave="HandlePointerUp">
            @foreach (var area in activeGarden!.Areas)
            {
                <div class="bed-wrapper">
                    <div class="bed-label" style="border-color:@area.Color">
                        <span class="color-dot" style="background:@area.Color"></span>
                        @area.Name
                        <span class="bed-dims">@area.WidthCm×@area.LengthCm cm</span>
                    </div>
                    <div class="garden-bed"
                         style="width:@(area.WidthCm * Scale)px; height:@(area.LengthCm * Scale)px; --bed-color:@area.Color;"
                         @onpointerenter="() => OnBedEnter(area)"
                         @onpointerleave="() => OnBedLeave(area)">

                        @foreach (var crop in area.Crops)
                        {
                            int spacing = crop.Plant.PlantSpacing ?? 20;
                            double dPx = spacing * Scale;
                            double lPx = crop.CenterX * Scale - dPx / 2;
                            double tPx = crop.CenterY * Scale - dPx / 2;
                            string initials = crop.Plant.PlantName.Length > 1
                                ? crop.Plant.PlantName[..2]
                                : crop.Plant.PlantName;

                            <div class="crop-circle @(draggedCrop?.Id == crop.Id ? "is-dragging" : "") @(draggedCrop?.Id == crop.Id && dragTargetArea != dragSourceArea ? "leaving-area" : "")"
                                 style="width:@(dPx)px;height:@(dPx)px;left:@(lPx)px;top:@(tPx)px;background:@GetColor(crop.Plant.Id);"
                                 title="@crop.Plant.PlantName (@spacing cm)"
                                 @onpointerdown="(e) => StartDrag(crop, area, e)"
                                 @onpointerdown:stopPropagation="true">
                                <span class="crop-name">@initials</span>
                                <button class="crop-delete"
                                        @onclick="() => RemoveCrop(area, crop)"
                                        @onclick:stopPropagation="true"
                                        @onpointerdown:stopPropagation="true">×</button>
                            </div>
                        }

                        <!-- Drop zone highlight when dragging from a different area -->
                        @if (draggedCrop != null && dragTargetArea == area && area != dragSourceArea)
                        {
                            <div class="drop-highlight"></div>
                        }
                    </div>
                </div>
            }

            @if (!activeGarden!.Areas.Any())
            {
                <div class="canvas-empty">
                    <Blazicon Svg="MdiIcon.FloorPlan" />
                    <p>Lägg till en yta i sidopanelen för att börja planera.</p>
                </div>
            }
        </div>
    </div>
}

@code {
    // ── Constants ─────────────────────────────────────────────────────────────
    private const double Scale = 3.0;

    private static readonly string[] AreaColors = new[]
    {
        "#86efac", "#93c5fd", "#fcd34d", "#fca5a5",
        "#c4b5fd", "#fdba74", "#5eead4", "#f9a8d4"
    };

    private static readonly string[] CropColors = new[]
    {
        "#16a34a","#2563eb","#ca8a04","#dc2626",
        "#7c3aed","#ea580c","#0d9488","#db2777"
    };

    private string GetColor(int plantId) => CropColors[Math.Abs(plantId) % CropColors.Length];

    // ── State ──────────────────────────────────────────────────────────────────
    private enum PlannerMode { ModeSelect, ByArea, ByCount }

    private bool isLoading = true;
    private bool showMobileWarning = false;
    private bool isSaving;
    private string? saveMessage;
    private string? userId;
    private bool sidebarOpen = true;

    private List<Garden> gardens = new();
    private Garden? activeGarden;
    private CultivationArea? selectedArea;
    private PlannerMode plannerMode = PlannerMode.ModeSelect;

    // Plant search
    private string searchQuery = string.Empty;
    private List<Plant> searchResults = new();
    private List<Plant> plantLibrary = new();

    // Pending plant add
    private Plant? pendingPlant;
    private int pendingQty = 1;

    // Delete confirm
    private bool showDeleteConfirm;
    private Garden? gardenToDelete;

    // Drag
    private PlantedCrop? draggedCrop;
    private CultivationArea? dragSourceArea;
    private CultivationArea? dragTargetArea;
    private double dragOffsetX, dragOffsetY;
    private double lastPointerX, lastPointerY;

    // Count mode
    private class CountRow { public Plant Plant = null!; public int Quantity; }
    private List<CountRow> countRows = new();
    private bool isImporting = false;

    // Sowing import panel (shared between ByArea and ByCount)
    private bool showSowingPanel = false;
    private List<(Plant Plant, int Quantity)> sowingPlants = new();

    // Collapsible sidebar sections
    private HashSet<string> openSections = new() { "areas", "plants", "add" };

    private double TotalAreaM2 => countRows.Sum(r =>
    {
        int sp = r.Plant.PlantSpacing ?? 25;
        return r.Quantity * (double)sp * sp / 10000.0;
    });

    private record BedSuggestion(int Count, string Label, int WidthCm, int LengthCm);
    private IEnumerable<BedSuggestion> BedSuggestions
    {
        get
        {
            double totalCm2 = TotalAreaM2 * 10000;
            yield return new BedSuggestion(
                (int)Math.Ceiling(totalCm2 / (80 * 120)), "pallkrage", 80, 120);
            yield return new BedSuggestion(
                (int)Math.Ceiling(totalCm2 / (80 * 60)), "halvpallkrage", 80, 60);
            yield return new BedSuggestion(
                (int)Math.Ceiling(totalCm2 / (120 * 240)), "frilandsyta 1,2×2,4 m", 120, 240);
        }
    }

    // ── Lifecycle ──────────────────────────────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        AuthStateProvider.AuthenticationStateChanged += OnAuthStateChanged;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            plantLibrary = await PlantLibrary.GetAllPlantsAsync();
            if (userId != null)
                gardens = await PlanService.GetUserGardensAsync(userId);

            var dismissed = await JS.InvokeAsync<string>("localStorage.getItem", "plannerMobileWarningDismissed");
            if (string.IsNullOrEmpty(dismissed))
            {
                var width = await JS.InvokeAsync<int>("eval", "window.innerWidth");
                if (width < 768)
                    showMobileWarning = true;
            }
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        var authState = await task;
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (userId != null)
            gardens = await PlanService.GetUserGardensAsync(userId);
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthStateChanged;
    }

    private async Task DismissMobileWarning()
    {
        showMobileWarning = false;
        await JS.InvokeVoidAsync("localStorage.setItem", "plannerMobileWarningDismissed", "1");
    }


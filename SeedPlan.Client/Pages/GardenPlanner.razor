        var area = new CultivationArea
        {
            Name = $"Yta {idx + 1}",
            Color = AreaColors[idx % AreaColors.Length],
            GardenId = activeGarden.Id,
            SortOrder = idx
        };
        activeGarden.Areas.Add(area);
        selectedArea = area;

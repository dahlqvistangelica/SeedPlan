    }

    private void RemoveCrop(CultivationArea area, PlantedCrop crop) => area.Crops.Remove(crop);

    private void RemoveArea(CultivationArea area)
    {
        activeGarden!.Areas.Remove(area);
        if (selectedArea == area)
            selectedArea = activeGarden.Areas.FirstOrDefault();

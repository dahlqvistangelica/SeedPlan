@page "/guide"
@implements IDisposable
@using SeedPlan.Shared.Models
@inject IPlantLibraryService PlantService
@inject IJSRuntime JS
@using System.Text.Json

<div class="guide-container">
    <header class="guide-header">
        <h1 class="serif-title">Växtguide</h1>
        <button class="filter-toggle @(showFilters ? "active" : "")" @onclick="ToggleFilters">
            <Blazicon Svg="Lucide.Funnel" />
        </button>
    </header>

    @* SEARCHFIELD *@
    <div class="search-section">
        <div class="search-wrapper">
            <input type="text" value="@searchText" @oninput="OnSearchInput" placeholder="Sök växt..." class="search-input" />
        </div>
    </div>

    @* FILTERPANEL *@
    @if (showFilters)
    {
        <div class="filter-panel fade-in">
            <div class="filter-group">
                <label>HÄRDIGHET</label>
                <div class="chip-group">
                    <button class="chip @(activeHardiness == null ? "active" : "")" @onclick="() => SetHardiness(null)">Alla</button>
                    <button class="chip @(activeHardiness == 2 ? "active" : "")" @onclick="() => SetHardiness(2)">Härdig</button>
                    <button class="chip @(activeHardiness == 1 ? "active" : "")" @onclick="() => SetHardiness(1)">Halvhärdig</button>
                    <button class="chip @(activeHardiness == 0 ? "active" : "")" @onclick="() => SetHardiness(0)">Känslig</button>
                </div>
            </div>

            <div class="filter-group">
                <label>EGENSKAPER</label>
                <div class="property-row" @onclick="ToggleLightGerm">
                    <span>Ljusgroende</span>
                    <span class="status-text">@(onlyLightGerm ? "Ja" : "Alla")</span>
                </div>
                <div class="property-row" @onclick="ToggleTopping">
                    <span>Toppas</span>
                    <span class="status-text">@(onlyTopping ? "Ja" : "Alla")</span>
                </div>
            </div>

            <div class="filter-footer">
                <button class="reset-btn" @onclick="ResetFilters">NOLLSTÄLL FILTER</button>
            </div>
        </div>
    }

    @* PLANTGRID *@
    <div class="plant-grid">
        @foreach (var plant in FilteredPlants)
        {
            <div class="plant-card" @onclick="() => OpenPlantDetail(plant)">
                <div class="card-top">
                    <div class="plant-icon-circle">
                        <Blazicon Svg="Lucide.Leaf" />
                    </div>
                    <span class="hardiness-badge @GetHardinessClass(plant.HardinessLevel)">
                        @GetHardinessText(plant.HardinessLevel)
                    </span>
                </div>
                
                <div class="card-body">
                    <h3 class="plant-name">@plant.PlantName</h3>
                    <p class="sowing-info">Sås @plant.SowingLeadTime v. före frost</p>
                </div>

                <div class="card-footer">
                    <div class="feature-icons">
                        @if (plant.IsLightGerminating)
                        {
                            <div class="icon-light">
                            <Blazicon Svg="Lucide.Sparkles" class="icon-light" />
                            </div>
                        }
                        @if (plant.RequiresTopping)
                        {<div class="icon-topping">
                            <Blazicon Svg="Lucide.Scissors" class="icon-topping" />
                            </div>
                        }
                    </div>
                    <div class="arrow">
                        <Blazicon Svg="Lucide.ChevronRight" class="arrow" />
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<PlantDetailModal IsVisible="showDetailModal" Plant="selectedPlant" OnClose="() => showDetailModal = false" />

@code {
    private List<Plant> allPlants = new();
    private string searchText = "";
    private bool showFilters = false;
    private int? activeHardiness = null;
    private bool onlyLightGerm = false;
    private bool onlyTopping = false;
    private CancellationTokenSource? _searchCts;

    private const string StorageKey = "guide_filters";

    protected override async Task OnInitializedAsync()
    {
        searchText = "";
        allPlants = await PlantService.GetAllPlantsAsync();
    }
    //MODAL HANDLING AND HELP METHODS
    private void ToggleFilters() => showFilters = !showFilters;
    private async Task SetHardiness(int? level) { activeHardiness = level; StateHasChanged(); await SaveFilters(); }
    private async Task ToggleLightGerm() { onlyLightGerm = !onlyLightGerm; StateHasChanged(); await SaveFilters(); }
    private async Task ToggleTopping() { onlyTopping = !onlyTopping; StateHasChanged(); await SaveFilters(); }
    private string GetHardinessText(int level) => level switch { 0 => "KÄNSLIG", 1 => "HALVHÄRDIG", 2 => "HÄRDIG", _ => "" };
    private string GetHardinessClass(int level) => level switch { 0 => "sensitive", 1 => "half-hardy", 2 => "hardy", _ => "" };
    private bool showDetailModal = false;
    private Plant? selectedPlant;
    private void OpenPlantDetail(Plant plant) { selectedPlant = plant; showDetailModal = true; }

    private async Task ResetFilters()
    {
        searchText = "";
        activeHardiness = null;
        onlyLightGerm = false;
        onlyTopping = false;
        await JS.InvokeVoidAsync("localStorage.removeItem", StorageKey);
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? "";

        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await Task.Delay(500, token); // Longer delay to save memory/Js-call. 
            if (!token.IsCancellationRequested)
            {
                await SaveFilters();
            }
        }
        catch (TaskCanceledException) { }
    }

    public void Dispose()
    {
        _searchCts?.Cancel();
        _searchCts?.Dispose();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadFilters();
            StateHasChanged(); // Force change to UI
        }
    }
    private async Task SaveFilters()
    {
        var filterData = new
        {
            SearchText = searchText,
            Hardiness = activeHardiness,
            LightGerm = onlyLightGerm,
            Topping = onlyTopping
        };

        var json = JsonSerializer.Serialize(filterData);
        await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, json);
    }

    /// <summary>
    /// Asynchronously restores the UI filter states from the browser's local storage.
    /// Parses the stored JSON to populate search text, hardiness levels, and specific plant properties.
    /// </summary>
    /// <returns>A task representing the asynchronous load operation.</returns>
    private async Task LoadFilters()
    {
        var json = await JS.InvokeAsync<string>("localStorage.getItem", StorageKey);
        if (string.IsNullOrEmpty(json)) return;

        try
        {
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;

            // Use GetProperty safely
            if (root.TryGetProperty("SearchText", out var s)) searchText = s.GetString() ?? "";

            if (root.TryGetProperty("Hardiness", out var h))
            {
                activeHardiness = h.ValueKind == JsonValueKind.Null ? null : h.GetInt32();
            }

            if (root.TryGetProperty("LightGerm", out var l)) onlyLightGerm = l.GetBoolean();
            if (root.TryGetProperty("Topping", out var t)) onlyTopping = t.GetBoolean();

            // Force reload
            StateHasChanged();
        }
        catch
        {

        }
    }

    /// <summary>
    /// Gets a filtered collection of plants based on the current search text,
    /// hardiness level, and specific growth properties like light germination or topping requirements.
    /// </summary>
    /// <value>An enumerable collection of plants that match the active filter criteria.</value>
    private IEnumerable<Plant> FilteredPlants
    {
        get
        {
            var query = allPlants.AsEnumerable();

            // 1. Search-text
            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(p => p.PlantName != null && p.PlantName.Contains(searchText, StringComparison.OrdinalIgnoreCase));
            }

            // 2. Hardiness
            if (activeHardiness.HasValue)
            {
                query = query.Where(p => p.HardinessLevel == activeHardiness.Value);
            }

            // 3. Properties
            if (onlyLightGerm) query = query.Where(p => p.IsLightGerminating);
            if (onlyTopping) query = query.Where(p => p.RequiresTopping);

            return query.ToList(); // Force-filtration 
        }
    }
}
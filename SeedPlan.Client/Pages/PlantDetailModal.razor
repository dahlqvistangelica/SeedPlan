@using SeedPlan.Shared.Models
@inject IUserInventoryService SeedService
@inject IJSRuntime JS
@inject Supabase.Client _supabase
@inject IPlantLibraryService PlantService

@if (Plant != null && IsVisible)
{
    <div class="modal-overlay" @onclick="Close">
        <div class="detail-card fade-in" @onclick:stopPropagation>
            

            <header class="detail-header">
                <div class="title-with-plus">
                    <div class="plant-icon-circle @GetPlantCategory(Plant.Category)">
                        <Blazicon Svg="@GetPlantBlazicon(Plant.Category)" />
                    </div>
                    <h2 class="serif-title">@Plant.PlantName</h2>
                </div>
                <div class="modal-actions">
                    <button class="expand-btn" @onclick="ToggleAddForm" title="Lägg till frö">
                        <Blazicon Svg="MdiIcon.SeedPlusOutline" />
                    </button>
                    <button class="close-x" @onclick="Close">×</button>
                </div>
            </header>

            @if (ownedSeeds.Any())
            {
                <details class="inventory-section">
                    <summary class="inventory-summary">
                        <div class="inventory-summary-main">
                            <span class="inventory-chevron">
                                <Blazicon Svg="Lucide.ChevronRight" />
                            </span>
                            <span class="inventory-summary-title">Sorter i lager</span>
                        </div>
                        <span class="seed-count">@ownedSeeds.Count</span>
                    </summary>

                    <div class="seed-variety-list">
                        @foreach (var seed in ownedSeeds)
                        {
                            <div class="variety-card">
                                <div class="variety-info">
                                    <span class="variety-name">@(string.IsNullOrEmpty(seed.VarietyName) ? "Okänd sort" : seed.VarietyName)</span>
                                    <span class="variety-meta">@seed.Quantity st</span>
                                </div>
                            </div>
                        }
                    </div>
                </details>
            }

            @if (showAddForm)
            {
                <div class="add-seed-container slide-down">
                    <div class="form-header">
                        <h3>LÄGG TILL FRÖ</h3>
                        <button class="text-link" @onclick="ToggleAddForm">Avbryt</button>
                    </div>

                    <div class="form-grid">
                        <div class="input-block full">
                            <label>Sortnamn</label>
                            <input type="text" @bind="newSeed.VarietyName" placeholder="T.ex. Genovese" class="form-input" />
                        </div>

                        <div class="input-row">
                            <div class="input-block">
                                <label>Antal fröer</label>
                                <input type="number" @bind="newSeed.Quantity" class="form-input" />
                            </div>
                            <div class="input-block">
                                <label>Utgångsdatum</label>
                                <input type="date" @bind="newSeed.ExpiryDate" class="form-input" />
                            </div>
                        </div>

                        <div class="input-block full">
                            <label>Noteringar</label>
                            <textarea @bind="newSeed.Notes" placeholder="T.ex. köpt på rean, ekologiska, bra grobarhet..." class="sp-textarea"></textarea>
                        </div>
                    </div>

                    <button class="save-btn-large" @onclick="HandleSave">Spara i lager</button>
                </div>
            }

            <div class="info-grid">
                <div class="info-box">
                    <label>VETENSKAPLIGT NAMN</label>
                    <span>@(Plant.ScientificName ?? "Ej angivet")</span>
                </div>
                <div class="info-box">
                    <label>FÖRODLING</label>
                    <span>@Plant.SowingLeadTimeMin - @Plant.SowingLeadTime veckor</span>
                </div>
                <div class="info-box">
                    <label>UTPLANTERING</label>
                    <span>@GetPlantingText(Plant.WeeksBeforeFrost)</span>
                </div>
                <div class="info-box">
                    <label>PLANTAVSTÅND</label>
                    <span>@(Plant.PlantSpacing?.ToString() + " cm" ?? "Okänt")</span>
                </div>
                <div class="info-box">
                    <label>UTVECKLINGSTID</label>
                    <span>@(Plant.DevelopDaysMin) - @(Plant.DevelopDaysMax) dagar</span>
                </div>
                <div class="info-box">
                    <label>SÅDJUP</label>
                    <span>@(Plant.SowingDepth?.ToString() + " cm" ?? "Okänt")</span>
                </div>
            </div>

            <div class="growing-advice">
                <label>ODLINGSRÅD</label>
                <div class="growing-advice-text">@GetSowingAdvice(Plant)</div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Plant? Plant { get; set; }
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private List<Variety> allVarieties = new();
    private bool showAddForm = false;
    private Seed newSeed = new() { ExpiryDate = DateTime.Now.AddYears(2), Quantity = 1 };
    private DateTime purchaseDate = DateTime.Now;
    private List<Seed> ownedSeeds = new();
    private string errorMessage = "";
    private string GetPlantCategory(PlantCategory category) => category switch { PlantCategory.Vegetable => "vegetable", PlantCategory.Flower => "flower", PlantCategory.Herb => "herb", PlantCategory.Fruit => "fruit" };
    private SvgIcon GetPlantBlazicon(PlantCategory category) => category switch
    {
        PlantCategory.Vegetable => Lucide.Carrot,
        PlantCategory.Flower => Lucide.Flower,
        PlantCategory.Herb => MdiIcon.Clover,
        PlantCategory.Fruit => Lucide.Apple
    };

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && Plant != null)
        {
            var allSeeds = await SeedService.GetMySeeds();
            ownedSeeds = allSeeds.Where(s => s.PlantId == Plant.Id).ToList();

            allVarieties = await PlantService.GetVarietiesForPlantAsync(Plant.Id);
            await Task.Delay(50);
        }
    }

    private void ToggleAddForm() => showAddForm = !showAddForm;

    private string GetSowingAdvice(Plant plant) => $"Inga planteringsråd om {plant.PlantName} ännu";

    private string GetPlantingText(int weeks)
    {
        if (weeks <= 0)
        {
            return "Efter sista frost";
        }

        return $"{weeks}v. före sista frost";
    }

    private async Task HandleSave()
    {
        if (Plant == null)
        {
            return;
        }

        try
        {
            errorMessage = "";
            newSeed.PlantId = Plant.Id;
            newSeed.Name = Plant.PlantName;
            newSeed.UserId = _supabase.Auth.CurrentUser?.Id;

            if (!string.IsNullOrWhiteSpace(newSeed.VarietyName))
            {
                var existingVariety = allVarieties.FirstOrDefault(v => v.VarietyName.Equals(newSeed.VarietyName, StringComparison.OrdinalIgnoreCase));

                if (existingVariety == null)
                {
                    var newVarietyObj = new Variety
                    {
                        PlantId = Plant.Id,
                        VarietyName = newSeed.VarietyName
                    };

                    var savedVariety = await PlantService.AddVarietyAsync(newVarietyObj);
                    newSeed.VarietyId = savedVariety.Id;
                    allVarieties.Add(savedVariety);
                }
                else
                {
                    newSeed.VarietyId = existingVariety.Id;
                }
            }

            await SeedService.AddSeed(newSeed);
            newSeed = new Seed { ExpiryDate = DateTime.Now.AddYears(2), Quantity = 1 };
            showAddForm = false;
            await OnSaved.InvokeAsync();
            await Close();
        }
        catch (Exception ex)
        {
            errorMessage = "Kunde inte spara fröet: " + ex.Message;
            await JS.InvokeVoidAsync("alert", errorMessage);
        }
    }

    private async Task Close()
    {
        showAddForm = false;
        await OnClose.InvokeAsync();
    }
}
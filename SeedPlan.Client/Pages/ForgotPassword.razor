@page "/forgot-password"
@inject Supabase.Client Supabase
@inject NavigationManager Nav

<div class="auth-container">
    <div class="card-box" style="max-width: 400px; margin: 0 auto; padding: 2rem;">
        <h2 class="serif-title">Glömt lösenordet?</h2>
        <p style="margin-bottom: 1.5rem; color: var(--text-muted);">
            Fyll i din mailadress så skickar vi en länk för att återställa ditt lösenord.
        </p>

        @if (isSuccess)
        {
            <div class="success-message" style="color: green; font-weight: bold; margin-bottom: 1rem;">
                Kolla din inkorg! Vi har skickat en länk till dig.
            </div>
            <button class="sp-btn sp-btn-outline" style="width: 100%;" @onclick='() => Nav.NavigateTo("/login")'>
                Tillbaka till inloggning
            </button>
        }
        else
        {
            <div class="input-block">
                <label>Mailadress</label>
                <input type="email" @bind="email" class="sp-input" placeholder="din@mail.se" />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div style="color: red; margin-bottom: 1rem; font-size: 0.9rem;">@errorMessage</div>
            }

            <button class="btn-primary" style="width: 100%; margin-top: 1rem;" @onclick="SendResetEmail" disabled="@isLoading">
                @(isLoading ? "Skickar..." : "Skicka återställningslänk")
            </button>
        }
    </div>
</div>

@code {
    private string email = "";
    private string errorMessage = "";
    private bool isLoading = false;
    private bool isSuccess = false;

    private async Task SendResetEmail()
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            errorMessage = "Du måste fylla i en mailadress.";
            return;
        }

        isLoading = true;
        errorMessage = "";

        try
        {
            
            var options = new Supabase.Gotrue.ResetPasswordForEmailOptions(email)
            {
                RedirectTo = Nav.BaseUri + "update-password"
            };

            
            await Supabase.Auth.ResetPasswordForEmail(options);
            
            isSuccess = true;
        }
        catch (Exception ex)
        {
            errorMessage = "Kunde inte skicka mailet. Kontrollera att adressen stämmer.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }
}
@page "/settings"
@using SeedPlan.Shared.Models
@inject IUserProfileService ProfileService
@inject NotificationService NotificationService
@inject INotificationSettingsService NotifSettingsService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IFeatureService FeatureService

<SeoHead Title="Inställningar - SeedPlan"
         Description="Hantera dina inställningar i SeedPlan, inklusive frostdatum, plats, aviseringar och profil."
         Keywords="inställningar, frostdatum, aviseringar, profil, seedplan" />

@if (isLoading)
{
    <LoadingSpinner Text="Laddar inställningar..." />
}
else
{
    <div class="settings-overview">
        <header class="settings-header">
            <h1 class="serif-title">Inställningar</h1>
            <p>Översikt av dina inställningar och kontofunktioner.</p>
        </header>

        <div class="settings-cards">
            <div class="settings-card" @onclick="() => showFrostModal = true">
                <div class="icon-circle">
                    <Blazicon Svg="Lucide.Calendar" />
                </div>
                <div class="card-text">
                    <div class="title">Frostdatum</div>
                    <div class="value">@GetFrostDateText()</div>
                </div>
            </div>

            <div class="settings-card" @onclick="() => showZoneModal = true">
                <div class="icon-circle">
                    <Blazicon Svg="Lucide.MapPin" />
                </div>
                <div class="card-text">
                    <div class="title">Plats</div>
                    <div class="value">@GetZoneText()</div>
                </div>
            </div>

            <div class="settings-card" @onclick="() => showNotificationsModal = true">
                <div class="icon-circle">
                    <Blazicon Svg="Lucide.Bell" />
                </div>
                <div class="card-text">
                    <div class="title">Aviseringar</div>
                    <div class="value">@(notifSettings.Enabled ? "Påslagna" : "Avstängda")</div>
                </div>
            </div>

            <div class="settings-card" @onclick="() => NavigateToProfile()">
                <div class="icon-circle">
                    <Blazicon Svg="Lucide.User" />
                </div>
                <div class="card-text">
                    <div class="title">Profil</div>
                    <div class="value">Redigera din profil</div>
                </div>
            </div>

            <div class="settings-card" @onclick="() => showInfoModal = true">
                <div class="icon-circle">
                    <Blazicon Svg="Lucide.CircleQuestionMark" />
                </div>
                <div class="card-text">
                    <div class="title">Info</div>
                    <div class="value">Viktig info om appen.</div>
                </div>
            </div>
        </div>

        @* --- ADMIN-MENY --- *@
        @if (userProfile != null && userProfile.IsAdmin)
        {
            <div class="settings-card" @onclick='() => Nav.NavigateTo("/admin/plants")'>
                <div class="icon-circle" style="background: #fefce8; color: #ca8a04;">
                    <Blazicon Svg="Lucide.Database" /> 
                </div>
                <div class="card-text">
                    <span class="title">Hantera växtbibliotek (Admin)</span>
                    <span class="value">Redigera arter, förodlingstider och kategorier</span>
                </div>
            </div>

            <div class="settings-card" @onclick='() => Nav.NavigateTo("/admin/features")'>
                <div class="icon-circle" style="background: #fefce8; color: #ca8a04;">
                    <Blazicon Svg="Lucide.Database" />
                </div>
                <div class="card-text">
                    <span class="title">Hantera features</span>
                    <span class="value">Redigera features och uppdatera info.</span>
                </div>
            </div>

            <div class="settings-card" @onclick='() => Nav.NavigateTo("/admin/dahlias")'>
                <div class="icon-circle" style="background: #fdf4ff; color: #9333ea;">
                    <Blazicon Svg="BootstrapIcon.Flower3" />
                </div>
                <div class="card-text">
                    <span class="title">Godkänn dahliasorter (Admin)</span>
                    <span class="value">Granska och godkänn inlagda sorter</span>
                </div>
            </div>
        }

        <div class="version-text">SeedPlan v.@currentVersion</div>
    </div>
}
@if (showFrostModal)
{
    <div class="settings-modal-backdrop">
        <div class="settings-modal">
            <h3>Uppdatera frostdatum</h3>
            <p class="muted">Detta datum används för att räkna ut såfönster.</p>

            <input type="date" @bind="userProfile.LastFrostDate" />

            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CloseFrostModal">Avbryt</button>
                <button class="btn-primary" @onclick="SaveFrostDate">Spara</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <div class="status-alert">@statusMessage</div>
            }
        </div>
    </div>
}
@if (showZoneModal)
{
    <div class="settings-modal-backdrop">
        <div class="settings-modal">
            <h3>Uppdatera växtzon</h3>
            <p class="muted">Ställ in din nuvarande växtzon.</p>

            <input type="number" @bind="userProfile.GrowingZone" />

            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CloseZoneModal">Avbryt</button>
                <button class="btn-primary" @onclick="SaveGrowingZone">Spara</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <div class="status-alert">@statusMessage</div>
            }
        </div>
    </div>
}

@if (showNotificationsModal)
{
    <div class="settings-modal-backdrop">
        <div class="settings-modal notif-modal">
            <h3>Aviseringar</h3>

            <label class="toggle-row">
                <input type="checkbox" @bind="notifSettings.Enabled" />
                <span>Aktivera push-aviseringar</span>
            </label>

            @if (notifSettings.Enabled)
            {
                <div class="notif-section">
                    <p class="notif-section-label">Påminn om kommande såddag</p>
                    <p class="muted small">Välj hur många dagar innan sådfönstret öppnar du vill få en notis.</p>
                    <div class="notif-chips">
                        @foreach (var day in new[] { 1, 2, 3, 5, 7, 14 })
                        {
                            var d = day;
                            var active = notifSettings.DaysBeforeSowing.Contains(d);
                            <button class="notif-chip @(active ? "active" : "")"
                                    @onclick="() => ToggleDayBeforeSowing(d)">
                                @d dag@(d == 1 ? "" : "ar")
                            </button>
                        }
                    </div>
                </div>

                <div class="notif-section">
                    <p class="notif-section-label">Påminn om orörda sådder</p>
                    <p class="muted small">Skicka en påminnelse om en sådd inte uppdaterats på X dagar.</p>
                    <div class="notif-chips">
                        @foreach (var day in new[] { 7, 10, 14, 21, 30 })
                        {
                            var d = day;
                            <button class="notif-chip @(notifSettings.DaysInactiveReminder == d ? "active" : "")"
                                    @onclick="() => notifSettings.DaysInactiveReminder = d">
                                @d dagar
                            </button>
                        }
                    </div>
                </div>
            }

            <p class="muted small ios-note">
                <strong>iPhone-användare:</strong> Spara SeedPlan på hemskärmen (Dela → "Lägg till på hemskärmen") och öppna appen därifrån för att ta emot aviseringar.
            </p>

            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CloseNotificationsModal">Avbryt</button>
                <button class="btn-primary" @onclick="SaveNotifications">Spara</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <div class="status-alert">@statusMessage</div>
            }
        </div>
    </div>
}

<InfoModal @bind-IsVisible="showInfoModal" />

@code {
    private bool isLoading = true;
    private UserProfile userProfile = new();
    private bool showFrostModal;
    private bool showZoneModal;
    private bool showInfoModal;
    private bool showNotificationsModal;
    private NotificationSettings notifSettings = new();
    private string statusMessage = "";
    private string currentVersion = "";

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            var profileTask = ProfileService.GetUserProfile();
            var notifTask = NotifSettingsService.GetAsync();
            var featureTask = FeatureService.GetLatestActiveFeatureAsync();

            await Task.WhenAll(profileTask, notifTask, featureTask);

            var profile = await profileTask;
            if (profile != null)
                userProfile = profile;
            else
            {
                userProfile.LastFrostDate = new DateTime(DateTime.Now.Year, 5, 15);
                userProfile.GrowingZone = 1;
            }

            notifSettings = await notifTask;
            currentVersion = (await featureTask)?.VersionTag ?? "Okänd version";
        }
        finally
        {
            isLoading = false;
            
        }
    }

    // FROST DATE
    private string GetFrostDateText()
        => userProfile.LastFrostDate.HasValue
            ? userProfile.LastFrostDate.Value.ToString("d MMM")
            : "Ej inställt";


    private void CloseFrostModal()
    {
        showFrostModal = false;
        statusMessage = "";
    }
    //GROWING ZONE

    private string GetZoneText()
        => userProfile.GrowingZone > 0 ? $"Zon {userProfile.GrowingZone}" : "Ej inställt";

    private void CloseZoneModal()
    {
        showZoneModal = false;
        statusMessage = "";
    }

    private void CloseNotificationsModal()
    {
        showNotificationsModal = false;
        statusMessage = "";
    }

    private async Task SaveFrostDate()
    {
        if (userProfile.LastFrostDate.HasValue)
        {
            userProfile.LastFrostDate = DateTime.SpecifyKind(userProfile.LastFrostDate.Value.Date, DateTimeKind.Utc);
        }

        await ProfileService.UpsertUserProfile(userProfile);
        statusMessage = "Frostdatum sparat ✨";
        await Task.Delay(1500);
        CloseFrostModal();
    }
    private async Task SaveGrowingZone()
    {
        if (userProfile.GrowingZone > 0 && userProfile.GrowingZone < 9)
        {
            userProfile.GrowingZone = userProfile.GrowingZone;
        }
        else
        {
            statusMessage = "Växtzon måste vara ett nummer mellan 1-8";
        }

        await ProfileService.UpsertUserProfile(userProfile);
        statusMessage = "Växtzon uppdaterad ✨";
        await Task.Delay(1500);
        CloseZoneModal();
    }

    private void ToggleDayBeforeSowing(int day)
    {
        var list = notifSettings.DaysBeforeSowing.ToList();
        if (list.Contains(day))
            list.Remove(day);
        else
            list.Add(day);
        notifSettings.DaysBeforeSowing = list.OrderBy(x => x).ToArray();
    }

    private async Task SaveNotifications()
    {
        await NotifSettingsService.UpsertAsync(notifSettings);

        if (notifSettings.Enabled)
            await NotificationService.SubscribeToPushAsync();
        else
            await NotificationService.UnsubscribeFromPushAsync();

        statusMessage = "Aviseringar uppdaterade ✨";
        await Task.Delay(1500);
        CloseNotificationsModal();
    }

    private void NavigateToProfile()
    {
        Nav.NavigateTo("/profile");
    }
}